---
/**
 * Wraps one design-system specimen — a single component or pattern shown
 * in the design gallery with a label, optional description, and a
 * checkered background to highlight transparency and edges.
 *
 * Used only by /[locale]/_design — not shipped to production routes.
 */
interface Props {
  name: string;
  description?: string;
  /** Tag the specimen with its inventory status. */
  status?: 'component' | 'inline' | 'missing' | 'inconsistent';
  /** Tighten the canvas — useful for tiny atoms like badges. */
  tight?: boolean;
  /** Show the canvas with a dark background instead of light. */
  dark?: boolean;
}

const { name, description, status, tight = false, dark = false } = Astro.props;

const statusStyle: Record<NonNullable<Props['status']>, { label: string; classes: string }> = {
  component: { label: 'Component', classes: 'bg-green-100 text-green-800' },
  inline: { label: 'Inline only', classes: 'bg-yellow-100 text-yellow-800' },
  missing: { label: 'Missing', classes: 'bg-red-100 text-red-800' },
  inconsistent: { label: 'Inconsistent', classes: 'bg-orange-100 text-orange-800' },
};
const badge = status ? statusStyle[status] : null;
---

<section class="border border-maxam-gray-300 rounded-lg overflow-hidden">
  <header class="px-4 py-3 bg-maxam-gray-100 border-b border-maxam-gray-300 flex items-start justify-between gap-3">
    <div>
      <h3 class="font-semibold text-maxam-black text-sm">{name}</h3>
      {description && <p class="text-xs text-maxam-gray-700 mt-0.5">{description}</p>}
    </div>
    {badge && (
      <span class={`text-[10px] font-semibold uppercase tracking-wide px-2 py-0.5 rounded-full shrink-0 ${badge.classes}`}>
        {badge.label}
      </span>
    )}
  </header>
  <div
    class:list={[
      'specimen-canvas',
      tight ? 'p-4' : 'p-6',
      dark ? 'bg-maxam-black' : 'bg-maxam-white',
    ]}
  >
    <slot />
  </div>
</section>

<style>
  /* Subtle checker pattern to show transparency / edges of atoms. */
  .specimen-canvas {
    background-image:
      linear-gradient(45deg, rgba(0, 0, 0, 0.025) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(0, 0, 0, 0.025) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(0, 0, 0, 0.025) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(0, 0, 0, 0.025) 75%);
    background-size: 16px 16px;
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
  }
</style>
