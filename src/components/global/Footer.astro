---
import type { Locale } from '../../types';
import { t, localePath } from '../../lib/i18n';
import MaxamLogo from '../ui/MaxamLogo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const copyright = t(locale, 'footer.copyright').replace('{year}', String(year));
---

<footer class="rubber-footer mt-auto">
  <div class="max-w-[var(--container-max)] mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={localePath(locale, '/')} class="inline-flex items-center" aria-label="MAXAM home">
          <MaxamLogo class="h-7 text-maxam-white" label="MAXAM" />
        </a>
        <p class="mt-3 text-sm leading-relaxed text-maxam-gray-300">
          {t(locale, 'site.description')}
        </p>
      </div>

      <!-- Products links -->
      <div>
        <h3 class="rubber-footer__heading">
          {t(locale, 'footer.products')}
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={localePath(locale, '/products')} class="rubber-footer__link">
              {t(locale, 'nav.products')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="rubber-footer__heading">
          {t(locale, 'nav.contact')}
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={localePath(locale, '/contact')} class="rubber-footer__link">
              {t(locale, 'nav.contact')}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/resources')} class="rubber-footer__link">
              {t(locale, 'nav.resources')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="rubber-footer__bottom">
      {copyright}
    </div>
  </div>
</footer>
