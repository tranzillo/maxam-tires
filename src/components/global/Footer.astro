---
/**
 * Footer — deep matte ground plane.
 *
 * Link parity with the header: the same top-level destinations only
 * (Products, Resources, Contact, Dealer Login) — no subnav columns.
 * Styles live in src/styles/components/footer.css.
 */
import type { Locale } from '../../types';
import { t, localePath } from '../../lib/i18n';
import MaxamLogo from '../ui/MaxamLogo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const copyright = t(locale, 'footer.copyright').replace('{year}', String(year));
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href={localePath(locale, '/')} class="footer-brand__logo" aria-label="MAXAM home">
          <MaxamLogo class="footer-brand__mark" label="MAXAM" />
        </a>
        <p class="footer-brand__description">
          {t(locale, 'site.description')}
        </p>
      </div>

      <!-- Top-level links — parity with the header nav -->
      <nav class="footer-nav">
        <a href={localePath(locale, '/products')} class="site-footer__link">
          {t(locale, 'nav.products')}
        </a>
        <a href={localePath(locale, '/resources')} class="site-footer__link">
          {t(locale, 'nav.resources')}
        </a>
        <a href={localePath(locale, '/contact')} class="site-footer__link">
          {t(locale, 'nav.contact')}
        </a>
        <a
          href="http://b2b.maxamtire.com/"
          class="site-footer__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t(locale, 'nav.dealer_login')}
          <svg class="footer-nav__external" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5h5v5M19 5l-7 7M5 5h6v2H7v10h10v-4h2v6H5V5z" />
          </svg>
        </a>
      </nav>
    </div>

    <div class="site-footer__bottom">
      {copyright}
    </div>
  </div>
</footer>
