---
import type { Locale, ArticleType } from '../../types';
import { t, localePath } from '../../lib/i18n';
import { getAllIndustries, getFeaturedProducts, getRecentArticles } from '../../lib/data';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MegaNav from './MegaNav.astro';
import FeaturedCard from '../ui/FeaturedCard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const industries = getAllIndustries(locale);
const featuredProduct = getFeaturedProducts(locale, 1)[0];
const featuredArticle = getRecentArticles(locale, 1)[0];
const resourceTypes: ArticleType[] = ['blog', 'news', 'event', 'product-sheet', 'brochure'];
---

<header class="bg-maxam-black text-maxam-white sticky top-0 z-50 relative">
  <div class="max-w-[var(--container-max)] mx-auto px-4 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="flex items-center gap-2 font-bold text-xl tracking-tight">
      MAXAM
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      <!-- Products (mega nav trigger) -->
      <button
        class="mega-nav-trigger text-sm font-medium text-maxam-gray-300 hover:text-maxam-white transition-colors"
        data-panel="mega-nav-products"
        aria-expanded="false"
      >
        {t(locale, 'nav.products')}
        <svg class="inline-block w-3.5 h-3.5 ms-0.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Resources (mega nav trigger) -->
      <button
        class="mega-nav-trigger text-sm font-medium text-maxam-gray-300 hover:text-maxam-white transition-colors"
        data-panel="mega-nav-resources"
        aria-expanded="false"
      >
        {t(locale, 'nav.resources')}
        <svg class="inline-block w-3.5 h-3.5 ms-0.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Contact (plain link) -->
      <a
        href={localePath(locale, '/contact')}
        class="text-sm font-medium text-maxam-gray-300 hover:text-maxam-white transition-colors"
      >
        {t(locale, 'nav.contact')}
      </a>

      <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-maxam-gray-300 hover:text-maxam-white"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Desktop mega nav panels -->
  <MegaNav locale={locale} />

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="md:hidden hidden bg-maxam-gray-900 border-t border-maxam-gray-700">
    <div class="px-4 py-3 space-y-1">
      <!-- Products section (expandable) -->
      <div>
        <button
          class="mobile-section-toggle w-full flex items-center justify-between py-2 text-sm text-maxam-gray-300 hover:text-maxam-white"
          aria-expanded="false"
          data-target="mobile-products"
        >
          {t(locale, 'nav.products')}
          <svg class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-products" class="hidden ps-4 pb-2 space-y-1">
          <a href={localePath(locale, '/products')} class="block py-1.5 text-sm font-semibold text-maxam-blue">
            {t(locale, 'nav.all_products')}
          </a>
          {industries.map((ind) => (
            <a
              href={localePath(locale, `/products/${ind.slug}/`)}
              class="flex items-center gap-2 py-1.5 text-sm text-maxam-gray-300 hover:text-maxam-white"
            >
              <span class="inline-block w-2 h-2 rounded-full shrink-0" style={`background:${ind.color}`}></span>
              {ind.name}
            </a>
          ))}
          {featuredProduct && (
            <div class="pt-2">
              <FeaturedCard locale={locale} product={featuredProduct} />
            </div>
          )}
        </div>
      </div>

      <!-- Resources section (expandable) -->
      <div>
        <button
          class="mobile-section-toggle w-full flex items-center justify-between py-2 text-sm text-maxam-gray-300 hover:text-maxam-white"
          aria-expanded="false"
          data-target="mobile-resources"
        >
          {t(locale, 'nav.resources')}
          <svg class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-resources" class="hidden ps-4 pb-2 space-y-1">
          <a href={localePath(locale, '/resources')} class="block py-1.5 text-sm font-semibold text-maxam-blue">
            {t(locale, 'nav.all_resources')}
          </a>
          {resourceTypes.map((type) => (
            <a
              href={`${localePath(locale, '/resources')}?type=${type}`}
              class="block py-1.5 text-sm text-maxam-gray-300 hover:text-maxam-white"
            >
              {t(locale, `resources.type.${type}`)}
            </a>
          ))}
          {featuredArticle && (
            <div class="pt-2">
              <FeaturedCard locale={locale} article={featuredArticle} />
            </div>
          )}
        </div>
      </div>

      <!-- Contact (plain link) -->
      <a
        href={localePath(locale, '/contact')}
        class="block py-2 text-sm text-maxam-gray-300 hover:text-maxam-white"
      >
        {t(locale, 'nav.contact')}
      </a>

      <div class="pt-2 border-t border-maxam-gray-700">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </div>
    </div>
  </nav>
</header>

<script>
  // ── Desktop mega nav ──────────────────────────────────
  const triggers = document.querySelectorAll<HTMLButtonElement>('.mega-nav-trigger');
  const panels = document.querySelectorAll<HTMLElement>('[id^="mega-nav-"]');

  function closeAllPanels() {
    panels.forEach((p) => p.classList.add('hidden'));
    triggers.forEach((t) => t.setAttribute('aria-expanded', 'false'));
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const panelId = trigger.dataset.panel!;
      const panel = document.getElementById(panelId)!;
      const isOpen = !panel.classList.contains('hidden');

      closeAllPanels();

      if (!isOpen) {
        panel.classList.remove('hidden');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('[id^="mega-nav-"]') && !target.closest('.mega-nav-trigger')) {
      closeAllPanels();
    }
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAllPanels();
  });

  // Close when clicking a link inside a panel
  panels.forEach((panel) => {
    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeAllPanels());
    });
  });

  // ── Mobile menu ───────────────────────────────────────
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('hidden');
  });

  // Mobile expandable sections
  document.querySelectorAll<HTMLButtonElement>('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target!;
      const target = document.getElementById(targetId)!;
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      target.classList.toggle('hidden');
      // Rotate chevron
      const svg = btn.querySelector('svg');
      svg?.classList.toggle('rotate-180');
    });
  });
</script>
