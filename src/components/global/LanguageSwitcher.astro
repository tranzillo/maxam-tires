---
import type { Locale } from '../../types';
import { locales, localeName } from '../../lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

/**
 * Replace the leading locale segment of a path with the target locale.
 * Path-only (no query/hash) — the client script re-derives the swap from
 * window.location at click time so it preserves the live query string + hash
 * (e.g. /products?industry=mining). After slug normalization every locale
 * shares the same path segments, so the swapped path always resolves.
 */
function switchLocalePath(targetLocale: Locale, path: string): string {
  const segments = path.split('/').filter(Boolean);
  if (locales.includes(segments[0] as Locale)) segments.shift();
  return `/${targetLocale}/${segments.join('/')}`;
}

const localeOptions = locales.map((loc) => ({
  loc,
  name: localeName(loc),
  path: switchLocalePath(loc, currentPath),
}));
---

<div class="lang-switcher">
  <select
    id="lang-select"
    class="lang-switcher__select"
    aria-label="Select language"
  >
    {localeOptions.map((opt) => (
      <option value={opt.loc} data-path={opt.path} selected={opt.loc === locale}>
        {opt.name}
      </option>
    ))}
  </select>
</div>

<script>
  import { locales } from '../../lib/i18n';

  const select = document.getElementById('lang-select') as HTMLSelectElement | null;
  select?.addEventListener('change', () => {
    const target = select.value;
    // Re-derive the swap from the LIVE url so query string + hash survive.
    const segments = window.location.pathname.split('/').filter(Boolean);
    if ((locales as readonly string[]).includes(segments[0])) segments.shift();
    const path = '/' + [target, ...segments].join('/');
    window.location.href = path + window.location.search + window.location.hash;
  });
</script>
