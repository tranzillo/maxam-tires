---
/**
 * SiteHeader — rubbermorphism version of the site header.
 *
 * Design choices:
 *  - Header is a light raised surface that sits on the warm page background
 *    (not the previous dark band). Hairline border + soft contact shadow
 *    define the bottom edge; chamfered top highlight gives the upper edge
 *    a sense of light catching.
 *  - Logo uses the inline MAXAM wordmark SVG (currentColor) in brand blue.
 *  - Nav triggers are pill-shaped molded surfaces — they lift slightly on
 *    hover and press in (inset shadow) when active/open.
 *  - Mega nav panel is a second elevation: opaque overlay with its own
 *    panel shadow, dropped below the header like a drawer on a workbench.
 *  - Industry color dots in the mega nav get the same inset-shadow chip
 *    treatment as the ProductCard chip dot, so they read as molded.
 *  - Sticky positioning preserved.
 *
 * Original Header.astro remains in place — this is a parallel prototype
 * shown in the design gallery for review before site-wide swap.
 */
import type { Locale, ArticleType } from '../../types';
import { t, localePath } from '../../lib/i18n';
import { getAllIndustries, getFeaturedProducts, getRecentArticles } from '../../lib/data';
import LanguageSwitcher from './LanguageSwitcher.astro';
import FeaturedCard from '../ui/FeaturedCard.astro';
import MaxamLogo from '../ui/MaxamLogo.astro';
import Plate from '../ui/Plate.astro';
import Chip from '../ui/Chip.astro';
import Button from '../ui/Button.astro';

interface Props {
  locale: Locale;
  /** Disable sticky positioning — useful in the design gallery preview. */
  sticky?: boolean;
  /**
   * Surface tone for the top bar. `light` (default) is a raised cream
   * surface; `dark` is a deep matte surface that anchors a colored hero
   * below it. The mega-nav panel stays light in both variants — its
   * job is to be a workbench drawer of content.
   */
  variant?: 'light' | 'dark';
}

const { locale, sticky = true, variant = 'light' } = Astro.props;

const industries = getAllIndustries(locale);
const featuredProduct = getFeaturedProducts(locale, 1)[0];
const featuredArticle = getRecentArticles(locale, 1)[0];
const resourceTypes: ArticleType[] = ['blog', 'news', 'event', 'product-sheet', 'brochure'];
---

<header class:list={['site-header', `site-header--${variant}`, sticky && 'site-header--sticky']}>
  <div class="site-header__bar">
    <!-- Logo -->
    <a
      href={localePath(locale, '/')}
      class="site-header__logo-link"
      aria-label="MAXAM home"
    >
      <MaxamLogo class="site-header__logo" label="MAXAM" />
    </a>

    <!-- Desktop nav -->
    <nav class="site-header__nav" aria-label="Primary">
      <button
        class="site-nav-trigger"
        data-panel="products"
        aria-expanded="false"
      >
        {t(locale, 'nav.products')}
        <svg class="site-nav-trigger__chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <button
        class="site-nav-trigger"
        data-panel="resources"
        aria-expanded="false"
      >
        {t(locale, 'nav.resources')}
        <svg class="site-nav-trigger__chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <a href={localePath(locale, '/contact')} class="site-nav-link">
        {t(locale, 'nav.contact')}
      </a>

      <a
        href="http://b2b.maxamtire.com/"
        class="site-nav-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t(locale, 'nav.dealer_login')}
        <svg class="site-nav-link__external" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5h5v5M19 5l-7 7M5 5h6v2H7v10h10v-4h2v6H5V5z" />
        </svg>
      </a>

      <div class="site-header__lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </div>
    </nav>

    <!-- Mobile menu button — only visible below the md breakpoint (header.css). -->
    <button
      data-mobile-toggle
      class="mobile-nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="mobile-nav-toggle__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- ─── Products mega nav panel ─── -->
  <div data-panel="products" class="mega-nav-panel" role="region" aria-label="Products menu" hidden>
    <div class="mega-nav-panel__inner">
      <div class="mega-nav-panel__main">
        <div class="mega-nav-panel__head">
          <Plate as="h3" size="xs">{t(locale, 'home.industries_heading')}</Plate>
          <Button variant="ghost" size="sm" href={localePath(locale, '/products')}>
            {t(locale, 'nav.all_products')}
            <span aria-hidden="true" class="arrow">&rarr;</span>
          </Button>
        </div>
        <div class="mega-nav-panel__chips">
          {industries.map((ind) => (
            <Chip
              variant="industry"
              size="lg"
              color={ind.color}
              href={localePath(locale, `/products/${ind.urlSlug}/`)}
            >
              {ind.name}
            </Chip>
          ))}
        </div>
      </div>

      {featuredProduct && (
        <div class="mega-nav-panel__featured">
          <Plate as="h3" size="xs">{t(locale, 'nav.featured')}</Plate>
          <FeaturedCard locale={locale} product={featuredProduct} />
        </div>
      )}
    </div>
  </div>

  <!-- ─── Resources mega nav panel ─── -->
  <div data-panel="resources" class="mega-nav-panel" role="region" aria-label="Resources menu" hidden>
    <div class="mega-nav-panel__inner">
      <div class="mega-nav-panel__main">
        <div class="mega-nav-panel__head">
          <Plate as="h3" size="xs">{t(locale, 'resources.title')}</Plate>
          <Button variant="ghost" size="sm" href={localePath(locale, '/resources')}>
            {t(locale, 'nav.all_resources')}
            <span aria-hidden="true" class="arrow">&rarr;</span>
          </Button>
        </div>
        <div class="mega-nav-panel__chips">
          {resourceTypes.map((type) => (
            <Chip
              variant="category"
              size="lg"
              href={`${localePath(locale, '/resources')}?type=${type}`}
            >
              {t(locale, `resources.type.${type}`)}
            </Chip>
          ))}
        </div>
      </div>

      {featuredArticle && (
        <div class="mega-nav-panel__featured">
          <Plate as="h3" size="xs">{t(locale, 'nav.featured')}</Plate>
          <FeaturedCard locale={locale} article={featuredArticle} />
        </div>
      )}
    </div>
  </div>

  <!-- ─── Mobile menu ─── -->
  <nav data-mobile-menu class="mobile-nav-menu" aria-label="Mobile navigation" hidden>
    <div class="mobile-nav-menu__inner">
      <!-- Products section (expandable) -->
      <div class="mobile-nav-section">
        <button class="mobile-nav-section-toggle" aria-expanded="false" data-target="[data-mobile-products]">
          {t(locale, 'nav.products')}
          <svg class="mobile-nav-section-toggle__chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-mobile-products class="mobile-nav-section__body" hidden>
          <Button variant="ghost" size="sm" full href={localePath(locale, '/products')}>
            {t(locale, 'nav.all_products')}
          </Button>
          <div class="mobile-nav-section__chips">
            {industries.map((ind) => (
              <Chip
                variant="industry"
                size="lg"
                color={ind.color}
                href={localePath(locale, `/products/${ind.urlSlug}/`)}
              >
                {ind.name}
              </Chip>
            ))}
          </div>
          {featuredProduct && (
            <FeaturedCard locale={locale} product={featuredProduct} />
          )}
        </div>
      </div>

      <!-- Resources section (expandable) -->
      <div class="mobile-nav-section">
        <button class="mobile-nav-section-toggle" aria-expanded="false" data-target="[data-mobile-resources]">
          {t(locale, 'nav.resources')}
          <svg class="mobile-nav-section-toggle__chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-mobile-resources class="mobile-nav-section__body" hidden>
          <Button variant="ghost" size="sm" full href={localePath(locale, '/resources')}>
            {t(locale, 'nav.all_resources')}
          </Button>
          <div class="mobile-nav-section__chips">
            {resourceTypes.map((type) => (
              <Chip
                variant="category"
                size="lg"
                href={`${localePath(locale, '/resources')}?type=${type}`}
              >
                {t(locale, `resources.type.${type}`)}
              </Chip>
            ))}
          </div>
          {featuredArticle && (
            <FeaturedCard locale={locale} article={featuredArticle} />
          )}
        </div>
      </div>

      <a href={localePath(locale, '/contact')} class="site-nav-link mobile-nav-link">
        {t(locale, 'nav.contact')}
      </a>

      <a
        href="http://b2b.maxamtire.com/"
        class="site-nav-link mobile-nav-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t(locale, 'nav.dealer_login')}
        <svg class="site-nav-link__external" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5h5v5M19 5l-7 7M5 5h6v2H7v10h10v-4h2v6H5V5z" />
        </svg>
      </a>

      <div class="mobile-nav-menu__lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </div>
    </div>
  </nav>
</header>

<script>
  /**
   * Wire up every SiteHeader on the page. The gallery renders multiple
   * instances side-by-side, so we iterate over all of them and scope
   * panel/menu lookups to each header. Mega-nav panels are looked up
   * BY ID (panel id from data-panel attr) but only within the same header's
   * subtree, so duplicate IDs across instances don't cross-wire.
   */
  type Init = (header: HTMLElement) => void;

  const initHeader: Init = (header) => {
    if (header.dataset.rubberHeaderInit === '1') return;
    header.dataset.rubberHeaderInit = '1';

    const triggers = header.querySelectorAll<HTMLButtonElement>('.site-nav-trigger[data-panel]');
    const panels = header.querySelectorAll<HTMLElement>('.mega-nav-panel');

    function closeAllPanels() {
      panels.forEach((p) => (p.hidden = true));
      triggers.forEach((t) => t.setAttribute('aria-expanded', 'false'));
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const panelName = trigger.dataset.panel!;
        // Scope to this header instance — galleries may render multiple
        // headers on one page and we want each to control only its own panels.
        const panel = header.querySelector<HTMLElement>(`.mega-nav-panel[data-panel="${panelName}"]`);
        if (!panel) return;
        const isOpen = !panel.hidden;

        closeAllPanels();
        if (!isOpen) {
          panel.hidden = false;
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!header.contains(target)) {
        closeAllPanels();
        return;
      }
      if (!target.closest('.mega-nav-panel') && !target.closest('.site-nav-trigger[data-panel]')) {
        closeAllPanels();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAllPanels();
    });

    panels.forEach((panel) => {
      panel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeAllPanels());
      });
    });

    // Mobile menu — scope by querying inside the header
    const mobileToggle = header.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
    const mobileMenu = header.querySelector<HTMLElement>('[data-mobile-menu]');

    mobileToggle?.addEventListener('click', () => {
      const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', String(!expanded));
      if (mobileMenu) mobileMenu.hidden = expanded;
    });

    header.querySelectorAll<HTMLButtonElement>('.mobile-nav-section-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetSelector = btn.dataset.target!;
        const target = header.querySelector<HTMLElement>(targetSelector);
        if (!target) return;
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        target.hidden = expanded;
        // Chevron rotation is driven by [aria-expanded] in CSS.
      });
    });
  };

  document.querySelectorAll<HTMLElement>('.site-header').forEach(initHeader);
</script>
