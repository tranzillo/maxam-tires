---
interface Props {
  name: string;
  color: string;
  size?: 'sm' | 'md';
  href?: string;
}

const { name, color, size = 'sm', href } = Astro.props;

const sizeClasses = size === 'md'
  ? 'text-sm px-3 py-1'
  : 'text-xs px-2 py-0.5';

const baseClasses = `${sizeClasses} text-maxam-white rounded-full font-medium inline-block`;
---

{href ? (
  <a href={href} class={baseClasses} style={`background:${color}`}>
    {name}
  </a>
) : (
  <span class={baseClasses} style={`background:${color}`}>
    {name}
  </span>
)}
