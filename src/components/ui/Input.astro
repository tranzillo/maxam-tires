---
/**
 * Input — single-line text input atom.
 *
 * Recessed-well treatment: the input sits BELOW the surface plane (inset
 * shadow at the top simulates the well's upper edge in shadow). This is
 * the inverse of the raised treatment buttons get — inputs are wells you
 * fill, buttons are switches you press. The same visual logic that drives
 * the pressed-in nav trigger applies always-on here.
 *
 * On focus, the well "fills up with attention" — gains a brand-blue tinted
 * border and ring, but keeps its inset shadow so it still reads as recessed.
 */
interface Props {
  type?: 'text' | 'email' | 'tel' | 'url' | 'password' | 'search' | 'number';
  name?: string;
  id?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  autocomplete?: string;
  /** Visual full-width — common case for form fields. */
  full?: boolean;
  /** Error state — red-tinted border + ring. */
  error?: boolean;
  /**
   * Control height, shared scale with Button (--control-h-*). Use
   * the same size as an adjacent button so paired controls match height.
   */
  size?: 'md' | 'lg';
  class?: string;
}

const {
  type = 'text',
  name,
  id,
  placeholder,
  value,
  required = false,
  disabled = false,
  readonly = false,
  autocomplete,
  full = true,
  error = false,
  size = 'md',
  class: className,
} = Astro.props;

const dataAttrs: Record<string, string | boolean> = {};
if (full) dataAttrs['data-full'] = true;
if (error) dataAttrs['data-error'] = true;
if (size !== 'md') dataAttrs['data-size'] = size;
---

<input
  type={type}
  name={name}
  id={id}
  placeholder={placeholder}
  value={value}
  required={required}
  disabled={disabled}
  readonly={readonly}
  autocomplete={autocomplete}
  aria-invalid={error || undefined}
  class:list={['input', className]}
  {...dataAttrs}
/>
