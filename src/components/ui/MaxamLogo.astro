---
/**
 * MAXAM wordmark. Paths extracted from the WP theme's inline SVG header.
 * Uses currentColor so the parent controls fill via text-* utilities or
 * inline style. Width auto-sizes from height to preserve aspect ratio.
 */
interface Props {
  /** Tailwind classes applied to the <svg> — typically text-color + size. */
  class?: string;
  /** Accessible label. Pass null/'' to mark decorative (no title element). */
  label?: string | null;
}

const { class: className, label = 'MAXAM' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 507.5 77.7"
  class:list={['shrink-0', className]}
  role={label ? 'img' : 'presentation'}
  aria-label={label || undefined}
  aria-hidden={label ? undefined : 'true'}
  fill="currentColor"
>
  {label && <title>{label}</title>}
  <g>
    <polygon
      points="0,27.5 0,62.1 20.7,62.1 20.1,36.2 23.9,36.2 49.8,62.1 67.2,62.1 93.2,36.2 96.7,36.2 96.2,62.1 116.8,62.1 116.8,27.5 79,27.5 58.5,50 38,27.5"
    />
    <path
      d="M185.7,48.7h-30.9l13.4-13.1h4.1L185.7,48.7z M198.9,62.1h23.9l-36.1-34.6H154l-36.5,34.6h24l5.9-5.9H193 L198.9,62.1z"
    />
    <polygon
      points="390.7,27.5 390.7,62.1 411.4,62.1 410.8,36.2 414.6,36.2 440.5,62.1 457.9,62.1 483.9,36.2 487.4,36.2 486.9,62.1 507.5,62.1 507.5,27.5 469.7,27.5 449.2,50 428.7,27.5"
    />
    <path
      d="M353.7,48.7h-30.9l13.4-13.1h4.1L353.7,48.7z M366.9,62.1h23.9l-36.1-34.6H322l-36.5,34.6h24l5.9-5.9H361 L366.9,62.1z"
    />
    <path
      d="M243,11.4C243,5.1,248.1,0,254.4,0c6.3,0,11.4,5.1,11.4,11.4c0,6.3-5.1,11.4-11.4,11.4 C248.1,22.8,243,17.7,243,11.4"
    />
    <polygon
      points="240.2,43.8 208.2,77.7 235.5,77.7 254.1,57.4 272.7,77.7 300.6,77.7 267.7,43.4 297,16.1 254.5,30.1 210.9,16.1"
    />
  </g>
</svg>
