---
/**
 * RubberField — wraps a form input with a label and optional hint/error
 * messages. Use as the default form-row primitive — consumers slot the
 * actual Input/Select/Textarea inside.
 *
 * Pairs the label and control via `htmlFor` + `id` so screen readers
 * announce them together. Hint text gets aria-describedby; error text
 * gets aria-errormessage when an error is shown.
 */
interface Props {
  /** Input id — required for label association. */
  inputId: string;
  label: string;
  hint?: string;
  error?: string;
  required?: boolean;
  class?: string;
}

const { inputId, label, hint, error, required = false, class: className } = Astro.props;
const hintId = hint ? `${inputId}-hint` : undefined;
const errorId = error ? `${inputId}-error` : undefined;
---

<div class:list={['rubber-field', className]}>
  <label for={inputId} class="rubber-field__label">
    {label}
    {required && <span class="rubber-field__required" aria-hidden="true">*</span>}
  </label>

  <slot {hintId} {errorId} />

  {hint && !error && (
    <p id={hintId} class="rubber-field__hint">{hint}</p>
  )}
  {error && (
    <p id={errorId} class="rubber-field__error" role="alert">{error}</p>
  )}
</div>
