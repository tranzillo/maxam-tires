---
/*
 * Section — the page section primitive.
 *
 * Pure markup. All styles live in src/styles/components/section.css
 * (loaded globally via global.css). Class names emitted here match
 * the rules in that file.
 *
 * Structure:
 *   <section>                              full-bleed outer pane
 *     [optional overlay div]
 *     <div class="section__container">     centered max-width content column
 *       <slot />
 *     </div>
 *   </section>
 *
 * Content always sits inside the container. Backgrounds always bleed.
 *
 * Variants (see section.css for what each one renders):
 *   vertical    'none' | 'md' | 'lg' | 'xlg'         vertical padding scale
 *   background  'page' | 'sunken' | 'deep' | 'image' surface bg
 *   overlay     'none' | 'dark' | 'blue-lr' | 'blue-full'  tint over bg image
 *   as          'section' | 'div'                    rendered tag (use 'div' if nested)
 */
interface Props {
  vertical?: 'none' | 'md' | 'lg' | 'xlg';
  background?: 'page' | 'sunken' | 'deep' | 'image';
  backgroundImage?: string;
  backgroundPosition?: string;
  overlay?: 'none' | 'dark' | 'blue-lr' | 'blue-full';
  as?: 'section' | 'div';
  class?: string;
}

const {
  vertical = 'md',
  background = 'page',
  backgroundImage,
  backgroundPosition = 'center',
  overlay = 'none',
  as: Tag = 'section',
  class: className,
} = Astro.props;

const bgStyle = backgroundImage
  ? `background-image:url('${backgroundImage}');background-position:${backgroundPosition};`
  : '';
---

<Tag
  class:list={[
    'section',
    `section--bg-${background}`,
    `section--v-${vertical}`,
    overlay !== 'none' && `section--overlay-${overlay}`,
    className,
  ]}
  style={bgStyle}
>
  {overlay !== 'none' && <div class="section__overlay" aria-hidden="true"></div>}
  <div class="section__container">
    <slot />
  </div>
</Tag>
