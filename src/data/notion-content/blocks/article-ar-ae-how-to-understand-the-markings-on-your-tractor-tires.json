[{"object":"block","id":"35534d6d-7cea-81e6-8202-dc7314c17cb2","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"How to understand the markings on your Tractor tires?","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"How to understand the markings on your Tractor tires?","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-816f-97c1-dab4c8e76a3a","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Each MAXAM Tractor tire’s sidewall includes important markings called the nomenclature which details the following: tire size, tread, load index (weight carrying capability), speed rating, and any additional safety or mounting requirements. These details can help you make an informed tire purchase, ensure proper fitment, and help you assess your tire’s optimal use in any farming or construction equipment application.","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Each MAXAM Tractor tire’s sidewall includes important markings called the nomenclature which details the following: tire size, tread, load index (weight carrying capability), speed rating, and any additional safety or mounting requirements. These details can help you make an informed tire purchase, ensure proper fitment, and help you assess your tire’s optimal use in any farming or construction equipment application.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-816e-8397-e839a021de6e","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"divider","divider":{},"archived":false},{"object":"block","id":"35534d6d-7cea-8173-b3b0-d89b32a87425","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Tire Size","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire Size","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8164-80bf-fb56d0364747","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Load-index-1.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-811a-8108-f5e6a6114c68","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"On your sidewall, you will find your tire size. To help you understand what each item means please see the below example.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"On your sidewall, you will find your tire size. To help you understand what each item means please see the below example.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81a9-a3ad-ffcb1ed07b29","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tire Size Example:","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":true,"code":false,"color":"default"},"plain_text":"Tire Size Example:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-819b-bf73-dca19f80f772","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"VF – This tells you that this product is not a standard Ag tire but part of our VF (very high sidewall flexion) series. Not all tires will have this VF nomenclature on the sidewall.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"VF – This tells you that this product is not a standard Ag tire but part of our VF (very high sidewall flexion) series. Not all tires will have this VF nomenclature on the sidewall.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-812f-98ed-cbe10b5d76ec","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"380 – this tells the nominal section width or tread width in millimeters. This is the measurement from one shoulder to the other shoulder.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"380 – this tells the nominal section width or tread width in millimeters. This is the measurement from one shoulder to the other shoulder.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8150-9f21-c9f16e810b30","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"90 – this is the aspect ratio. Which is equivalent to 90% of 380 mm = 342 mm measure from the bead area to the shoulder. The lower the ratio, the taller the sidewall height in relation to the tread width.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"90 – this is the aspect ratio. Which is equivalent to 90% of 380 mm = 342 mm measure from the bead area to the shoulder. The lower the ratio, the taller the sidewall height in relation to the tread width.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8134-8daa-d0beda963915","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"R - The letter R indicates radial construction. A bias-constructed tire uses a dash (-) instead of the letter R.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"R - The letter R indicates radial construction. A bias-constructed tire uses a dash (-) instead of the letter R.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8198-9433-d3d376b97c09","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"46 – this indicates the rim diameter and means this tire would fit a rim with a 46-inch diameter.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"46 – this indicates the rim diameter and means this tire would fit a rim with a 46-inch diameter.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-815d-9e50-f3590ac769d8","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Load Index Number and Speed Rating","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Load Index Number and Speed Rating","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8102-8ef6-e5acb45cf9a7","parent":{"type":"page_id","page_id":"35534d6d-7cea-810d-986e-d46c31bab912"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"3553