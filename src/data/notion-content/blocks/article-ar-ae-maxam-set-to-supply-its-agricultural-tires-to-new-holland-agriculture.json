"MAXAM AGRIXTRA Radial Tire Series ","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM AGRIXTRA Radial Tire Series ","href":null},{"type":"text","text":{"content":"for ","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"for ","href":null},{"type":"text","text":{"content":"T5, T6, & T7 ","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"T5, T6, & T7 ","href":null},{"type":"text","text":{"content":"tractor families","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"tractor families","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8113-8762-c6735aee5f73","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"May 19th, 2022 – FRANKFURT, DE – MAXAM Tire Europe is proud to announce that the AGRIXTRA range of agricultural tires has been approved on select New Holland T5, T6, and T7 SWB and LWB tractors.","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"May 19th, 2022 – FRANKFURT, DE – MAXAM Tire Europe is proud to announce that the AGRIXTRA range of agricultural tires has been approved on select New Holland T5, T6, and T7 SWB and LWB tractors.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-818a-8ca8-fd0ab2cf2694","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Gaining another global supply agreement with a major equipment manufacturer, MAXAM is pleased to provide the AGRIXTRA business solution to New Holland Agriculture. Achieving an agricultural equipment manufacturer’s (OEM) approval is a major milestone for the MAXAM brand since the launch of the AGRIXTRA series in 2014.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Gaining another global supply agreement with a major equipment manufacturer, MAXAM is pleased to provide the AGRIXTRA business solution to New Holland Agriculture. Achieving an agricultural equipment manufacturer’s (OEM) approval is a major milestone for the MAXAM brand since the launch of the AGRIXTRA series in 2014.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8114-a4b3-c4f16c84d493","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"“The homologation, approval, and commercialization of our radial agricultural tires is a significant step in the evolution of the MAXAM brand as a long-term supplier to CNH Industrial and New Holland Agriculture,” says Kevin Buckley MAXAM OE Sales Director Europe.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"“The homologation, approval, and commercialization of our radial agricultural tires is a significant step in the evolution of the MAXAM brand as a long-term supplier to CNH Industrial and New Holland Agriculture,” says Kevin Buckley MAXAM OE Sales Director Europe.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c0-a2cd-f153842362b5","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MAXAM AGRIXTRA range of radial tires has built a formidable reputation for performance and value engendering exceptional customer feedback. Offering improved traction, increased stability, and reduced slip, the AGRIXTRA family of products delivers a valuable solution to farmers and growers globally.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM AGRIXTRA range of radial tires has built a formidable reputation for performance and value engendering exceptional customer feedback. Offering improved traction, increased stability, and reduced slip, the AGRIXTRA family of products delivers a valuable solution to farmers and growers globally.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e9-a334-d0ea12e9318c","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2022/05/IMG_3113-1-1024x683.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-81dd-833a-d076614a6a26","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Engineered to deliver superior performance on the road and in the field.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Engineered to deliver superior performance on the road and in the field.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8169-a348-c84e298dc615","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"The 45° lug design ensures the best profile for superior traction & minimal vibration through constant lug contact.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The 45° lug design ensures the best profile for superior traction & minimal vibration through constant lug contact.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-811e-9eff-fd6c6df77637","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"The tread stability delivers increased comfort, improved handling, and durability.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The tread stability delivers increased comfort, improved handling, and durability.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8153-bbbd-d96e42b43e2d","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"The optimized self-cleaning design and carrying capacity conquer heavy loads and/or heavy plowing operations.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The optimized self-cleaning design and carrying capacity conquer heavy loads and/or heavy plowing operations.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81f2-87bd-f37433e99e66","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Approved in twenty-seven tire sizes in the 85, 70, 65, and XL series, New Holland Tractors are now available for purchase with MAXAM’s AGRIXTRA radial tires in sizes 24-42 inches in diameter. All MAXAM radial agricultural tires are backed by an 8-year tire warranty, highlighting MAXAM’s confidence in its product offering. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Approved in twenty-seven tire sizes in the 85, 70, 65, and XL series, New Holland Tractors are now available for purchase with MAXAM’s AGRIXTRA radial tires in sizes 24-42 inches in diameter. All MAXAM radial agricultural tires are backed by an 8-year tire warranty, highlighting MAXAM’s confidence in its product offering. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-817b-9375-c9f3b95afafb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For more information on MAXAM’s supply agreement with New Holland, please contact your local representative or visit us at maxamtire.com.                                                                            ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For more information on MAXAM’s supply agreement with New Holland, please contact your local representative or visit us at maxamtire.com.                                                                            ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8102-8cd7-fbfb617964ea","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2022/05/new-holland-close-up.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8110-ae88-dcdd7e7e6572","parent":{"type":"page_id","page_id":"35534d6d-7cea-8150-b723-c411b8d9b778"},"created_time":"2026-05-03T22:02:00.000Z","last_edited_time":"2026-05-03T22:02:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2022/05/side.png"}},"archived":false}]