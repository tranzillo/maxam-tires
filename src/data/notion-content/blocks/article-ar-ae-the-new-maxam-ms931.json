[{"object":"block","id":"35534d6d-7cea-818d-bae8-cc2355e60ad5","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"THE NEW MAXAM MS931 LOGXTRA","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"THE NEW MAXAM MS931 LOGXTRA","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8142-b15e-d0e66673bae0","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"The MAXAM Solution for Abusive Forestry Applications ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM Solution for Abusive Forestry Applications ","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e2-837d-e1c3ed07dbec","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, August 19, 2019] MAXAM is excited to introduce the LogXtra forestry line to our broad range of specialty tire programs. MAXAM has engineered the MS931 LogXtra to provide the industry with the best solution for abusive forestry applications. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, August 19, 2019] MAXAM is excited to introduce the LogXtra forestry line to our broad range of specialty tire programs. MAXAM has engineered the MS931 LogXtra to provide the industry with the best solution for abusive forestry applications. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8178-898f-d5363fc1db0c","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Throughout the development and performance validation phase of the LogXtra program, the design components and tire construction have displayed increased efficiency, durability and traction compared to industry benchmarks. The steel belt stabilized construction along with heavy duty shoulder and sidewall thrives in harsh environments while also resisting cuts, cracks, impacts and punctures. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Throughout the development and performance validation phase of the LogXtra program, the design components and tire construction have displayed increased efficiency, durability and traction compared to industry benchmarks. The steel belt stabilized construction along with heavy duty shoulder and sidewall thrives in harsh environments while also resisting cuts, cracks, impacts and punctures. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-815c-9c0d-d0a9f410e892","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"A high performance rubber compound has been developed by the MAXAM engineering group specifically for the LogXtra tread to maximize tire resilience in the working environment. To prevent bead winding defects and protect against mounting damage, the LogXtra goes through an enhanced bead wrapping process that has been developed and implemented during the manufacturing process. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"A high performance rubber compound has been developed by the MAXAM engineering group specifically for the LogXtra tread to maximize tire resilience in the working environment. To prevent bead winding defects and protect against mounting damage, the LogXtra goes through an enhanced bead wrapping process that has been developed and implemented during the manufacturing process. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8183-a15b-f0bbb3a810bc","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"In addition, the LogXtra offers excellent traction and flotation thanks to its aggressive self-cleaning tread pattern that is deeper and wider than the industry standards. The MS931 Logxtra will be offered in five LS2 sizes and optional ply ratings as shown in the below chart. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"In addition, the LogXtra offers excellent traction and flotation thanks to its aggressive self-cleaning tread pattern that is deeper and wider than the industry standards. The MS931 Logxtra will be offered in five LS2 sizes and optional ply ratings as shown in the below chart. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8133-bc9a-fdecf07e093a","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e9-a077-eb57c5ec481b"},"created_time":"2026-05-03T22:05:00.000Z","last_edited_time":"2026-05-03T22:05:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information contact your local representative or visit us at maxamtire.com","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For additional information contact your local representative or visit us at maxamtire.com","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8144-b893-e73a2752f6c9","p