xt":{"content":"Bear in mind the long-term needs and demands of your work. To best suit your tire to your needs, refer to the table, talk to your dealer, or"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"contact the MAXAM team"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"to find the right solution."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"YOU MIGHT LIKE: ["},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"Rolling Resistance and Its Ag Tire Impact","link":{"url":"https://maxamtire.com/rolling-resistance-and-its-ag-tire-impact/"}},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"]"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"III. Matching Tires to Applications"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"In agriculture, the right tire construction balances load capacity, traction, and soil preservation. Below, we provide the key insights on how specific designs address the unique demands of critical farming tasks."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":" Fieldwork (Tractors, Planters): Reducing Compaction, Enhancing Traction"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Challenge"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":":\n\n \tHeavy machinery compacts soil, reducing aeration and water infiltration.\n \tRigid tires concentrate weight, disrupting seedbeds and lowering yields.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],"children":[{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Heavy machinery compacts soil, reducing aeration and water infiltration."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Rigid tires concentrate weight, disrupting seedbeds and lowering yields."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Solution"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":": "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"Nylon/Nylon Radial Tires"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"\n\n \tFlex under load to distribute weight evenly.\n \tMinimize ground pressure, preserving soil structure.\n \tAdapt to uneven terrain for consistent grip.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],"children":[{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Flex under load to distribute weight evenly."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Minimize ground pressure, preserving soil structure."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Adapt to uneven terrain for consistent grip."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Benefits"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":":\n\n \tin sensitive areas (e.g., wet fields).\n \tLower fuel consumption compared to bias-ply designs.\n \tIdeal for row-crop operations and delicate planting.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],"children":[{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"in sensitive areas (e.g., wet fields)."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Lower fuel consumption compared to bias-ply designs."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Ideal for row-crop operations and delicate planting."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/06/Ag-Blog-Image-2-800x544.jpg"}}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":" Harvesting (Combines, Foragers): Stability Under Heavy Loads"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Challenge"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":":\n\n \tHeavy loads and rough terrain strain tires.\n \tHeat buildup and debris increase wear.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],"children":[{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Heavy loads and rough terrain strain tires."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Heat buildup and debris increase wear."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Solution"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"ty