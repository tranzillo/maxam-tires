[{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"5 radial tire tips to maximize your aggregate and quarry productivity"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nA tire isn’t just black and round, especially for aggregates and quarry operations. Knowing the type of tires that are appropriate for your earthmoving equipment and how to maintain them are equally important as maintaining your machines. By conducting a proper OTR (off-the-road) tire maintenance program, it’ll directly impact your overall safety, productivity and cost.\n\nWhile OTR tires are built to withstand tough conditions, they also have their limit and knowing these factors will help you properly care for them:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"How fast they can travel"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"How much load they can carry"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"The amount of heat they can sustain"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"How much impact they can absorb"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nHere are five things to consider when it comes to your quarry and aggregate equipment’s tires:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Understand the functions of a tire and their limits"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"The importance of air pressure, especially on radial tires"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"How to minimize road hazards"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Know the common tire failures and how you can avoid them"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Conduct pre-shift daily tire check to extend tire life"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/oemohw-article-infographic_V2-560x800.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"I. Tire Awareness"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nSometimes it’s easy to forget that tires have their limits once they’re mounted on. As we’ve shared their limits above, a reminder on the functions of a tire:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Support the vehicle’s load by being that pressure vessel"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Provide traction and braking"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Control the direction of travel"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Absorb road shocks"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Overcome (most of the time) road hazards"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nKnowing tires’ functional attributes and limits will help you understand the importance of tire maintenance. As they’re a costly investment, particularly for mining operations, you don’t want to overlook the importance of maintaining your machine’s tires.\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"II. Air Pressure"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nThe most important factors on maintaining your off-the-road tires, bias, or radial, is air pressure. Here are six reasons why air pressure maintenance is crucial for your OTR tires:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Having the right air pressure reduces the amount of deflection"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Having the proper air pressure provide a better ride and added durability"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"When inflated properly, the overall heat levels are kept to a minimum"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Having the proper air pressure provide the best traction and braking"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"When inflated properly, you get a better control on your vehicle"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Proper air pressure allows the optimum level of road hazard absorption"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nThe most asked questions we get: when do I check my tires then?\n\nTry to check your tires’ air pressure daily, ideally before each shift, especially on a “cold” tire. Below is how a “cold” tire versus a “hot” tire is defined:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":2,"has_column_header":false,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":" Cold tire"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Hot tire"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"A cold tire is generally defined as one that has been sitting idle and not used for a minimum of 24 hours. From this point the pressure can be monitored more accurately."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"As a tire works, its internal temperature will increase, as will its air pressure. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"A hot tire must never be deflated."},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"\n\n- If the air pressure increases by 20% or more from the cold inflation reading, it’s a sign that the tire is overheating and should cool down or moved to an operation that is less demanding."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article-quotation.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\n\nIn addition to ensuring safety, having the proper air pressure allows your OTR tire to maintain its correct shape that’s engineered for its precise performance. Below is a reference on what a properly inflated, overinflated and underinflated OTR tire shape and tread look like:\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article-correct-psi-image-800x502.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"III. Avoid road hazards"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nThere are many road hazards that could occur at a quarry/aggregates site, but below are the top four to avoid:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Spillage on haul roads: ensure to have your crew clean up the road, rocks and debris can create deep cuts in your tires."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Avoid water: water acts as a lubricant and allows rocks to cut into tires easily."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Avoid spillage: don’t ever overload your machine."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Curved roads with super elevation: ensure curve roads have proper superelevation."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nIn addition, make sure to check the attributes below at the loading area:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Floor: is it smooth and clean?"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Traffic patterns established: do you have a clear traffic pattern for operators to travel?"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Ensure your loader operator have controlled and minimized tire spin."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Ensure the bucket payloads match the conditions."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Are cycle times reasonable and matching the needs?"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Does dust cause production and safety issues?"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"IV. Common tire failures and how to avoid them"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nWe’ve shared the "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"top ten most common OTR tire failures","link":{"url":"https://maxamtire.com/how-to-identify-damaged-otr-tires-2/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":" in this article. But here are some shocking tire failures and what they can cost your operation:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"\nRunning flat tires (caused by low PSI)\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nRunning flat tires that have low air pressure, below are some examples of how much it could cost your operation (keep in mind that this is based on a case study):\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":1,"has_column_header":false,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":""}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"$26,000 loss"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"table","table":{"table_width":1,"has_column_header":false,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":""}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"$11,000 loss"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"2. Zipper ruptures"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nZipper ruptures due to low air pressure. Low PSI can cause tires to over-flex in the sidewall and weaken the structural cables, causing the tire to have rapid air loss.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article_zippre-rupture-image-2-800x574.jpg"}}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article_zippre-rupture-image-1.jpg"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"3. Improper mounting"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article_improper-mounting-image-1.jpg"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\n\nThis can lead to a bead separation and potentially break the bead, due to the bead being hung up on the flange and not sitting properly. Tire fitters should always:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Double-inflate tire at the time of mounting."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Check the GG ring to ensure it’s equal all around the tire. If the bead is hung up on the rim, deflate and lubricate both the rim and the tire bead."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Take the time to inspect the rim parts to ensure proper seating, use the image below as a reference:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/10/OTR_5-tire-tip-for-aggregate-article-rim-component-image-800x461.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"V. Daily pre/post-shift inspection and why it matters"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nTires should be visually inspected before every shift for cuts and impacts that could lead to tire failure. Routine maintenance inspections can lead to discovering deeper cuts that have exposed plies. In these cases, removing the tire and repairing it immediately can extend the life of the tire, increasing the site’s profitability.\n\nBelow are the basic components on the tires you should always inspect before each shift daily:\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Check the face of the tire"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nCheck for cuts and tears on the face of the tire. Is anything missing?  Has the lug torn off?\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Check the bead"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nRun your hand all around where the tire meets the wheel.  Is it consistent all the way around?\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Check the valve stem"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nCheck the core. Is it leaking?  Is there a cap on the valve stem?  Is it tight?  Is the valve stem properly seated on the wheel? All of this can be checked by spraying a little bit of soapy water on the stem.  If you see bubbles, you may have a leak.\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Check the air pressure"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nMake sure the air pressure is at the recommended level.\n\n \n\nBy following these top five tips mentioned above, you will notice a significant difference in maximizing your operation cost-per-hour and having the best productivity. For more tire tips to maximize your operation, check out our "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"technical bulletin","link":{"url":"https://maxamtire.com/resources/?postType=post"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":".\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Watch Webinar:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nMore of a visual learner? Check out the webinar below and watch our tire expert walk you through each step in detail.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]