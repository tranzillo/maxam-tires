[{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Rubber tracks are the backbone of heavy machinery, enduring everything from rocky construction sites to waterlogged fields. While tracks are built to withstand harsh conditions, their lifespan hinges on proactive care.\n\nAt MAXAM, we’ve spent years refining rubber track technology, and we know that simple, consistent maintenance can mean the difference between years of reliable service and costly, unexpected downtime. Here’s how to prolong your track’s performance and lifespan.\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Proper Tension and Track Rotation"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Proper track tension is crucial to minimizing wear and avoiding catastrophic failures. When tracks are too loose, they slip on sprockets, causing uneven wear and increasing the risk of derailment. On the other hand, over-tightened tracks will strain rollers and idlers, accelerating component fatigue.\n\nTo strike the right balance, check tension daily using manufacturer guidelines. Here’s a general guideline to follow, but be sure to check the guidelines if available:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":3,"has_column_header":false,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Machine Size"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Sag Depth (mm)"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Sag Depth (in)"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":".75 – 1.5 ton"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"8-10mm"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"0.31-0.39\""},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"1.5 – 3.0 ton"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"10-15mm"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"0.39-0.59\""},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"3.0 – 6.0 ton"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"12-20mm"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"0.47-0.79\""},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"6.0 – 8.0 ton"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"15-25mm"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"0.59-0.98\""},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/Artboard-1.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Seasonal adjustments are equally important: cold weather contracts rubber, requiring a slight loosening, while summer heat may necessitate tightening. For precision, consider tension-monitoring tools designed to eliminate guesswork."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"quote","quote":{"rich_text":[{"type":"text","text":{"content":"\nMAXAM PRO TIP: Rotate Tracks to Distribute Wear\nJust like tires, rubber tracks wear unevenly depending on terrain and usage patterns. Benefits of rotating tracks:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"It ensures stress is distributed more evenly, preventing localized damage that can lead to premature replacement."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Swapping tracks from left to right is particularly effective for machinery that frequently navigates slopes or tight turns, as these conditions often place asymmetrical strain on one side."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Clean Tracks Thoroughly After Each Shift"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Mud, gravel, and debris are abrasive agents that grind down rubber tracks over time. Cleaning tracks after each shift removes these contaminants, reducing wear and preventing grit from infiltrating seals and joints."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Best way to clean tracks:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Use stiff brushes or low-pressure water to dislodge dirt."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"High-pressure washers can force debris deeper into critical components."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/RBT-Clean-Tracks-Visual-400x400.png"}}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/RBT-Clean-Tracks-Zoom.png"}}},{"object":"block","type":"quote","quote":{"rich_text":[{"type":"text","text":{"content":"MAXAM PRO TIP Pay special attention to the undercarriage, where trapped debris often leads to cuts or tears."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"After implementing a daily cleaning routine, a few minutes of post-shift care can yield significant long-term savings."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Train Operators for Mindful Equipment Use"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Even the most durable tracks suffer under rough handling. Operator training is key to reducing unnecessary stress: teach crews to drive straight up and down slopes rather than sideways, which minimizes lateral scrubbing and sidewall damage."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/Operator-training-visual.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Encourage your operators to:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Make three-point turns instead of sharp pivots to reduce friction"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Emphasize avoiding obstacles like curbs, rebar, or jagged rocks. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Smooth acceleration and braking also play a role as sudden movements strain tracks and undercarriage components. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Adapt to Your Worksite’s Environment"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Every environment poses distinct challenges."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For example, in muddy or abrasive areas:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Lay down track mats to protect rubber from direct contact with damaging surfaces."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Plan routes to avoid unnecessary hazards and invest in terrain-specific tracks."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Climate-based changes:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Cold climates benefit from cold-resistant rubber compounds that remain flexible in sub-zero temperatures."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"High-heat environments demand tracks with heat-dissipating designs."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"By tailoring your approach to the worksite, you mitigate wear before it starts."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"The importance of proper rubber track storage"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Rubber tracks demand careful storage to protect their durability and performance."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Things that damage rubber tracks include:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"UV rays: degrades rubber overtime"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Extreme temperatures"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Moisture: humidity invites mold"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Improper positioning can cause dry rot, cracks, or warping. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"quote","quote":{"rich_text":[{"type":"text","text":{"content":"MAXAM Pro Tip Clean tracks thoroughly, store in a cool, dry, shaded area, and use racks or pallets to maintain shape. Inspect periodically for early wear signs. For an easy and useful tool to help you conduct regular checks, look no further than the MAXAM App."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/Environment-Visual.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Along with tire information and helpful tips, the app includes a rubber track ground pressure calculator to help you understand the pressure under certain load and to optimize flotation."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Download the MAXAM app today for more great tools like this:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/11/Download_on_the_App_Store_RGB_blk.svg"}}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2024/11/Google_Play_Store_badge_EN.svg"}}},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Prioritize Equipment Health"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"A well-maintained undercarriage is a track’s best ally. Misaligned rollers or worn sprockets place uneven pressure on tracks, leading to premature failure."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2025/05/Undercarriage-visual.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Here are the areas to check:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Rollers, idlers, and sprockets weekly for signs of wear"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Replace damaged components immediately—a single worn roller can shred a track in hours. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Monthly lubrication of pivot points reduces friction"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Practice alignment checks to ensure even weight distribution. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Have proactive maintenance kits ready to go, including wear gauges and alignment tools,"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"By simplifying these tasks, your operation can stay ahead of issues."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Rubber Tracks That Endure"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Extending track life isn’t just about avoiding repairs. It’s about maximizing uptime, protecting your team, and safeguarding your bottom line. With these five strategies, you’re not just maintaining tracks; you’re fortifying the foundation of your operation."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"To maximize your performance further, consider downloading the MAXAM Mobile app. This great tool comes packed with helpful track information, a ground pressure calculator, and an in-depth fitment guide."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MAXAM Mobile is your all-in-one tool for everything rubber tracks related. Whether it’s finding the right rubber track fit, calculating ground pressure, or discovering your next tire/track, download MAXAM Mobile today."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]