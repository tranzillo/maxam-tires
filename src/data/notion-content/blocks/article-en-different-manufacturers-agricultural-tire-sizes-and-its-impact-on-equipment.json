-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"The tire tread depth based on the lug design affects the overall diameter (OD) of a standard R-1 pattern versus the same sized tire with deeper R-1W, or R-2 tread depth.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The tire tread depth based on the lug design affects the overall diameter (OD) of a standard R-1 pattern versus the same sized tire with deeper R-1W, or R-2 tread depth.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-810a-a886-ff8b634b583c","parent":{"type":"page_id","page_id":"38234d6d-7cea-8137-8884-d5f67dd6dbb0"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Tire tread depth will also differ from manufacturer to manufacturer which will affect the tire geometry despite tires being of the same size and within the above industry tolerances.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire tread depth will also differ from manufacturer to manufacturer which will affect the tire geometry despite tires being of the same size and within the above industry tolerances.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-811b-b850-daedbe56840b","parent":{"type":"page_id","page_id":"38234d6d-7cea-8137-8884-d5f67dd6dbb0"},"created_time":"202