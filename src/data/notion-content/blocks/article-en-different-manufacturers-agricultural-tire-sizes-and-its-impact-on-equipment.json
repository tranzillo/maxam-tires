[{"object":"block","id":"38234d6d-7cea-819c-87d1-d41234712552","parent":{"type":"page_id","page_id":"38234d6d-7cea-8137-8884-d5f67dd6dbb0"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Since 1903, all tires, tubes, valves, and rims have followed standards established by the Tire & Rim Association of America (T&RA). Such a move benefits manufacturers, farmers, and growers in the way they source tires and fit their equipment.\n\nThe European market would also follow this model, with the European Tyre and Rim Technical Organization’s (ERTRO) creation in the 1960s. ERTRO standardized pneumatic tires and rims in the same way as the T&RA, providing a benchmark for the industries to follow.\n\nEach size that manufacturers develop must fall within the following tolerance for any given tire size in millimeters or inches:\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Since 1903, all tires, tubes, valves, and rims have followed standards established by the Tire & Rim Association of America (T&RA). Such a move benefits manufacturers, farmers, and growers in the way they source tires and fit their equipment.\n\nThe European market would also follow this model, with the European Tyre and Rim Technical Organization’s (ERTRO) creation in the 1960s. ERTRO standardized pneumatic tires and rims in the same way as the T&RA, providing a benchmark for the industries to follow.\n\nEach size that manufacturers develop must fall within the following tolerance for any given tire size in millimeters or inches:\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"b