"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"41"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"59"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"16.00"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"DW16"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"ETRTO Standard"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"2038"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"80.2"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"479"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"18.9"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":" -"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":" -"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"16.00"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"DW16L"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Common Problems from Mismatched Tires"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"In agriculture, the application and operation most affects tire design and performance within the industry standards. As agricultural tires are considered “off-road” and not US Department of Transportation (DOT) regulated, there is some flexibility in the design process for each tire manufacturer to enhance features to deliver improved performance.\n\nIn all instances, the type of machinery, soil conditions, application, and air pressure maintenance will have a direct impact on its performance even after improvements. Here’s some things to keep in mind when using tires from different manufacturers:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":3,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Tire Operational Condition"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tire Issue"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Recommended Action"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Tire Slip"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Different brand tires on the same axle can create increased tire slip due to diameter or tread width differences when inflated and under load."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Maintain the same brand and size tires on the same axle or side by side to maximize the best possible traction and tire footprint, ensuring improved tire slip."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Excessive Tire Wear"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tire wear for more than 10% difference in tread depth or overall diameter (OD) on the same axle can result in a loss of traction, increased slip, increased fuel consumption, or can impact gear ratios."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"We suggest replacing the tires on the axle of the same brand and OD."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Diameter and Width Differences"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tires that have more than 5% difference in overall diameter that are operating side by side or on the same axle can lead to a loss of traction, increased slip, gear ratio issues, and increased soil compaction."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tire diameters need to be as closely matched as possible to prevent excessive tire slip and to limit any gear ratio issues. We suggest replacing tires on an axle at the same time with the same brand of tires to limit this occurrence."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"To get the best from your tires, understand that these small changes in tire manufacturers can affect the performance of your farm equipment. When you match up your Ag tires properly, you reduce the chances of tire slip, improve fuel efficiency, reduce tire wear, and minimize soil compaction. Check out our website to learn more about our lineup of radial agriculture tires or jump into some more learning on"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"the best ways to choose an Agriculture tire"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}}]