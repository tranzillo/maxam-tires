[{"object":"block","id":"38234d6d-7cea-81fb-a740-c3becc8e9ea9","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"INTRODUCING THE HIGH-TRACTION MS303 SCRAPER TIRE","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"INTRODUCING THE HIGH-TRACTION MS303 SCRAPER TIRE","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81de-aa2f-c9b88d398498","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Delivering Leading Performance & Traction to the Industry","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Delivering Leading Performance & Traction to the Industry","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-819e-b0f1-d6d1b1dc4d7b","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, July 20th, 2021] MAXAM Tire is excited to introduce the MS303 high-traction scraper tire to their comprehensive line-up of OTR products. Available in two sizes, the 33.25R29, and the all-new 37.25R35, the MS303 delivers the reliability, traction, and performance the industry demands.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, July 20th, 2021] MAXAM Tire is excited to introduce the MS303 high-traction scraper tire to their comprehensive line-up of OTR products. Available in two sizes, the 33.25R29, and the all-new 37.25R35, the MS303 delivers the reliability, traction, and performance the industry demands.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8113-87a0-d70d6cb5f1e2","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Expertly engineered to thrive in multiple conditions, the MAXAM MS303 is built to exceed expectations, deliver superior grip and customer value. The MS303 incorporates a durable wear and cut-resistant rubber compound that eliminates the threat of downtime. Providing superior traction in soft, wet, and rocky conditions, the MS303 is a value-added solution.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Expertly engineered to thrive in multiple conditions, the MAXAM MS303 is built to exceed expectations, deliver superior grip and customer value. The MS303 incorporates a durable wear and cut-resistant rubber compound that eliminates the threat of downtime. Providing superior traction in soft, wet, and rocky conditions, the MS303 is a value-added solution.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8181-952e-ffb6964b55c6","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Understanding customer’s needs, MAXAM designed the MS303 with a high-strength bead design that minimizes wheel indexing at high torque. Delivering superior cut resistance, the MS303 is engineered with a reinforced shoulder and sidewall to tackle both smooth and rocky conditions. In addition, the MS303 boasts a self-cleaning tread design to ensure maximum grip in wet conditions and the utmost productivity. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Understanding customer’s needs, MAXAM designed the MS303 with a high-strength bead design that minimizes wheel indexing at high torque. Delivering superior cut resistance, the MS303 is engineered with a reinforced shoulder and sidewall to tackle both smooth and rocky conditions. In addition, the MS303 boasts a self-cleaning tread design to ensure maximum grip in wet conditions and the utmost productivity. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-812a-8b95-d9162c812940","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\"In today’s fast-growing off-the-road global market, the addition of the 37.25R35 scraper tire to the MAXAM MS303 program will provide a major solution to the market. Meeting the demands of the industry, the MS303 is engineered to excel, delivering the performance our customers seek,\" says Matthew Fagan, Director of R&D at MAXAM Tire North America.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"\"In today’s fast-growing off-the-road global market, the addition of the 37.25R35 scraper tire to the MAXAM MS303 program will provide a major solution to the market. Meeting the demands of the industry, the MS303 is engineered to excel, delivering the performance our customers seek,\" says Matthew Fagan, Director of R&D at MAXAM Tire North America.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-816d-af84-ebed6456ab36","parent":{"type":"page_id","page_id":"38234d6d-7cea-81b7-8b1d-f81a14462ebb"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information, contact your local representative or visit us at ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"co