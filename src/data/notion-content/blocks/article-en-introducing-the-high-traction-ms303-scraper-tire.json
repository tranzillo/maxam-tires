[{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"INTRODUCING THE HIGH-TRACTION MS303 SCRAPER TIRE"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Delivering Leading Performance & Traction to the Industry"},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, July 20th, 2021] MAXAM Tire is excited to introduce the MS303 high-traction scraper tire to their comprehensive line-up of OTR products. Available in two sizes, the 33.25R29, and the all-new 37.25R35, the MS303 delivers the reliability, traction, and performance the industry demands."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Expertly engineered to thrive in multiple conditions, the MAXAM MS303 is built to exceed expectations, deliver superior grip and customer value. The MS303 incorporates a durable wear and cut-resistant rubber compound that eliminates the threat of downtime. Providing superior traction in soft, wet, and rocky conditions, the MS303 is a value-added solution."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Understanding customer’s needs, MAXAM designed the MS303 with a high-strength bead design that minimizes wheel indexing at high torque. Delivering superior cut resistance, the MS303 is engineered with a reinforced shoulder and sidewall to tackle both smooth and rocky conditions. In addition, the MS303 boasts a self-cleaning tread design to ensure maximum grip in wet conditions and the utmost productivity. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\"In today’s fast-growing off-the-road global market, the addition of the 37.25R35 scraper tire to the MAXAM MS303 program will provide a major solution to the market. Meeting the demands of the industry, the MS303 is engineered to excel, delivering the performance our customers seek,\" says Matthew Fagan, Director of R&D at MAXAM Tire North America."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information, contact your local representative or visit us at "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"maxamtire.com","link":{"url":"https://maxamtire.com"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2021/01/ms303_th.png"}}},{"object":"block","type":"table","table":{"table_width":3,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Size"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":" "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Rating"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"T.D."},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"(32nds/mm)"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"33.25R29"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"**"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"55 / 44"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"37.25R35"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"**"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"75 / 60"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]}]