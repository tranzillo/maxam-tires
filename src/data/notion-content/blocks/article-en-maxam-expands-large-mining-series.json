[{"object":"block","id":"38234d6d-7cea-819d-bc16-dfb56e047ae5","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"MAXAM EXPANDS LARGE MINING SERIES","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM EXPANDS LARGE MINING SERIES","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-812c-ab4f-e00afe13c551","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MAXAM Solution for Large Mining Applications ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM Solution for Large Mining Applications ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8170-a20f-ff6b7a266f9d","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, Oct 15th, 2019] MAXAM Tire announces the expansion of the Large Mining series to their broad range of specialty tire programs. MAXAM has engineered their haulage tires (MS401, MS402, MS403) to provide the industry with the best solution for mining applications.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, Oct 15th, 2019] MAXAM Tire announces the expansion of the Large Mining series to their broad range of specialty tire programs. MAXAM has engineered their haulage tires (MS401, MS402, MS403) to provide the industry with the best solution for mining applications.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-812d-9f6a-faa8dd5085c6","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The Large Mining product line is the result of extensive research and testing in multiple mine locations across several continents. In order to meet the toughest application requirements, the new haulage tires utilize newly developed compounding and carcass construction. These enhancements allow MAXAM’s Large Mining products to provide the best delivered value, greatest productivity and lowest cost per ton value of operation. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The Large Mining product line is the result of extensive research and testing in multiple mine locations across several continents. In order to meet the toughest application requirements, the new haulage tires utilize newly developed compounding and carcass construction. These enhancements allow MAXAM’s Large Mining products to provide the best delivered value, greatest productivity and lowest cost per ton value of operation. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-814f-8202-d2af359227cb","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Available for haul trucks up to 320 tons, MAXAM offers three specific tread patterns available in multiple compounds based on site TKPH/TMPH to meet different surface mine application requirements. The MS401 features an aggressive tread design with heat-resistant under tread, ideal for applications that require maximum traction and high site TKPH/TMPH. The MS402 features enhanced shoulder lugs and a solid centerline providing increased protection, traction and tread life in haulage applications. The MS403 integrates an advanced tread design for flexibility in all applications, from smooth haul roads to rough and rocky terrain. Designed to deliver lowest cost per hour/ton, the MS403 is the proven solution for the mining industry. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Available for haul trucks up to 320 tons, MAXAM offers three specific tread patterns available in multiple compounds based on site TKPH/TMPH to meet different surface mine application requirements. The MS401 features an aggressive tread design with heat-resistant under tread, ideal for applications that require maximum traction and high site TKPH/TMPH. The MS402 features enhanced shoulder lugs and a solid centerline providing increased protection, traction and tread life in haulage applications. The MS403 integrates an advanced tread design for flexibility in all applications, from smooth haul roads to rough and rocky terrain. Designed to deliver lowest cost per hour/ton, the MS403 is the proven solution for the mining industry. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-813e-8d7e-f33e115a8c64","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MAXAM is a global specialty tire supplier with a full range of products for construction, material handling, agricultural, forestry and other specialty segments. Innovative engineering, extensive testing, research and state-of-the-art manufacturing differentiates themselves from their competitors. Centering MAXAM’s core values around innovation and commitment to provide an exceptional customer experience. As a rapidly growing global organization, MAXAM invests heavily in their people, advanced engineering and their manufacturing facilities to ensure unique business solutions are delivered to customers worldwide. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM is a global specialty tire supplier with a full range of products for construction, material handling, agricultural, forestry and other specialty segments. Innovative engineering, extensive testing, research and state-of-the-art manufacturing differentiates themselves from their competitors. Centering MAXAM’s core values around innovation and commitment to provide an exceptional customer experience. As a rapidly growing global organization, MAXAM invests heavily in their people, advanced engineering and their manufacturing facilities to ensure unique business solutions are delivered to customers worldwide. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8129-b812-fe6865de528e","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information contact your local representative or visit us at maxamtire.com","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For additional information contact your local representative or visit us at maxamtire.com","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-811a-bc49-f4743e3fa4a1","parent":{"type":"page_id","page_id":"38234d6d-7cea-81c8-91ab-df1d192ff59f"},"created_time":"2026-06-17T19:20:00.000Z","last_edited_time":"2026-06-17T19:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MS401","link":null},"annotations":{"bold":true,"ita