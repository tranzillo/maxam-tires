[{"object":"block","id":"38234d6d-7cea-81ac-a2da-c842b6fdb8d9","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM EXPANDS THE MS930 LOGXTRA SERIES ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM EXPANDS THE MS930 LOGXTRA SERIES ","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8154-ba4c-cf392803f34c","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Delivering a Rugged and Reliable Tire to Dual Wheel Applications Globally","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Delivering a Rugged and Reliable Tire to Dual Wheel Applications Globally","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81cf-827c-faef64ac78fe","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, November 16th, 2021] To further strengthen the market offering of the LOGXTRA lineup, MAXAM is proud to announce the new size addition to the MS930 series. Specifically designed for high flotation applications, the 24.5-32 MS930 offers a winning combination of strength and reliability, making it a popular choice for dual-wheel applications.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, November 16th, 2021] To further strengthen the market offering of the LOGXTRA lineup, MAXAM is proud to announce the new size addition to the MS930 series. Specifically designed for high flotation applications, the 24.5-32 MS930 offers a winning combination of strength and reliability, making it a popular choice for dual-wheel applications.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81c7-adef-e12873f1f368","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MAXAM LOGXTRA series combines advanced manufacturing with superior product quality, offering an undeniable value and high-strength solution to the timber industry. With the addition of the 24.5-32 to the MS930 series, MAXAM now delivers this dependable tire to dual-wheel applications. Offered at an aggressive price point, the MS930 is an added-value solution for skidders and feller bunchers globally.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM LOGXTRA series combines advanced manufacturing with superior product quality, offering an undeniable value and high-strength solution to the timber industry. With the addition of the 24.5-32 to the MS930 series, MAXAM now delivers this dependable tire to dual-wheel applications. Offered at an aggressive price point, the MS930 is an added-value solution for skidders and feller bunchers globally.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81fa-879f-e353e22c84d5","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"To fit the needs of the application, the MS930 is manufactured with an extra-wide footprint that delivers exceptional flotation in muddy and wet ground conditions, increasing efficiency on all sites. Additionally, the high-strength, belt-stabilized tire construction provides excellent grip and protection from the harsh working environment. Integrating advanced compounding and enhanced features such as a heavy-duty shoulder and sidewall, the MS930 helps eliminate the threat of downtime. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"To fit the needs of the application, the MS930 is manufactured with an extra-wide footprint that delivers exceptional flotation in muddy and wet ground conditions, increasing efficiency on all sites. Additionally, the high-strength, belt-stabilized tire construction provides excellent grip and protection from the harsh working environment. Integrating advanced compounding and enhanced features such as a heavy-duty shoulder and sidewall, the MS930 helps eliminate the threat of downtime. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81be-b14d-dfef2bdc201a","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MS930 LOGXTRA delivers the flotation, strength, and grip the timber industry demands at an exceptional value. Available in the below size range, the MS930 comes in a variety of ply ratings to meet the needs of each application.  ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MS930 LOGXTRA delivers the flotation, strength, and grip the timber industry demands at an exceptional value. Available in the below size range, the MS930 comes in a variety of ply ratings to meet the needs of each application.  ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81e6-ae99-c12340a61357","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cb-9152-c6bfa0298ab3"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional informa