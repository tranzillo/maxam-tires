[{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM MS302 BOASTS A COMPLETE LINE WITH NEW SIZES"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MS302 delivers innovation and performance"},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, Feb 2nd, 2021] MAXAM Tire North America is pleased to announce that the MS302 E3/L3+ is now a complete line with the addition of two new sizes. The 20.5R25 and 550/65R25 are available now for fitment on small wheel loaders and motor graders."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Expertly engineered to thrive under extreme conditions, the MAXAM MS302 is built tough to exceed expectations, deliver excellent traction and customer value. Featuring a rugged E3/L3+ heavy duty design for maximum traction in all off-road applications, the MS302 delivers the high heat resistance needed for rugged applications. Designed with reinforced lugs to minimizes vibration at haul speeds and provide the lowest cost-per-hour, the MS302 is a value-added solution. Designed to minimize downtime due to tire damage, the MS302 incorporates durable cut and tear resistant rubber compound that eliminates the constant threat of downtime due to tire damage."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\"In a rapidly growing off-the-road global market, the addition of the two new sizes complete the MS302 line delivering solutions to OTR applications globally. To meet the demands and ever-increasing productivity our customers have, the MS302 line is engineered to perform excellently while safely tackling challenges of OTR equipment,\" says Matthew Fagan, Director of R&D at MAXAM Tire North America."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For more information, please contact your local representative or visit us at "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"www.maxamtire.com","link":{"url":"http://www.localhost:10022"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":3,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Size"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":" "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"TYPE"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"T.D."},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"(32nds/mm)"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"con