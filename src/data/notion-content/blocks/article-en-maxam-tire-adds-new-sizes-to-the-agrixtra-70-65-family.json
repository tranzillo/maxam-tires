[{"object":"block","id":"38234d6d-7cea-81ec-8bdb-ebcc2103a5fd","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM Tire Adds New Sizes to the AGRIXTRA 70 & 65 Family of Agricultural Tires","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM Tire Adds New Sizes to the AGRIXTRA 70 & 65 Family of Agricultural Tires","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8168-9bf8-c02714e104cb","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Expanding the AGRIXTRA series to simplify farmers and growers’ lives","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Expanding the AGRIXTRA series to simplify farmers and growers’ lives","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8119-aaf5-cff6de8dab09","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, September 27th, 2022]","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, September 27th, 2022]","href":null},{"type":"text","text":{"content":" MAXAM Tire, a global leader in specialty tire manufacturing, continues to expand its product offerings in the AGRIXTRA 70 and 65 series of agricultural tires. Focused on delivering a performance-driven range of products to the global market, the addition of the new sizes to the AGRIXTRA family will provide farmers and growers with more options for varied farming applications. Starting this fall, the all-new AGRIXTRA 70 & 65 sizes will be available for purchase and will be offered as a part of the MAXAM North American Spring Savings Program for 2023.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" MAXAM Tire, a global leader in specialty tire manufacturing, continues to expand its product offerings in the AGRIXTRA 70 and 65 series of agricultural tires. Focused on delivering a performance-driven range of products to the global market, the addition of the new sizes to the AGRIXTRA family will provide farmers and growers with more options for varied farming applications. Starting this fall, the all-new AGRIXTRA 70 & 65 sizes will be available for purchase and will be offered as a part of the MAXAM North American Spring Savings Program for 2023.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8161-bc93-c0aef2cae377","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The wide profile AGRIXTRA 70-series, engineered to deliver extra flotation and traction, will add seven new sizes to the product family. The self-cleaning wide tread design maximizes performance in the field, delivering the utmost productivity to users. Sporting a premium 45° lug profile, the 70 series provides excellent traction and minimizes vibration while roading.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The wide profile AGRIXTRA 70-series, engineered to deliver extra flotation and traction, will add seven new sizes to the product family. The self-cleaning wide tread design maximizes performance in the field, delivering the utmost productivity to users. Sporting a premium 45° lug profile, the 70 series provides excellent traction and minimizes vibration while roading.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81da-a4b3-c04ea3fb867a","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"In addition, MAXAM has released two new sizes to the AGRIXTRA 65 series family. The all-new 600/65R34 and 650/65R38 AGRIXTRA 65 tires, like the 70 series, boast an extra wide profile for high flotation and superior traction. The 65-series is engineered to employ premium rubber compounds that reduce ozone cracking and weathering, delivering a greater value to farmers through decreased tire wear rates. Developed with the user in mind, the AGRIXTRA 65 series provides minimal soil disturbance through its wide gross flat plate that maximizes flotation during every rotation.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"In addition, MAXAM has released two new sizes to the AGRIXTRA 65 series family. The all-new 600/65R34 and 650/65R38 AGRIXTRA 65 tires, like the 70 series, boast an extra wide profile for high flotation and superior traction. The 65-series is engineered to employ premium rubber compounds that reduce ozone cracking and weathering, delivering a greater value to farmers through decreased tire wear rates. Developed with the user in mind, the AGRIXTRA 65 series provides minimal soil disturbance through its wide gross flat plate that maximizes flotation during every rotation.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8144-820a-d5273a59bd71","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"“Offering improved traction, increased stability, and reduced slip, the AGRIXTRA family of products, allows MAXAM to deliver a value-driven and comprehensive solution to farmers and growers globally. MAXAM’s 8-year tire warranty is our promise to farmers and growers that we remain confident in protecting their investments,” says Greg Gilland, Vice President of Global Agriculture at MAXAM Tire.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"“Offering improved traction, increased stability, and reduced slip, the AGRIXTRA family of products, allows MAXAM to deliver a value-driven and comprehensive solution to farmers and growers globally. MAXAM’s 8-year tire warranty is our promise to farmers and growers that we remain confident in protecting their investments,” says Greg Gilland, Vice President of Global Agriculture at MAXAM Tire.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8126-9d14-ca142251e934","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For more information, contact your local representative or visit us at www.maxamtire.com.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For more information, contact your local representative or visit us at www.maxamtire.com.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8108-8e77-c99ba2d95440","parent":{"type":"page_id","page_id":"38234d6d-7cea-8136-9619-cf68d9c50eca"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":true,"in_trash":false,"type":"table","table":{"table_width":1,"has_column_header":true,"has_row_he