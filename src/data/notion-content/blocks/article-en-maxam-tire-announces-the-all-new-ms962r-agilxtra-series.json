[{"object":"block","id":"38234d6d-7cea-813a-b841-df5fabb0e1fe","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM Tire Announces the All-New MS962R AGILXTRA Series","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM Tire Announces the All-New MS962R AGILXTRA Series","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81b0-aa74-e8e662b0a851","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The Radial Flotation Solution for Preserving Crops and Soil Mineral Regeneration","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The Radial Flotation Solution for Preserving Crops and Soil Mineral Regeneration","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8150-b18c-fd1e54f9c474","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, Jan 3rd, 2023]","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, Jan 3rd, 2023]","href":null},{"type":"text","text":{"content":" MAXAM Tire, a global leader in specialty tire manufacturing, celebrates another milestone in the agricultural industry by delivering an all-new product solution. Announcing the MS962R AGILXTRA radial flotation series, manufactured to help farmers and growers preserve crops and the mineral regeneration of their soil.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" MAXAM Tire, a global leader in specialty tire manufacturing, celebrates another milestone in the agricultural industry by delivering an all-new product solution. Announcing the MS962R AGILXTRA radial flotation series, manufactured to help farmers and growers preserve crops and the mineral regeneration of their soil.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8196-92fd-ef346c7d381d","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Now available in seven sizes, this new radial high-speed D-rated implement I3 flotation tire is manufactured to provide the longest treadwear, increased stability, and improved resistance to field hazards. Similar to the MAXAM FLOTXTRA series, the all-new MS962R AGILXTRA radial tire is designed with a fabric casing supported by steel belts to enhance flotation in any mixed-use surface application. Sporting a wear and cut-resistant tread compound, the AGILXTRA ensures productivity and performance in all applications with maximum versatility.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Now available in seven sizes, this new radial high-speed D-rated implement I3 flotation tire is manufactured to provide the longest treadwear, increased stability, and improved resistance to field hazards. Similar to the MAXAM FLOTXTRA series, the all-new MS962R AGILXTRA radial tire is designed with a fabric casing supported by steel belts to enhance flotation in any mixed-use surface application. Sporting a wear and cut-resistant tread compound, the AGILXTRA ensures productivity and performance in all applications with maximum versatility.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-811f-a80a-c4f526cff871","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Protecting farmers’ and growers’ investments with its innovative construction, the AGILXTRA is engineered to deliver value without compromising wear or endurance. Providing superior field traction with minimal vibration at roading speeds, the innovative MS962R’s tread pattern is optimized to ensure high traction no matter the conditions. Backed by an 8-year warranty, MAXAM is committed to ensuring the quality and performance of our tires.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Protecting farmers’ and growers’ investments with its innovative construction, the AGILXTRA is engineered to deliver value without compromising wear or endurance. Providing superior field traction with minimal vibration at roading speeds, the innovative MS962R’s tread pattern is optimized to ensure high traction no matter the conditions. Backed by an 8-year warranty, MAXAM is committed to ensuring the quality and performance of our tires.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8175-9ab3-ec95b1f1a769","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"“The MAXAM range of radial agricultural tires has built a reputation for improved performance and value, engendering exceptional customer feedback. In conjunction with the MS961R FLOTXTRA series, the new MS962R AGILXTRA allows MAXAM to deliver two viable performance-driven flotation solutions to the market and continue to expand upon our reputation within the segment,” says Greg Gilland, Vice President of Global Agriculture at MAXAM Tire.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"“The MAXAM range of radial agricultural tires has built a reputation for improved performance and value, engendering exceptional customer feedback. In conjunction with the MS961R FLOTXTRA series, the new MS962R AGILXTRA allows MAXAM to deliver two viable performance-driven flotation solutions to the market and continue to expand upon our reputation within the segment,” says Greg Gilland, Vice President of Global Agriculture at MAXAM Tire.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81db-aa10-c575305a6ac2","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MAXAM will display the all-new AGILXTRA at the National Farm Machinery Show 2023, February 15th-18th at booth #7764","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM will display the all-new AGILXTRA at the National Farm Machinery Show 2023, February 15th-18th at booth #7764","href":null},{"type":"text","text":{"content":". For more information on the new MAXAM MS962R AGILXTRA, please contact your local representative or visit us at maxamtire.com ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":". For more information on the new MAXAM MS962R AGILXTRA, please contact your local representative or visit us at maxamtire.com ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-81c3-918a-fa03774d614d","parent":{"type":"page_id","page_id":"38234d6d-7cea-81cd-b583-ea41b028fce1"},"created_time":"2026-06-17T19:19:00.000Z","last_edited_time":"2026-06-17T19:19:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"u