[{"object":"block","id":"38234d6d-7cea-81c1-a6b3-d37a58dff087","parent":{"type":"page_id","page_id":"38234d6d-7cea-8161-afb1-ca1b8629ae8a"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Danvers, MA – Nov 11th, 2025 - ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Danvers, MA – Nov 11th, 2025 - ","href":null},{"type":"text","text":{"content":"MAXAM Tire announces the addition of the ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM Tire announces the addition of the ","href":null},{"type":"text","text":{"content":"MS303","link":{"url":"https://maxamtire.com/tire/ms303/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MS303","href":"https://maxamtire.com/tire/ms303/"},{"type":"text","text":{"content":" 40.5/75R39 to its portfolio, engineered for demanding scraper applications, empowering larger earthmoving fleets with a new, high-performance option.\n\nPurpose-built for exceptional ride quality and stability even at higher transport speeds, the MS303 couples a robust casing structure with an aggressive E3 tread. For wear and tear resistance, the tire features a fortified shoulder and sidewall help guard against cuts and impacts. In addition, the MS303 integrates a high-strength bead design which improves durability and increases the machine stability under maximum load. The result is confident traction, consistent handling, and dependable performance across viable ground conditions, shift after shift.\n\n“Contractors and quarry operators run on uptime. The new MS303 40.5/75R39 delivers traction, durability, superior ride quality and control they demand on the toughest jobs,” said Jimmy McDonnell, VP of Sales & Marketing at MAXAM Tire. “Our customers can move more material with fewer interruptions and a lower total cost of operations.”\n\nThe MS303 40.5/75R39 arrives as a strategic complement to MAXAM’s growing scraper range, enabling fleets to standardize on a proven design that thrives in variable terrain and high-impact environments. With the MS303, operations gain a tire that lasts longer, supporting productivity on the job site.\n\nFor more information on the MS303 40.5/75R39, please contact your local MAXAM rep or visit us at ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" 40.5/75R39 to its portfolio, engineered for demanding scraper applications, empowering larger earthmoving fleets with a new, high-performance option.\n\nPurpose-built for exceptional ride quality and stability even at higher transport speeds, the MS303 couples a robust casing structure with an aggressive E3 tread. For wear and tear resistance, the tire features a fortified shoulder and sidewall help guard against cuts and impacts. In addition, the MS303 integrates a high-strength bead design which improves durability and increases the machine stability under maximum load. The result is confident traction, consistent handling, and dependable performance across viable ground conditions, shift after shift.\n\n“Contractors and quarry operators run on uptime. The new MS303 40.5/75R39 delivers traction, durability, superior ride quality and control they demand on the toughest jobs,” said Jimmy McDonnell, VP of Sales & Marketing at MAXAM Tire. “Our customers can move more material with fewer interruptions and a lower total cost of operations.”\n\nThe MS303 40.5/75R39 arrives as a strategic complement to MAXAM’s growing scraper range, enabling fleets to standardize on a proven design that thrives in variable terrain and high-impact environments. With the MS303, operations gain a tire that lasts longer, supporting productivity on the job site.\n\nFor more information on the MS303 40.5/75R39, please contact your local MAXAM rep or visit us at ","href":null},{"type":"text","text":{"content":"maxamtire.com","link":{"url":"https://maxamtire.com/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"maxamtire.com","href":"https://maxamtire.com/"},{"type":"text","text":{"content":".\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":".\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-816a-a0df-e919b47d24ce","parent":{"type":"page_id","page_id":"38234d6d-7cea-8161-afb1-ca1b8629ae8a"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Download Press Release","link":{"url":"https://maxamtire.com/wp-content/uploads/2025/09/MAXAM-Tire-Expands-MS303-Scraper-Line-To-Power-Heavy-duty-Earthmoving-Performance_final.pdf"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Download Press Release","href":"https://maxamtire.com/wp-content/uploads/2025/09/MAXAM-Tire-Expands-MS303-Scraper-Line-To-Power-Heavy-duty-Earthmoving-Performance_final.pdf"}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-814b-a121-d2a76bc8c96e","