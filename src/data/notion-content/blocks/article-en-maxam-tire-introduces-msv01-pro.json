[{"object":"block","id":"38234d6d-7cea-8166-9102-f4dabfc65fd9","parent":{"type":"page_id","page_id":"38234d6d-7cea-8153-b421-e2dd8b757fdd"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Danvers, MA – February 10th, 2026","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Danvers, MA – February 10th, 2026","href":null},{"type":"text","text":{"content":" – MAXAM Tire is proud to announce the launch of the MSV01 PRO, a high-performance crane tire engineered for equipment operating in both highway and off-the-road environments. Designed with a TBR-style casing and a closed-shoulder tread configuration, the MSV01 PRO delivers superior durability and exceptional handling performance across various working conditions.\n\nDesigned to meet the needs of modern crane applications, the MSV01 is F-Speed rated (50mph / 80kph), providing operators with confidence when traveling at highway speeds between job sites. The newly engineered tread pattern is optimized to significantly reduce road noise and vibration, helping improve operator comfort during long transport cycles. The closed-shoulder design improves fuel efficiency and steering responsiveness on pavement, while the deep tread and aggressive traction lug pattern provide outstanding grip in wet or soft terrain conditions.\n\n“With the MSV01, we’re expanding our commitment to deliver purpose-built solutions for specialty equipment,” said Jimmy McDonnel, VP of Sales and Marketing at MAXAM Tire. “This tire was engineered based on direct feedback from crane operators and fleet owners who needed more reliability both on the highway and in off-the-road environments. The MSV01 delivers the comfort, stability and traction performance that today’s demanding job sites require, while reducing downtime and improving operational efficiency.”\n\nDeveloped for maximum performance and versatility, the MSV01 underscores MAXAM’s continued investment in advanced tire engineering and support for industries that rely on equipment mobility and productivity.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" – MAXAM Tire is proud to announce the launch of the MSV01 PRO, a high-performance crane tire engineered for equipment operating in both highway and off-the-road environments. Designed with a TBR-style casing and a closed-shoulder tread configuration, the MSV01 PRO delivers superior durability and exceptional handling performance across various working conditions.\n\nDesigned to meet the needs of modern crane applications, the MSV01 is F-Speed rated (50mph / 80kph), providing operators with confidence when traveling at highway speeds between job sites. The newly engineered tread pattern is optimized to significantly reduce road noise and vibration, helping improve operator comfort during long transport cycles. The closed-shoulder design improves fuel efficiency and steering responsiveness on pavement, while the deep tread and aggressive traction lug pattern provide outstanding grip in wet or soft terrain conditions.\n\n“With the MSV01, we’re expanding our commitment to deliver purpose-built solutions for specialty equipment,” said Jimmy McDonnel, VP of Sales and Marketing at MAXAM Tire. “This tire was engineered based on direct feedback from crane operators and fleet owners who needed more reliability both on the highway and in off-the-road environments. The MSV01 delivers the comfort, stability and traction performance that today’s demanding job sites require, while reducing downtime and improving operational efficiency.”\n\nDeveloped for maximum performance and versatility, the MSV01 underscores MAXAM’s continued investment in advanced tire engineering and support for industries that rely on equipment mobility and productivity.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38234d6d-7cea-8132-ae62-d017694bf352","parent":{"type":"page_id","page_id":"38234d6d-7cea-8153-b421-e2dd8b757fdd"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2026/01/MAXAM-MSV01PRO_PressRelease_image.jpg"}},"archived":false},{"object":"block","id":"38234d6d-7cea-8194-ba23-fd8c39ecf24b","parent":{"type":"page_id","page_id":"38234d6d-7cea-8153-b421-e2dd8b757fdd"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":true,"in_trash":false,"type":"table","table":{"table_width":3,"has_column_header":true,"has_row_header":false},"archived":false,"children":[{"object":"block","id":"38234d6d-7cea-815e-b865-c765d1dbc418","parent":{"type":"block_id","block_id":"38234d6d-7cea-8194-ba23-fd8c39ecf24b"},"created_time":"2026-06-17T19:18:00.000Z","last_edited_time":"2026-06-17T19:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Size","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":f