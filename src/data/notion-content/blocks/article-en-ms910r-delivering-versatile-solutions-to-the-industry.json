[{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MS910R DELIVERING VERSATILE SOLUTIONS TO THE INDUSTRY"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM Debuts the Complete MS910R Series for Compact Equipment"},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, February 23rd, 2021] MAXAM is excited to debut the full line of the MS910R multipurpose radial tire. The versatile MS910R is designed to operate in multiple applications, including agriculture, construction, and industrial vehicles. Engineered to provide the industry with a versatile solution, the MS910R delivers the performance customers seek in MAXAM’s products."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Developed with the end-user in mind, the MS910R boasts an all-steel radial construction to provide maximum durability, stability, and improved traction in every application. Designed to operate on a wide range of equipment from telehandlers to compact wheel loaders, the MS910R is engineered to minimize vibration providing a comfortable ride without compromising traction."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MS910R exhibits a versatile lug pattern adapted to meet the demands of every vehicle it serves. Featuring a unique self-cleaning design with cutting-edge mud breakers, the MS910R prevents terrain buildup in the lugs ensuring maximum grip and performance."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MS910R delivers performance, durability, and adaptability to sites globally. The MS910R is available in the below sizes for three different applications: multipurpose (MPT), industrial (IN), and construction (EM). "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information, contact your local representative or visit us at "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"maxamtire.com","link":{"url":"https://maxamtirena.com/en-us/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2021/01/ms910r_th.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Multipurpose Radial "},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":3,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Size"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":" "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"te