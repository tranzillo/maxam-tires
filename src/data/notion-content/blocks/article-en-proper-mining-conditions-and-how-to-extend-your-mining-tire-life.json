[{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Proper-mining-conditions-and-how-to-extend-tire-life-banner.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Proper mining conditions and how to extend tire life"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"With rigid haul truck tires being one of the highest expenses for your mining operations, maintaining proper mining conditions for the tires plays a key role in extending tire life. In this article, we discuss in depth factors that affect your mining tire’s life and some ways to improve site conditions, ensuring maximum tire life and productivity."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Inflation Pressure"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Inflation pressure is dependent on:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Load / overload"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Type of service"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Tire type and location on the vehicle"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Designed (percentage) deflection of the tire"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Keep in mind that the published inflation pressures recommended by your manufacturer are for standard loads. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"If you overload, inflation pressure should be increased 2% for each 1% of overload and max out at 14% of 7% overload."},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Below is a comparison of what overinflation and underinflation does for your mining tires. "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Proper-mining-conditions-article_inflation-comparison.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Loads"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Ensure that the shovel operator controls the specified payload and distributes the load equally on each tire of the equipment because all tires should carry equal loads. MAXAM always recommends operations refer to the pressure load table specific to each tire to determine tire load according to the size and ply, and star rating."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Mining-article_overloading.jpg"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Overloading can cause"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":": "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Casing and heat fatigue"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Radial cracking"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Inner liner failure"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Greater chance for impacts"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Reduced rim life"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Proper-mining-conditions-article_tire-life-vs-load.png"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Here's an illustration of how overloading can affect tire life relatively."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Grades"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Haul roads should be ideally straight for rigid dump trucks because "},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"for every 1% change in grade, the load will transfer 2%"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":". Below is an example of the setting level for your front and rear tires on a 777D rigid dump truck and how it affects the tires."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Proper-mining-conditions-article_grades-ex.png"}}},{"object":"block","type":"table","table":{"table_width":2,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Load"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tire Life"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Rated"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"100%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"110%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"90%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"120%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"80%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"140%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"50%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"tire life vs. load"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tire life or cost to fix the grade should be decided by the mine. However, having the downtime might affect overall productivity."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Mining-article_grade-1.jpg"}}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Mining-article_grade-2.jpg"}}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Grades should be minimized for a degree of rise and length. Best grades usually range from 5% to 8%, which will reduce tire slip and increase overall fuel economy."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Underfoot conditions"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Ensure the haul road is clean with minimum spillage with rocks by conducting continuous use of graders around the site."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tires that are being run on a rutted road can have:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"sidewall and tread cuts"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"stress on the casing when the truck enters and leaves the rut"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"table","table":{"table_width":2,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Condition"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"Tire life"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Soft earth - no rock"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"100%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Soft earth - some rock"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"90%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Shot rock"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"60%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Shot rock in water"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"40%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"A good haul road is equivalent to a lower cost per hour. Poor haul roads will lead to early tire failures due to:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"rock cuts"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"chunking"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"rock cut separations"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Mining-article_poor-haul-road-vs-good-haul-road.jpg"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Curves"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The less curves your mine site has, the better, more importantly, negative curves should never exist. Trucks running around curves can:"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Put high lateral tire forces which significantly increases wear and tear"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Inconsistent speeds"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Increase chance of spillage"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Slower cycle time"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Mining-article_curve.jpg"}}},{"object":"block","type":"table","table":{"table_width":2,"has_column_header":true,"has_row_header":false},"children":[{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"Curves"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"\n\n"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}},{"type":"text","text":{"content":"Tire life"},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"None"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"100%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Moderate"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"90%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}},{"object":"block","type":"table_row","table_row":{"cells":[[{"type":"text","text":{"content":"Severe"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}],[{"type":"text","text":{"content":"80%"},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]]}}]},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Maintaining proper mine site condition is a cross-departmental effort, involving mine management, engineering, operations, training, maintenance, purchasing, tire maintenance and tire manufacturers. With rigid haul trucks’ tires being one of the top expenses for mining operations, ensuring the utmost condition of the mine site will significantly increase tire life."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Should you need further assistance, contact your local MAXAM rep and we’ll assist you with your inquiries."},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false}}]}},{"object":"block","type":"image","image":{"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/proper-mine-site-email-infograh-1.png"}}},{"object":"block","type":"heading_3","heading_3":{"rich_text":[]}}]