[{"object":"block","id":"35534d6d-7cea-8103-8534-f949b7b2f8ef","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Whether you’re wheeling in between warehouses, or powering operations on the ports, your forklift fleet is the key to efficiency in material handling. How well your equipment performs daily can make all the difference between business-as-usual and unexpected downtime.\n\nForklift tire condition impacts forklift fleets everywhere. New or well-maintained tires lead to better results for your fleet. Damage, wear, and other factors often lead to equipment failure, lost productivity, and potentially, safety hazards.\n\nBelow, we’ll dive into the different types of forklift tires and the best times to replace them, offering our best tips to maintain your forklift tires.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Whether you’re wheeling in between warehouses, or powering operations on the ports, your forklift fleet is the key to efficiency in material handling. How well your equipment performs daily can make all the difference between business-as-usual and unexpected downtime.\n\nForklift tire condition impacts forklift fleets everywhere. New or well-maintained tires lead to better results for your fleet. Damage, wear, and other factors often lead to equipment failure, lost productivity, and potentially, safety hazards.\n\nBelow, we’ll dive into the different types of forklift tires and the best times to replace them, offering our best tips to maintain your forklift tires.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e0-bd30-d3cabe44aa0b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Recap: Different Types of Forklift Tires","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Recap: Different Types of Forklift Tires","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e8-a3ce-fb441bcdf01b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"If you’ve been in the industry, this may not be much of a secret. However, spotting the key differences between forklift tires not only informs you in the future, but helps you maintain tires of any kind. Forklifts are typically fitted with the following type of tires:","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"If you’ve been in the industry, this may not be much of a secret. However, spotting the key differences between forklift tires not only informs you in the future, but helps you maintain tires of any kind. Forklifts are typically fitted with the following type of tires:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8192-ab2f-e142feacae9b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Press-On Solids: ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Press-On Solids: ","href":null},{"type":"text","text":{"content":"Also known as cushion tires, they are often constructed with solid rubber with or without tread. Press-on tires are installed on wheels using tire pressing rings.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Also known as cushion tires, they are often constructed with solid rubber with or without tread. Press-on tires are installed on wheels using tire pressing rings.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c6-a257-cf969afb8773","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Standard Pneumatic Tires: ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Standard Pneumatic Tires: ","href":null},{"type":"text","text":{"content":"Like your average car tire, these incorporate an inner tube to hold air and, in some cases, foam.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Like your average car tire, these incorporate an inner tube to hold air and, in some cases, foam.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ba-8035-ccf6f6185727","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Solid Pneumatic/Resilient Tires: ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Solid Pneumatic/Resilient Tires: ","href":null},{"type":"text","text":{"content":"Rather than air, these forklift tires are shaped like standard pneumatics but have a solid rubber core instead.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Rather than air, these forklift tires are shaped like standard pneumatics but have a solid rubber core instead.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c9-b83c-ed3c38dbfa01","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"YOU MIGHT LIKE: [","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"YOU MIGHT LIKE: [","href":null},{"type":"text","text":{"content":"How to Read Forklift Tire Sizes","link":{"url":"https://maxamtire.com/how-to-read-forklift-tire-sizes/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"How to Read Forklift Tire Sizes","href":"https://maxamtire.com/how-to-read-forklift-tire-sizes/"},{"type":"text","text":{"content":"]","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"]","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8124-9160-eea76116d0e7","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Each type of forklift tire is optimal for a specific work environment. Understanding the different types demonstrates the importance of using proper tires. If it’s due to load, tread, or equipment specifications, using the wrong forklift tire can your forklift’s overall performance, even lead to an earlier tire replacement.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Each type of forklift tire is optimal for a specific work environment. Understanding the different types demonstrates the importance of using proper tires. If it’s due to load, tread, or equipment specifications, using the wrong forklift tire can your forklift’s overall performance, even lead to an earlier tire replacement.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8157-a49a-dcad5a4fb5b6","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"When is it Time to Replace Forklift Tires?","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"When is it Time to Replace Forklift Tires?","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8153-9038-cd76882dd95a","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"With the different forklift tire types identified, how you identify potential problems varies from tire to tire. What damage may look like on a press-on, could look different from a standard pneumatic tire.\n\nBelow are some common types of forklift tire damage and the cause, what they look like on each tire, and what you can do about it:","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"With the different forklift tire types identified, how you identify potential problems varies from tire to tire. What damage may look like on a press-on, could look different from a standard pneumatic tire.\n\nBelow are some common types of forklift tire damage and the cause, what they look like on each tire, and what you can do about it:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81d8-8dba-fc68100c8199","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81d5-8c58-f1d79adc860e","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Tire Chunking","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire Chunking","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8174-88af-c9ee38fcdc97","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tire chunking—the loss of large rubber pieces from the tread—often occurs due to abrasive surfaces, overloaded equipment, or aggressive maneuvers. This issue compromises traction and exposes the tire’s inner layers, leading to further damage. To reduce chunking, avoid rough or debris-covered floors (and ensure your warehouse floor is clean) and ensure loads stay within the forklift’s capacity.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire chunking—the loss of large rubber pieces from the tread—often occurs due to abrasive surfaces, overloaded equipment, or aggressive maneuvers. This issue compromises traction and exposes the tire’s inner layers, leading to further damage. To reduce chunking, avoid rough or debris-covered floors (and ensure your warehouse floor is clean) and ensure loads stay within the forklift’s capacity.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8163-a65c-c76539ec0817","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"Tears and Cracks","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tears and Cracks","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81dd-9933-c1f86b329ef0","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ee-a9f7-f6df30c9287a","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e83de3cec582"},"created_time":"2026-05-03T21:56:00.000Z","last_edited_time":"2026-05-03T21:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Tire Bond Failure","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire Bond Failure","href":null},{"type":"text","text":{"content":": Separation between the rubber and casing can result from excessive heat, aging, or improper repairs. Look for bubbling or gaps along the tread during inspections.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":": Separation between the rubber and casing can result from excessive heat, aging, or improper repairs. Look for bubbling or gaps along the tread during inspections.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8177-be38-fcaf37c9c62b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8177-a124-e