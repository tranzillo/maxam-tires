"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/12/Replace-solid-otr-tires-1.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8199-9add-c3a3e00aad16","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\n\nIn this image, you can see the rubber piece is starting to peel off.\n\nThere are ways to help prolong the life of your solid OTR wheel loader tires:\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"\n\nIn this image, you can see the rubber piece is starting to peel off.\n\nThere are ways to help prolong the life of your solid OTR wheel loader tires:\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ed-8cc9-e9c52afe0b3b","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Inspect all four tires and ensure the front and rear tires are no more than two inches of difference in overall diameter, if so, consider rotating the tires","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Inspect all four tires and ensure the front and rear tires are no more than two inches of difference in overall diameter, if so, consider rotating the tires","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8150-96fe-eafc2cf80382","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Remove any objects and debris stuck inside the tires and the treads","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Remove any objects and debris stuck inside the tires and the treads","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e0-8b94-ff46a3176f2f","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nMAXAM’s traction solid OTR MS708 is designed from the inside out for the tire to increase its footprint as it wears, transitioning through four unique tread patterns, ending in standard L5. We have created this design to maximize footprint and tire life in your traction solid OTR wheel loader tires.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"\nMAXAM’s traction solid OTR MS708 is designed from the inside out for the tire to increase its footprint as it wears, transitioning through four unique tread patterns, ending in standard L5. We have created this design to maximize footprint and tire life in your traction solid OTR wheel loader tires.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8166-b3f0-e197a4c52f65","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/12/Solid-otr-life-cycle.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8174-8392-df963db30523","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"\nIf you’re unsure whether or not your solid OTR tire needs to be replaced, contact your local MAXAM rep and we’ll assist you with your inquiries.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"\nIf you’re unsure whether or not your solid OTR tire needs to be replaced, contact your local MAXAM rep and we’ll assist you with your inquiries.","href":null}],"icon":null,"color":"default"},"archived":false}]