[{"object":"block","id":"35534d6d-7cea-8171-ad61-c81a7acfa9dd","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"While solid OTR tires require zero maintenance and are built to last much longer than foam filled pneumatics, they still have a certain life span. Although these tires don’t require the maintenance pneumatic off-the-road tires require, MAXAM recommends operations inspect their solid OTR tires every now and then.\n\nBelow are some indicators that your solid OTR tire need to be replaced:\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"While solid OTR tires require zero maintenance and are built to last much longer than foam filled pneumatics, they still have a certain life span. Although these tires don’t require the maintenance pneumatic off-the-road tires require, MAXAM recommends operations inspect their solid OTR tires every now and then.\n\nBelow are some indicators that your solid OTR tire need to be replaced:\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81b3-ba8a-cd601eae399d","parent":{"type":"page_id","page_id":"35534d6d-7cea-81fa-b56c-dab981e5a086"},"created_time":"2026-05-03T21:57:00.000Z","last_edited_time":"2026-05-03T21:57:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"conten