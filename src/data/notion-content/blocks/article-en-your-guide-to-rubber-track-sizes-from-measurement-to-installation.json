_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Example: A 400 x 72.5 x 66 track is 400mm wide, has a 72.5mm pitch between lugs, and 66 links in total.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Example: A 400 x 72.5 x 66 track is 400mm wide, has a 72.5mm pitch between lugs, and 66 links in total.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35634d6d-7cea-81ff-ad33-c1368cfad474","parent":{"type":"page_id","page_id":"35634d6d-7cea-813c-9539-fee94f7cc0ab"},"created_time":"2026-05-04T12:01:00.000Z","last_edited_time":"2026-05-04T12:01:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"content":"Track Width: The first number. A wider track increases flotation; a narrower one improves ground pressure for harder surfaces.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Track Width: The first number. A wider track increases flotation; a narrower one improves ground pressure for harder surfaces.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35634d6d-7cea-817c-9d04-d26488af6b40","parent":{"type":"page_id","page_id":"35634d6d-7cea-813c-9539-fee94f7cc0ab"},"created_time":"2026-05-04T12:01:00.000Z","last_edited_time":"2026-05-04T12:01:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"numbered_list_item","numbered_list_item":{"rich_text":[{"type":"text","text":{"c