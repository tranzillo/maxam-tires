[{"object":"block","id":"35634d6d-7cea-8162-b035-f4e4312e2d9a","parent":{"type":"page_id","page_id":"35634d6d-7cea-813c-9539-fee94f7cc0ab"},"created_time":"2026-05-04T12:01:00.000Z","last_edited_time":"2026-05-04T12:01:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Selecting the correct rubber track size is one of the most critical decisions for maintaining your compact track loaders, skid steer, and mini excavator.\n\nWith an array of types of rubber tracks and part numbers on the market, a mistake in track width or pitch leads directly to downtime and damaged undercarriage components. This guide decodes the industry standard sizing system and provides a step-by-step process to ensure perfect compatibility and maximum durability for your construction equipment.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Selecting the correct rubber track size is one of the most critical decisions for maintaining your compact track loaders, skid steer, and mini excavator.\n\nWith an array of types of rubber tracks and part numbers on the market, a mistake in track width or pitch leads directly to downtime and damaged undercarriage components. This guide decodes the industry standard sizing system and provides a step-by-step process to ensure perfect compatibility and maximum durability for your construction equipment.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35634d6d-7cea-81a6-814b-e97aea85309e","parent":{"type":"page_id","page_id":"35634d6d-7cea-813c-9539-fee94f7cc0ab"},"created_time":"2026-05-04T12:01:00.000Z","last_edited_time":"2026-05-04T12:01:00.000Z","created_by":{"object":"user","id":"35534d6d-