[{"object":"block","id":"35534d6d-7cea-811c-9906-fe64b61ed2eb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Depending on the equipment design or need, rims are made in various widths to allow the tire to drive or steer under load.\n\nThe key to tire performance is the capability of the air in the tire to suspend the load and allow the tire to press the tire footprint into the surface without slipping or damaging crops.\n\nAs OEMs continue to improve productivity via the evolution of larger machinery, tire sizes changed to meet the demand for more load, speed, and traction. To see how, farmers and growers can use aspect ratio to determine the optimal width for their tires.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Depending on the equipment design or need, rims are made in various widths to allow the tire to drive or steer under load.\n\nThe key to tire performance is the capability of the air in the tire to suspend the load and allow the tire to press the tire footprint into the surface without slipping or damaging crops.\n\nAs OEMs continue to improve productivity via the evolution of larger machinery, tire sizes changed to meet the demand for more load, speed, and traction. To see how, farmers and growers can use aspect ratio to determine the optimal width for their tires.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-816b-985b-e3654e50065e","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"What is Aspect Ratio?","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"What is Aspect Ratio?","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8157-bea9-d8005a56cac8","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tires must conform to international standards when it comes to sizing. Depending on their construction, tires are grouped by aspect ratio or families of sizes.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tires must conform to international standards when it comes to sizing. Depending on their construction, tires are grouped by aspect ratio or families of sizes.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-818a-ab87-ff70b45d8079","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2021/04/Aspect-Ratio-1-800x419.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8158-8df6-eb81dcaf7045","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The width and diameter of a tire will determine the size of the sidewall on the wheel or rim. The size of the tire determines the size of the air chamber.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The width and diameter of a tire will determine the size of the sidewall on the wheel or rim. The size of the tire determines the size of the air chamber.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81cd-b319-cc75ed5b97d5","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"What Aspect Ratio Means for Tire Performance","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"What Aspect Ratio Means for Tire Performance","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81a6-b6f3-dd7ef4da5bc1","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"As tires grow in aspect ratio or width, their tire radius and diameter remain almost the same.\n\nHowever, the larger tire delivers a wider footprint (Gross Flat Plate), improving flotation and increasing traction. Due to their size, these tires have a larger air chamber that provides increased load carrying capacity.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"As tires grow in aspect ratio or width, their tire radius and diameter remain almost the same.\n\nHowever, the larger tire delivers a wider footprint (Gross Flat Plate), improving flotation and increasing traction. Due to their size, these tires have a larger air chamber that provides increased load carrying capacity.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81b4-aeba-ff436520ef51","parent":{"type":"page_id","page_id":"35534d6d-7cea-8147-875e-fa9a08aabdce"},"created_time":"2026-05-03T22:09:00.000Z","last_edited_time":"2026-05-03T22:09:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"YOU MIGHT LIKE: [","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"under