[{"object":"block","id":"35534d6d-7cea-81d2-a26a-e97456d42dfa","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-8d01-f655feb98daf"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"In the construction industry, time means money. Operations need to make the most of every moment to maximize profits. Outfitting equipment with application-specific construction/OTR tires can cut costs and increase productivity levels, but how do you know you are picking the correct tire for your application? Below are three crucial questions to consider when searching for your next construction tire.\n\n","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"In the construction industry, time means money. Operations need to make the most of every moment to maximize profits. Outfitting equipment with application-specific construction/OTR tires can cut costs and increase productivity levels, but how do you know you are picking the correct tire for your application? Below are three crucial questions to consider when searching for your next construction tire.\n\n","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8161-859a-c0ed752c7b4d","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-8d01-f655feb98daf"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"What Type of Tire Do I Need?","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"What Type of Tire Do I Need?","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c5-bbea-fbf769505821","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-8d01-f655feb98daf"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Understanding TRA Types\n\nEach construction tire is classified by TRA Type to simplify the selection process. TRA codes refer to the tire’s classification and tread depth. For example, a TRA of L3 means the tire is a loader-classified tire with a level 3 tread depth. Keep in mind, the tread depth of the tire increases as the TRA code level increases, making it crucial to understand your tires’ TRA code to ensure proper performance.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Understanding TRA Types\n\nEach construction tire is classified by TRA Type to simplify the selection process. TRA codes refer to the tire’s classification and tread depth. For example, a TRA of L3 means the tire is a loader-classified tire with a level 3 tread depth. Keep in mind, the tread depth of the tire increases as the TRA code level increases, making it crucial to understand your tires’ TRA code to ensure proper performance.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-819b-93e5-fee44a65064b","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-8d01-