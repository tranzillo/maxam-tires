[{"object":"block","id":"35534d6d-7cea-81e8-9644-d5702e47f341","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/forklift-safety-tips_1024x205.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8109-8eae-e954479658e7","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/forklift-safety-tips_800x400.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8172-a6c9-e3b2e82391ff","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM TIRE advises forklift tire safety tips for National Forklift Safety Day","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM TIRE advises forklift tire safety tips for National Forklift Safety Day","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81a9-9d97-d053353ffb78","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"With increased demands, it’s important to ensure maximum efficiency. Forklift tires play a major role in ensuring operator’s safety & maximizing productivity. It’s important to know how to tell when it’s time to change your tires. Below are some tire safety & maintenance tips to identify when to change your tires.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"With increased demands, it’s important to ensure maximum efficiency. Forklift tires play a major role in ensuring operator’s safety & maximizing productivity. It’s important to know how to tell when it’s time to change your tires. Below are some tire safety & maintenance tips to identify when to change your tires.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-810c-b4ef-f0c04c4c671b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Here are the four signs to determine when to replace your tire:","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Here are the four signs to determine when to replace your tire:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-811d-9220-e15e9d3b334d","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"1. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"1. ","href":null},{"type":"text","text":{"content":"Tire wear and balding","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire wear and balding","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c1-ace3-e0b03f89831e","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Both pneumatic and solid tires will become less effective as their tread wears down. For pneumatic tires, if the tread is nearly gone or you notice bald spots, it’s time to replace the tires. For solid cushion tires,  once the tire reaches 1/3 of the nominal section height, it’s time for new tires. For resilient tires, if the tire reaches the 60J line, it's time to replace the tires. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Both pneumatic and solid tires will become less effective as their tread wears down. For pneumatic tires, if the tread is nearly gone or you notice bald spots, it’s time to replace the tires. For solid cushion tires,  once the tire reaches 1/3 of the nominal section height, it’s time for new tires. For resilient tires, if the tire reaches the 60J line, it's time to replace the tires. ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ae-8852-c6cf2bc746f9","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"2. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"2. ","href":null},{"type":"text","text":{"content":"Tire chunking","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tire chunking","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8112-875f-cc56660ac7be","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"If pieces or chunks of your forklift tires are falling off, that’s a good sign you need to replace them.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"If pieces or chunks of your forklift tires are falling off, that’s a good sign you need to replace them.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8154-a288-f6c41c539481","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"3. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"3. ","href":null},{"type":"text","text":{"content":"Tearing on tires","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tearing on tires","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8112-af63-e2486bc0f654","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Similar to chunking, if your tires are tearing off in spots, they need to be replaced.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Similar to chunking, if your tires are tearing off in spots, they need to be replaced.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81d3-af39-e7a156e0b701","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"4. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"4. ","href":null},{"type":"text","text":{"content":"Flat spots","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Flat spots","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-817d-9784-c98235586085","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Similar to chunking, if your tires are tearing off in spots, they need to be replaced.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Similar to chunking, if your tires are tearing off in spots, they need to be replaced.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ec-b547-e9e52eca139a","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/did-you-know_forklift-safety-image.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8172-a654-d2ef46ba7eb9","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Other than checking for signs of potential tire replacement, other key inspection points include:","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Other than checking for signs of potential tire replacement, other key inspection points include:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8132-939d-d09f5389729a","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":" 1. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":" 1. ","href":null},{"type":"text","text":{"content":"Uneven tire wear","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Uneven tire wear","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81dd-9ea8-d57c04412629","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Check if there are any uneven signs of wear on each tire. There could be an underlying issue that is causing premature wear due to the road condition or the application.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Check if there are any uneven signs of wear on each tire. There could be an underlying issue that is causing premature wear due to the road condition or the application.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8131-82b1-cdb982925d43","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"2. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"2. ","href":null},{"type":"text","text":{"content":"Air pressure","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Air pressure","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81f9-98ff-ecbbcb117a5c","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Tires that aren’t filled to the proper pressure will wear out more quickly than tires filled to the correct PSI. Overinflation can also result in excessive tire wear.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Tires that aren’t filled to the proper pressure will wear out more quickly than tires filled to the correct PSI. Overinflation can also result in excessive tire wear.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8148-ae5a-e28e62657217","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"3. ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"3. ","href":null},{"type":"text","text":{"content":"Load","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Load","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8108-a67a-def865338caa","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"While you don’t want to overload the lift truck, running the forklift without a load also shortens your tire life. Without a load on the forks, the counterweight presses down on the steer tires which causes them to wear more quickly.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"While you don’t want to overload the lift truck, running the forklift without a load also shortens your tire life. Without a load on the forks, the counterweight presses down on the steer tires which causes them to wear more quickly.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8189-bcda-ccc9f7c0d620","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/what-else-to-expect-image.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-81eb-808d-e21f94eb44bb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Forklift tires play a key role not only in the efficiency of an operation but also the safety. After a tire has worn 40%, the forklift and the driver will absorb over 84% of the shock if it’s being run over a rough surface. The transmission has to work much harder to turn the tires the same amount of rotation, which can result in a breakdown. Therefore, maintaining tires is an inexpensive way to keep your forklift and operator in good condition.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Forklift tires play a key role not only in the efficiency of an operation but also the safety. After a tire has worn 40%, the forklift and the driver will absorb over 84% of the shock if it’s being run over a rough surface. The transmission has to work much harder to turn the tires the same amount of rotation, which can result in a breakdown. Therefore, maintaining tires is an inexpensive way to keep your forklift and operator in good condition.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8150-8c13-daba85bc9494","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Nat-Forklift-Safety-Day-Info-scaled.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8144-93d6-f6d1e366ce34","parent":{"type":"page_id","page_id":"35534d6d-7cea-8119-8dab-c66492636280"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information, contact your local representative or visit us at maxamtire.com.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For additional information, contact your local representative or visit us at maxamtire.com.","href":null}],"icon":null,"color":"default"},"archived":false}]