[{"object":"block","id":"35534d6d-7cea-81c4-8591-c34c54026615","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MS910R DELIVERING VERSATILE SOLUTIONS TO THE INDUSTRY","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MS910R DELIVERING VERSATILE SOLUTIONS TO THE INDUSTRY","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81b3-97d3-f9fa59385a75","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"MAXAM Debuts the Complete MS910R Series for Compact Equipment","link":null},"annotations":{"bold":true,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM Debuts the Complete MS910R Series for Compact Equipment","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-817b-b5f1-c03013b05943","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, February 23rd, 2021] MAXAM is excited to debut the full line of the MS910R multipurpose radial tire. The versatile MS910R is designed to operate in multiple applications, including agriculture, construction, and industrial vehicles. Engineered to provide the industry with a versatile solution, the MS910R delivers the performance customers seek in MAXAM’s products.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, February 23rd, 2021] MAXAM is excited to debut the full line of the MS910R multipurpose radial tire. The versatile MS910R is designed to operate in multiple applications, including agriculture, construction, and industrial vehicles. Engineered to provide the industry with a versatile solution, the MS910R delivers the performance customers seek in MAXAM’s products.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8153-ae3f-f4481bef727f","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Developed with the end-user in mind, the MS910R boasts an all-steel radial construction to provide maximum durability, stability, and improved traction in every application. Designed to operate on a wide range of equipment from telehandlers to compact wheel loaders, the MS910R is engineered to minimize vibration providing a comfortable ride without compromising traction.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Developed with the end-user in mind, the MS910R boasts an all-steel radial construction to provide maximum durability, stability, and improved traction in every application. Designed to operate on a wide range of equipment from telehandlers to compact wheel loaders, the MS910R is engineered to minimize vibration providing a comfortable ride without compromising traction.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81e6-a75e-d8dd93dccd43","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MS910R exhibits a versatile lug pattern adapted to meet the demands of every vehicle it serves. Featuring a unique self-cleaning design with cutting-edge mud breakers, the MS910R prevents terrain buildup in the lugs ensuring maximum grip and performance.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MS910R exhibits a versatile lug pattern adapted to meet the demands of every vehicle it serves. Featuring a unique self-cleaning design with cutting-edge mud breakers, the MS910R prevents terrain buildup in the lugs ensuring maximum grip and performance.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-819d-825a-cbc3c6b06490","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MS910R delivers performance, durability, and adaptability to sites globally. The MS910R is available in the below sizes for three different applications: multipurpose (MPT), industrial (IN), and construction (EM). ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MS910R delivers performance, durability, and adaptability to sites globally. The MS910R is available in the below sizes for three different applications: multipurpose (MPT), industrial (IN), and construction (EM). ","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81d6-8f90-da054d179e23","parent":{"type":"page_id","page_id":"35534d6d-7cea-815f-b4f7-d75f9ccef5e4"},"created_time":"2026-05-03T22:10:00.000Z","last_edited_time":"2026-05-03T22:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information, contact your local representative or visit us at ","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For additional information, contact your local representative or visit us at ","href":null},{"type":"text","text":{"content":"maxamtire.com","link":{"url":"https://maxamtirena.com/en-us/"}},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_t