[{"object":"block","id":"35534d6d-7cea-815d-991b-e00c973f1cfe","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"THE NEW MAXAM MS503","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"THE NEW MAXAM MS503","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8184-971a-e2b4c394b59a","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[{"type":"text","text":{"content":"The MAXAM Solution for Severe Applications","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM Solution for Severe Applications","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8192-a9fe-fec2d678fcba","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[Danvers, Massachusetts, June 28] ","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[Danvers, Massachusetts, June 28] ","href":null},{"type":"text","text":{"content":"MAXAM is pleased to announce the expansion of the L5 extra deep tire program with the MS503 L5T pattern. MAXAM has developed the new MS503 radial OTR program to provide the industry with the best solution for severe applications requiring high traction.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM is pleased to announce the expansion of the L5 extra deep tire program with the MS503 L5T pattern. MAXAM has developed the new MS503 radial OTR program to provide the industry with the best solution for severe applications requiring high traction.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81fa-9cee-c3ccdd838ee9","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Specifically designed to maximize service life in harsh conditions, the MS503 was developed with a reinforced shoulder, sidewall and bead construction to produce the most durable tire possible. Furthermore, the ultra-cut resistant tread compound and all steel radial tire construction maximizes protection from physical damage and extends the tire life.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Specifically designed to maximize service life in harsh conditions, the MS503 was developed with a reinforced shoulder, sidewall and bead construction to produce the most durable tire possible. Furthermore, the ultra-cut resistant tread compound and all steel radial tire construction maximizes protection from physical damage and extends the tire life.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8174-9c6e-fbf4bb021c83","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The extra-deep, non-directional L5T traction pattern allows the MS503 to provide lasting performance and optimized control in all conditions. Incorporating an open lug pattern with variable void geometry, the MS503 has excellent self-cleaning properties to retain traction in all conditions.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The extra-deep, non-directional L5T traction pattern allows the MS503 to provide lasting performance and optimized control in all conditions. Incorporating an open lug pattern with variable void geometry, the MS503 has excellent self-cleaning properties to retain traction in all conditions.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81a0-a84b-c72d0f199f27","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The staggered tread provides continuous ground contact while providing improved ride comfort for operators.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The staggered tread provides continuous ground contact while providing improved ride comfort for operators.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8105-b7f3-c68c7f7edb1b","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MAXAM MS503 is currently available in six sizes as displayed in the chart below.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MAXAM MS503 is currently available in six sizes as displayed in the chart below.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-819a-bc7e-e78b7ed6c285","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"For additional information contact your local representative or visit us at maxamtire.com","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"For additional information contact your local representative or visit us at maxamtire.com","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-812b-871b-d6ac9a991272","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[table content omitted]","link":null},"annotations":{"bold":false,"italic":true,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[table content omitted]","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81f4-bcae-edb0bd4c7c1b","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtirena.com/wp-content/uploads/2019/07/MS503_preview.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8137-8cb3-ebe7045c51e3","parent":{"type":"page_id","page_id":"35534d6d-7cea-816f-a76c-f03b32cc925f"},"created_time":"2026-05-03T22:11:00.000Z","last_edited_time":"2026-05-03T22:11:00.000Z","created_by":{"object":"us