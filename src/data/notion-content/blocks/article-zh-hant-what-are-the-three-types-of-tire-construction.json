[{"object":"block","id":"35534d6d-7cea-81f3-86b7-fc047fb13c41","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"What are the three types of tire construction?","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"What are the three types of tire construction?","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81ce-8fa7-c7c4cc71a59d","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Radial, bias, and solid are the three different types of tire constructions. Each construction has its strengths and it is important to pick the correct tire for your application.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Radial, bias, and solid are the three different types of tire constructions. Each construction has its strengths and it is important to pick the correct tire for your application.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8100-a29e-ea681316b95f","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"divider","divider":{},"archived":false},{"object":"block","id":"35534d6d-7cea-8147-aad2-caa7adb0cee6","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Bias tires","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Bias tires","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c1-8e13-da4d32ceec19","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Bias tires are made of layers of nylon plies in a crisscross pattern, placed at angles of 30-40 degrees. The plies are laid at opposing angles forming an x-pattern to which the tire tread is applied too. The main advantage of a bias ply tire is that they deliver a smooth ride on rough surfaces enhancing operator comfort and they have the ability to withstand high loads. Although, bias tires can be more sensitive to overheating and can lead to increased wear rates and fuel consumption rates.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Bias tires are made of layers of nylon plies in a crisscross pattern, placed at angles of 30-40 degrees. The plies are laid at opposing angles forming an x-pattern to which the tire tread is applied too. The main advantage of a bias ply tire is that they deliver a smooth ride on rough surfaces enhancing operator comfort and they have the ability to withstand high loads. Although, bias tires can be more sensitive to overheating and can lead to increased wear rates and fuel consumption rates.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81d0-b0c8-ffc5029815e6","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/Maxam-Tire-MS901-001.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-812f-a77a-e02c3c2f1cac","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/230306_Maxam-Tire_MS906R_FINAL-scaled-1.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-81d6-bcba-db1607886366","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Radial Tires ","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Radial Tires ","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8139-ab25-d81444667878","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Radial tires are manufactured with the tire’s body plies running radially, perpendicular to the circumference of the tire allowing the tire to flex more and permitting a larger footprint. MAXAM’s radial tires achieve a longer and more even tread wear, along with delivering a higher resistance to cuts and punctures decreasing repairs costs on job sites. Disadvantages include a harder ride at low speeds on rough roads, a more rigid sidewall, and a lower grip at slow speeds.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Radial tires are manufactured with the tire’s body plies running radially, perpendicular to the circumference of the tire allowing the tire to flex more and permitting a larger footprint. MAXAM’s radial tires achieve a longer and more even tread wear, along with delivering a higher resistance to cuts and punctures decreasing repairs costs on job sites. Disadvantages include a harder ride at low speeds on rough roads, a more rigid sidewall, and a lower grip at slow speeds.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-815e-9b64-d318e25e81f7","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Solid Tires","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Solid Tires","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81a7-8312-f84dcbadd282","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Solid Tires are best for tough applications that have a high risk of impact and damage. They are extremely stable, puncture resistant, and maintenance-free as they are non-pneumatic, meaning that they are not filled with air. Solid tires eliminate the threat of blowouts and can handle significantly higher weight per load than pneumatic tires. The disadvantages of solid tires are that they cannot operate at high speeds and the upfront cost is higher.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Solid Tires are best for tough applications that have a high risk of impact and damage. They are extremely stable, puncture resistant, and maintenance-free as they are non-pneumatic, meaning that they are not filled with air. Solid tires eliminate the threat of blowouts and can handle significantly higher weight per load than pneumatic tires. The disadvantages of solid tires are that they cannot operate at high speeds and the upfront cost is higher.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8169-935e-f025dc3c5de2","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/MS709-FP.png"}},"archived":false},{"object":"block","id":"35534d6d-7cea-811f-82a4-fb680147c9fd","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Not sure what series would be the right tire for your operation? Reach out to our team below:","link":null},"annotations":{"bold":true,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Not sure what series would be the right tire for your operation? Reach out to our team below:","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8183-95e2-dbd7402927eb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8104-a4af-ebbf417695c8"},"created_time":"2026-05-03T22:07:00.000Z","last_edited_time":"2026-05-03T22:07:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"[hubspot portal=\"22229044\" id=\"6811e594-fcca-41d1-a2fa-9018cf75c2c1\" type=\"form\"]","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"[hubspot portal=\"22229044\" id=\"6811e594-fcca-41d1-a2fa-9018cf75c2c1\" type=\"form\"]","href":null}],"icon":null,"color":"default"},"archived":false}]