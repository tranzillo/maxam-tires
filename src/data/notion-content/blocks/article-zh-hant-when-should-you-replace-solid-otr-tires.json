l},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"There are ways to help prolong the life of your solid OTR wheel loader tires:","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-815c-b052-d338cf0a03eb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Inspect all four tires and ensure the front and rear tires are no more than two inches of difference in overall diameter, if so, consider rotating the tires","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Inspect all four tires and ensure the front and rear tires are no more than two inches of difference in overall diameter, if so, consider rotating the tires","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8149-95e6-edc25c22173f","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Remove any objects and debris stuck inside the tires and the treads","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Remove any objects and debris stuck inside the tires and the treads","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-811d-bf6e-d11e19e49b23","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MAXAM’s traction solid OTR MS708 is designed from the inside out for the tire to increase its footprint as it wears, transitioning through four unique tread patterns, ending in standard L5. We have created this design to maximize footprint and tire life in your traction solid OTR wheel loader tires.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MAXAM’s traction solid OTR MS708 is designed from the inside out for the tire to increase its footprint as it wears, transitioning through four unique tread patterns, ending in standard L5. We have created this design to maximize footprint and tire life in your traction solid OTR wheel loader tires.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8163-8edf-fcdb21a288b7","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"image","image":{"caption":[],"type":"external","external":{"url":"https://maxamtire.com/wp-content/uploads/2023/10/708-life-cycle.jpg"}},"archived":false},{"object":"block","id":"35534d6d-7cea-8180-ac5a-f21a6ab5bc32","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"If you’re unsure whether or not your solid OTR tire needs to be replaced, contact your local MAXAM rep and we’ll assist you with your inquiries.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"If you’re unsure whether or not your solid OTR tire needs to be replaced, contact your local MAXAM rep and we’ll assist you with your inquiries.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8100-86b7-db11dd0bb5bb","parent":{"type":"page_id","page_id":"35534d6d-7cea-8162-9846-d7ce1f0406b0"},"created_time":"2026-05-03T22:08:00.000Z","last_edited_time":"2026-05-03T22:08:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_3","heading_3":{"rich_text":[],"is_toggleable":false,"color":"default"},"archived":false}]