[{"object":"block","id":"35534d6d-7cea-8116-ad4f-d8b59b013234","parent":{"type":"page_id","page_id":"35534d6d-7cea-813f-8cdb-e1173abb6ce9"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"إن إطار MX200L هو إطار توجيه متميز لعمليات النقل لمسافات طويلة من MAXAM يتميز بتقنية مُرَكب EcoPoint 3 التي نتمتع بحقوق ملكيتها. وتعمل تقنية EcoPoint 3 على تحسين المسافات التي يمكن قطعها والاقتصاد في استهلاك الوقود والجر على الطرق الرطبة دون أدنى تأثير على الأداء، مما يضع معيارًا جديدًا لاستخدام الإطارات في النقل لمسافات طويلة. يوفر هذا النوع المتميز من الإطارات تحكمًا وراحة لا مثيل لهما وذلك بفضل تصميمه بحزوز منفصل وخمسة أضلاع عريضة. وُجهزَّ الإطار MX200L أيضًا بشقوق دقيقة لتقليل التآكل غير المنتظم إلى أدنى حد ممكن وتعزيز الجر الجانبي في ظروف الطرق الرطبة، مما يوفر الموثوقية والسلامة في كل رحلة. إطار MX200L هو الإطار الأنسب لاستخدامات النقل لمسافات طويلة على الطرق السريعة. متوفر فقط في أمريكا الشمالية","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"إن إطار MX200L هو إطار توجيه متميز لعمليات النقل لمسافات طويلة من MAXAM يتميز بتقنية مُرَكب EcoPoint 3 التي نتمتع بحقوق ملكيتها. وتعمل تقنية EcoPoint 3 على تحسين المسافات التي يمكن قطعها والاقتصاد في استهلاك الوقود والجر على الطرق الرطبة دون أدنى تأثير على الأداء، مما يضع معيارًا جديدًا لاستخدام الإطارات في النقل لمسافات طويلة. يوفر هذا النوع المتميز من الإطارات تحكمًا وراحة لا مثيل لهما وذلك بفضل تصميمه بحزوز منفصل وخمسة أضلاع عريضة. وُجهزَّ الإطار MX200L أيضًا بشقوق دقيقة لتقليل التآكل غير المنتظم إلى أدنى حد ممكن وتعزيز الجر الجانبي في ظروف الطرق الرطبة، مما يوفر الموثوقية والسلامة في كل رحلة. إطار MX200L هو الإطار الأنسب لاستخدامات النقل لمسافات طويلة على الطرق السريعة. متوفر فقط في أمريكا الشمالية","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81fe-8a71-ccde6c95c232","parent":{"type":"page_id","page_id":"35534d6d-7cea-813f-8cdb-e1173abb6ce9"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"الميزات","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"الميزات","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-812b-bc4f-c6b89d7304d1","parent":{"type":"page_id","page_id":"35534d6d-7cea-813f-8cdb-e1173abb6ce9"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"تعمل الشقوق الدقيقة على تحسين الجر في الظروف الرطبة وتقليل التآكل غير المنتظم إلى أدنى حد ممكن.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"تعمل الشقوق الدقيقة على تحسين الجر في الظروف الرطبة وتقليل التآكل غير المنتظم إلى أدنى حد ممكن.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8171-9ef3-fa29f96cf9f6","parent":{"type":"page_id","page_id":"35534d6d-7cea-813f-8cdb-e1173abb6ce9"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_