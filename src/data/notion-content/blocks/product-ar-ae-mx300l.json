[{"object":"block","id":"35534d6d-7cea-81e2-af90-e1e8c93073c9","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e4-85ca-c42c061ce5df"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"إطار MX300L هو إطار متميز لعجلة الإدارة في عمليات النقل لمسافات طويلة من MAXAM، وهو مُصنَّع باستخدام تقنية مُركَّب EcoPoint 3 . وتعمل تقنية مُركَب EcoPoint 3 على تحسين المسافات التي يمكن قطعها والاقتصاد في استهلاك الوقود والجر على الطرق الرطبة دون أي تأثير غير مرغوب. يتميز إطار MX300L بعمق مداس كبير يبلغ 30/32 بوصة وعرض مداس 240 مم لضمان تحقيق مستوى استثنائي في المسافة التي يمكن قطعها والتآكل المتساوي، مما يوفر أساسًا متينًا لتجديد المداس. ويضمن تصميم الجزء العريض من الإطار (الكتف) المغلق توزيعًا متساويًا للوزن وعزم الدوران لتحقيق مستويين استثنائيين من الثبات والتحكم. الإطار MX300L هو الإطار الأنسب لاستخدامات شاحنات النقل لمسافات طويلة على الطرق السريعة والاستخدامات الإقليمية. متوفر فقط في أمريكا الشمالية","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"إطار MX300L هو إطار متميز لعجلة الإدارة في عمليات النقل لمسافات طويلة من MAXAM، وهو مُصنَّع باستخدام تقنية مُركَّب EcoPoint 3 . وتعمل تقنية مُركَب EcoPoint 3 على تحسين المسافات التي يمكن قطعها والاقتصاد في استهلاك الوقود والجر على الطرق الرطبة دون أي تأثير غير مرغوب. يتميز إطار MX300L بعمق مداس كبير يبلغ 30/32 بوصة وعرض مداس 240 مم لضمان تحقيق مستوى استثنائي في المسافة التي يمكن قطعها والتآكل المتساوي، مما يوفر أساسًا متينًا لتجديد المداس. ويضمن تصميم الجزء العريض من الإطار (الكتف) المغلق توزيعًا متساويًا للوزن وعزم الدوران لتحقيق مستويين استثنائيين من الثبات والتحكم. الإطار MX300L هو الإطار الأنسب لاستخدامات شاحنات النقل لمسافات طويلة على الطرق السريعة والاستخدامات الإقليمية. متوفر فقط في أمريكا الشمالية","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81b8-9990-dc0a02ff0ed4","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e4-85ca-c42c061ce5df"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"الميزات","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"الميزات","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-815b-80e0-c02ad7a874f0","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e4-85ca-c42c061ce5df"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"توفر الأجزاء العريضة من الإطارات الصلبة (الأكتاف) مستويين ممتازين من الثبات والمناولة وزيادة المسافة التي يمكن قطعها.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"توفر الأجزاء العريضة من الإطارات الصلبة (الأكتاف) مستويين ممتازين من الثبات والمناولة وزيادة المسافة التي يمكن قطعها.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8135-89b3-ec694c18ec27","parent":{"type":"page_id","page_id":"35534d6d-7cea-81e4-85ca-c42c061ce5df"},"created_time":"2026-05-03T20:56:00.000Z","last