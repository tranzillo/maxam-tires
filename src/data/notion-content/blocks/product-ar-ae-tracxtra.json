[{"object":"block","id":"35534d6d-7cea-818f-8119-c7e375f4e0f4","parent":{"type":"page_id","page_id":"35534d6d-7cea-81ef-b40f-fe8e874186e6"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"صُممت آلة MS971R لتلبية المتطلبات المتنوعة لمعدات المزارع والمقاولات متعددة الوظائف في عصرنا الحالي. صُممت لتتحمل مجموعة واسعة من ظروف الأسطح الصلبة أو التربة المتعددة، وتتميز بهيكل غلاف متين وتقنية أحزمة فولاذية، مما يضمن توزيعًا متساويًا لضغط الأرض، ومقاومة دوران منخفضة، وقوة جر استثنائية. يُمكّن مزيج MS971R الفريد من المتانة والراحة من تحقيق أقصى أداء في الميدان، وعلى الطرق السريعة، وفي بيئات العمل الصعبة، سواءً على الطرق المعبدة أو الوعرة.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"صُممت آلة MS971R لتلبية المتطلبات المتنوعة لمعدات المزارع والمقاولات متعددة الوظائف في عصرنا الحالي. صُممت لتتحمل مجموعة واسعة من ظروف الأسطح الصلبة أو التربة المتعددة، وتتميز بهيكل غلاف متين وتقنية أحزمة فولاذية، مما يضمن توزيعًا متساويًا لضغط الأرض، ومقاومة دوران منخفضة، وقوة جر استثنائية. يُمكّن مزيج MS971R الفريد من المتانة والراحة من تحقيق أقصى أداء في الميدان، وعلى الطرق السريعة، وفي بيئات العمل الصعبة، سواءً على الطرق المعبدة أو الوعرة.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8182-980d-e2c49221b797","parent":{"type":"page_id","page_id":"35534d6d-7cea-81ef-b40f-fe8e874186e6"},"created_time":"2026-05-03T20:56:00.000Z","last_edited_time":"2026-05-03T20:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":fa