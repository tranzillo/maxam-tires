[{"object":"block","id":"38034d6d-7cea-81dc-be54-c6aa71f6a32b","parent":{"type":"page_id","page_id":"38034d6d-7cea-812f-8b41-ee543f8c1f91"},"created_time":"2026-06-15T13:55:00.000Z","last_edited_time":"2026-06-15T13:55:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX220V ist ein für alle Positionen geeigneter Radialreifen für LKW, der für raue Umgebungen und unterschiedliche Einsatzbereiche konstruiert wurde. Durch den in die Profilhohlräume eingearbeiteten Steinschutz wird das Eindringen von Steinen in MX220V-Reifen verhindert, was zu einer langanhaltenden Leistung beiträgt. Die solide Schulterkonstruktion widersteht seitlichem Scheuern unter schwierigen Einsatzbedingungen. Gleichzeitig sorgt die schnitt- und splitterfeste Verbundmischung für hervorragenden Profilschutz und eine hohe Laufleistung während des Betriebs. MX220V eignet sich in unterschiedlichen Einsatzbereichen optimal für alle Positionen und verspricht Haltbarkeit und Zuverlässigkeit auf jeder Fahrt. Nur in Nordamerika erhältlich","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX220V ist ein für alle Positionen geeigneter Radialreifen für LKW, der für raue Umgebungen und unterschiedliche Einsatzbereiche konstruiert wurde. Durch den in die Profilhohlräume eingearbeiteten Steinschutz wird das Eindringen von Steinen in MX220V-Reifen verhindert, was zu einer langanhaltenden Leistung beiträgt. Die solide Schulterkonstruktion widersteht seitlichem Scheuern unter schwierigen Einsatzbedingungen. Gleichzeitig sorgt die schnitt- und splitterfeste Verbundmischung für hervorragenden Profilschutz und eine hohe Laufleistung während des Betriebs. MX220V eignet sich in unterschiedlichen Einsatzbereichen optimal für alle Positionen und verspricht Haltbarkeit und Zuverlässigkeit auf jeder Fahrt. Nur in Nordamerika erhältlich","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8124-b327-c1356878046b","parent":{"type":"page_id","page_id":"38034d6d-7cea-812f-8b41-ee543f8c1f91"},"created_time":"2026-06-15T13:55:00.000Z","last_edited_time":"2026-06-15T13:55:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81ea-a0d3-edbda8d08074","parent":{"type":"page_id","page_id":"38034d6d-7cea-812f-8b41-ee543f8c1f91"},"created_time":"2026-06-15T13:55:00.000Z","last_edited_time":"2026-06-15T13:55:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Der in die Profilhohlräume eingearbeitete Steinschutz verhindert das Eindringen von Steinen und verlängert so die Lebensdauer der Karkasse.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Der in die Profilhohlräume eingearbeitete Steinschutz verhindert das Eindringen von Steinen und verlängert so die Lebensdauer der Karkasse.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-811f-ae3e-e2f7e271a23b","parent":{"type":"