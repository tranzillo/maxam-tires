[{"object":"block","id":"38034d6d-7cea-81b6-999b-e52caefbfd99","parent":{"type":"page_id","page_id":"38034d6d-7cea-8195-9f3e-dc3bdd39b715"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX300L ist MAXAMs Premium-Antriebsreifen für den Linienverkehr, ausgestattet mit EcoPoint 3 -Verbundtechnologie. Die EcoPoint 3 -Verbundtechnologie sorgt für eine optimierte Laufleistung, weniger Kraftstoffverbrauch und bessere Traktion bei Nässe – ohne Kompromisse. Mit seiner beachtlichen Profiltiefe von 30/32 Zoll und seiner Profilbreite von 240 mm bietet MX300L eine außergewöhnlich hohe Laufleistung, gleichmäßigen Verschleiß und eine solide Basis für eine Runderneuerung. Die geschlossene Schulterkonstruktion gewährleistet eine gleichmäßige Gewichts- und Drehmomentverteilung und sorgt so für eine hervorragende Stabilität und Handhabbarkeit. MX300L eignet sich am besten für den Linienverkehr auf der Autobahn und regionale Anwendungen. Nur in Nordamerika erhältlich","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX300L ist MAXAMs Premium-Antriebsreifen für den Linienverkehr, ausgestattet mit EcoPoint 3 -Verbundtechnologie. Die EcoPoint 3 -Verbundtechnologie sorgt für eine optimierte Laufleistung, weniger Kraftstoffverbrauch und bessere Traktion bei Nässe – ohne Kompromisse. Mit seiner beachtlichen Profiltiefe von 30/32 Zoll und seiner Profilbreite von 240 mm bietet MX300L eine außergewöhnlich hohe Laufleistung, gleichmäßigen Verschleiß und eine solide Basis für eine Runderneuerung. Die geschlossene Schulterkonstruktion gewährleistet eine gleichmäßige Gewichts- und Drehmomentverteilung und sorgt so für eine hervorragende Stabilität und Handhabbarkeit. MX300L eignet sich am besten für den Linienverkehr auf der Autobahn und regionale Anwendungen. Nur in Nordamerika erhältlich","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81fe-ad91-ce4e6ffe4cdf","parent":{"type":"page_id","page_id":"38034d6d-7cea-8195-9f3e-dc3bdd39b715"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-810f-85d2-fb44c32a32b9","parent":{"type":"page_id","page_id":"38034d6d-7cea-8195-9f3e-dc3bdd39b715"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Die solide Schulterkonstruktion sorgt für Stabilität, gutes Handling und eine hohe Laufleistung.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Die solide Schulterkonstruktion sorgt für Stabilität, gutes Handling und eine hohe Laufleistung.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81e8-806b-ddf2cc53a8d4","parent":{"type":"page_id","page_id":"3803