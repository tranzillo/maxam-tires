[{"object":"block","id":"38034d6d-7cea-8177-8bf0-f4f1460f3336","parent":{"type":"page_id","page_id":"38034d6d-7cea-813f-9404-f45a3fd2a13b"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX310R ist MAXAMs regionaler Antriebsreifen mit EcoPoint 3 -Technologie. Die EcoPoint 3 -Verbundtechnologie sorgt für eine optimierte Laufleistung, weniger Kraftstoffverbrauch und bessere Traktion bei Nässe – ohne Kompromisse. Das Stollenmuster des MX310R bietet ein ausgewogenes Verhältnis aus Traktion und Laufleistung und ist damit für eine Vielzahl von Anwendungen geeignet. Die Profilbreite von 230 mm sorgt für Stabilität und gleichmäßigen Verschleiß, sodass der Reifen lange hält. Durch die offene Schulterkonstruktion erzielt der Reifen eine besonders gute Traktion, was ihn zu einem zuverlässigen Begleiter in jeder Umgebung und bei Extremwetter macht. MX310R ist für regionale und lokale Lieferfahrten auf der Autobahn konzipiert. Nur in Nordamerika erhältlich","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX310R ist MAXAMs regionaler Antriebsreifen mit EcoPoint 3 -Technologie. Die EcoPoint 3 -Verbundtechnologie sorgt für eine optimierte Laufleistung, weniger Kraftstoffverbrauch und bessere Traktion bei Nässe – ohne Kompromisse. Das Stollenmuster des MX310R bietet ein ausgewogenes Verhältnis aus Traktion und Laufleistung und ist damit für eine Vielzahl von Anwendungen geeignet. Die Profilbreite von 230 mm sorgt für Stabilität und gleichmäßigen Verschleiß, sodass der Reifen lange hält. Durch die offene Schulterkonstruktion erzielt der Reifen eine besonders gute Traktion, was ihn zu einem zuverlässigen Begleiter in jeder Umgebung und bei Extremwetter macht. MX310R ist für regionale und lokale Lieferfahrten auf der Autobahn konzipiert. Nur in Nordamerika erhältlich","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81f7-9c8e-e1753df70e2c","parent":{"type":"page_id","page_id":"38034d6d-7cea-813f-9404-f45a3fd2a13b"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81e5-892f-c3d7569cb39b","parent":{"type":"page_id","page_id":"38034d6d-7cea-813f-9404-f45a3fd2a13b"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Die offene Schulterkonstruktion bietet eine verbesserte Traktion bei jedem Wetter.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Die offene Schulterkonstruktion bietet eine verbesserte Traktion bei jedem Wetter.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81c6-b7b6-e4125e91ec13","parent":{"type":"page_id","page_id":"38034d6d-7cea-813f-9404-f45a3fd2a13b"},"cr