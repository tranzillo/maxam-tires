[{"object":"block","id":"38034d6d-7cea-81a8-9a04-f5716c5f30ff","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cd-bf6a-d512bb046bce"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX320V ist MAXAMs Antriebsreifen für unterschiedliche Einsatzbereiche, auch bei anspruchsvollen Bedingungen. Mit seiner Profilbreite von 230 mm sorgt MX320V für Stabilität und gleichmäßigen Verschleiß, was zu seiner hohen Haltbarkeit selbst bei Anwendungen mit starkem Abrieb beiträgt. Durch das Stollenmuster sind Traktion und Verschleiß auf verschiedenen Oberflächen ausgeglichen, sodass der Reifen in unterschiedlichen Umgebungen vielseitig eingesetzt werden kann. Die verstärkte und abriebfeste Verbundmischung sorgt für einen geringen Rollwiderstand und macht den Reifen besonders schnitt-, splitter- und abriebresistent. MX320V ist für regionale und lokale Lieferfahrten in unterschiedlichen Einsatzbereichen konzipiert. Nur in Nordamerika erhältlich","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX320V ist MAXAMs Antriebsreifen für unterschiedliche Einsatzbereiche, auch bei anspruchsvollen Bedingungen. Mit seiner Profilbreite von 230 mm sorgt MX320V für Stabilität und gleichmäßigen Verschleiß, was zu seiner hohen Haltbarkeit selbst bei Anwendungen mit starkem Abrieb beiträgt. Durch das Stollenmuster sind Traktion und Verschleiß auf verschiedenen Oberflächen ausgeglichen, sodass der Reifen in unterschiedlichen Umgebungen vielseitig eingesetzt werden kann. Die verstärkte und abriebfeste Verbundmischung sorgt für einen geringen Rollwiderstand und macht den Reifen besonders schnitt-, splitter- und abriebresistent. MX320V ist für regionale und lokale Lieferfahrten in unterschiedlichen Einsatzbereichen konzipiert. Nur in Nordamerika erhältlich","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81b2-988b-f7f9d590513e","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cd-bf6a-d512bb046bce"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-813b-a783-c3f64e4ffca4","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cd-bf6a-d512bb046bce"},"created_time":"2026-06-15T13:56:00.000Z","last_edited_time":"2026-06-15T13:56:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Die offene Schulterkonstruktion bietet eine verbesserte Traktion bei jedem Wetter.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Die offene Schulterkonstruktion bietet eine verbesserte Traktion bei jedem Wetter.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81a9-8c23-f05fd6650d9a","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cd-bf6a-d512bb046bce"},"created_time":"2026-06-15T13:5