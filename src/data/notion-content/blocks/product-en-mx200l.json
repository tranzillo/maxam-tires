[{"object":"block","id":"35534d6d-7cea-81ca-a98c-d32f7cdf14aa","parent":{"type":"page_id","page_id":"35534d6d-7cea-813a-8f8d-ce81de6af1a3"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MX200L is MAXAM's premium line-haul steer tire that features our proprietary EcoPoint 3 compound technology. EcoPoint 3 optimizes mileage, fuel economy and wet traction without compromising performance, setting a new standard for long-haul application. Engineered with a decoupling groove and five wide ribs, this premium tire offers unparalleled control and comfort. The MX200L is also equipped with micro-sipes to minimize irregular wear and enhance lateral traction in wet conditions, providing reliability and safety in every journey. The MX200L is best suited for highway long haul applications. Available only in North America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MX200L is MAXAM's premium line-haul steer tire that features our proprietary EcoPoint 3 compound technology. EcoPoint 3 optimizes mileage, fuel economy and wet traction without compromising performance, setting a new standard for long-haul application. Engineered with a decoupling groove and five wide ribs, this premium tire offers unparalleled control and comfort. The MX200L is also equipped with micro-sipes to minimize irregular wear and enhance lateral traction in wet conditions, providing reliability and safety in every journey. The MX200L is best suited for highway long haul applications. Available only in North America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","i