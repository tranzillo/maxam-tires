[{"object":"block","id":"35534d6d-7cea-81bc-a89f-f6e1adce9ed8","parent":{"type":"page_id","page_id":"35534d6d-7cea-814a-89a1-c53db71433f0"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MX210R, featuring our proprietary EcoPoint 3 compound technology, is your ultimate choice for regional all-position tires. EcoPoint 3 compound technology takes efficiency to new heights, optimizing mileage, fuel economy and wet traction without compromise. With a substantial 20/32\" tread depth, the MX210R delivers exceptional mileage, promising unparalleled durability. The MX210R is also engineered with ribs for excellent stability and handling in wet conditions. The MX210R is best suited for on-highway regional and local delivery applications. Available only in North America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MX210R, featuring our proprietary EcoPoint 3 compound technology, is your ultimate choice for regional all-position tires. EcoPoint 3 compound technology takes efficiency to new heights, optimizing mileage, fuel economy and wet traction without compromise. With a substantial 20/32\" tread depth, the MX210R delivers exceptional mileage, promising unparalleled durability. The MX210R is also engineered with ribs for excellent stability and handling in wet conditions. The MX210R is best suited for on-highway regional and local delivery applications. Available only in North America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-814a-96d1-e788238282c3","parent":{"type":"page_id","page_id":"35534d6d-7cea-814a