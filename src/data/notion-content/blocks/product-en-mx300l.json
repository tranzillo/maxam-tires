[{"object":"block","id":"35534d6d-7cea-814d-b72a-c34e2aaa87fd","parent":{"type":"page_id","page_id":"35534d6d-7cea-8126-9670-f988e87f592f"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MX300L is MAXAM's premium line haul drive tire, engineered with EcoPoint 3 compound technology. The EcoPoint 3 compound technology optimizes mileage, fuel economy and wet traction without compromise. The MX300L boasts a substantial 30/32\" tread depth and a 240mm tread width for exceptional mileage and even wear, providing a solid foundation for retreading. Its closed shoulder design ensures even weight and torque distribution for exceptional stability and handling. The MX300L is best suited for highway line haul and regional applications. Available only in North America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MX300L is MAXAM's premium line haul drive tire, engineered with EcoPoint 3 compound technology. The EcoPoint 3 compound technology optimizes mileage, fuel economy and wet traction without compromise. The MX300L boasts a substantial 30/32\" tread depth and a 240mm tread width for exceptional mileage and even wear, providing a solid foundation for retreading. Its closed shoulder design ensures even weight and torque distribution for exceptional stability and handling. The MX300L is best suited for highway line haul and regional applications. Available only in North America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81be-bb1c-f0982f76d0df","parent":{"type":"page_id","page_id":"35534d6d-7cea-8126-9670-f988e8