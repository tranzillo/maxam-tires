[{"object":"block","id":"35534d6d-7cea-812f-95ab-c9526ca33b09","parent":{"type":"page_id","page_id":"35534d6d-7cea-8174-8961-ff3a2ddbcc30"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MX310R is MAXAM's regional drive tire engineered with EcoPoint 3 . The EcoPoint 3 compound technology optimizes mileage, fuel economy and wet traction without compromise. Balancing traction and mileage, the lug pattern of the MX310R accommodates multiple applications. With its open shoulder design, this tire offers enhanced traction making it reliable in any environment and extreme weather conditions. The MX310R is designed for on-highway regional and local delivery applications. Available only in North America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MX310R is MAXAM's regional drive tire engineered with EcoPoint 3 . The EcoPoint 3 compound technology optimizes mileage, fuel economy and wet traction without compromise. Balancing traction and mileage, the lug pattern of the MX310R accommodates multiple applications. With its open shoulder design, this tire offers enhanced traction making it reliable in any environment and extreme weather conditions. The MX310R is designed for on-highway regional and local delivery applications. Available only in North America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8193-930e-c05b9d1a4ed4","parent":{"type":"page_id","page_id":"35534d6d-7cea-8174-8961-ff3a2ddbcc30"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"u