[{"object":"block","id":"35534d6d-7cea-819c-8deb-d39c224dd2a6","parent":{"type":"page_id","page_id":"35534d6d-7cea-8103-8b54-fe9503efab0f"},"created_time":"2026-05-03T20:54:00.000Z","last_edited_time":"2026-05-03T20:54:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"The MX325V is MAXAM's mixed service drive tire, engineered for heavy-duty, mixed service applications such as logging. With a substantial 32/32\" tread depth, it strikes a balance between traction and wear, ensuring reliability in severe operating applications. The 230mm tread depth promotes stability and even wear for extended durability. The MX325V incorporates a heavy-duty tread compound, enabling maximum cut, chip, and abrasion-resistance. The MX325V is designed for severe mixed service regional and local applications such as logging. Available only in North America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"The MX325V is MAXAM's mixed service drive tire, engineered for heavy-duty, mixed service applications such as logging. With a substantial 32/32\" tread depth, it strikes a balance between traction and wear, ensuring reliability in severe operating applications. The 230mm tread depth promotes stability and even wear for extended durability. The MX325V incorporates a heavy-duty tread compound, enabling maximum cut, chip, and abrasion-resistance. The MX325V is designed for severe mixed service regional and local applications such as logging. Available only in North America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-817f-95a8-c9c5297629ea","parent":{"type":"page_id","page_id":"35534d6d-7cea-8103-8b54-fe9503efab0f"},"