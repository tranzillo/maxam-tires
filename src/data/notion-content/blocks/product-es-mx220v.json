[{"object":"block","id":"38034d6d-7cea-8191-b7e9-d1a4c8993322","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d2-aa32-c990d60f8174"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"El MX220V es el neumático radial para camión para todas las posiciones de MAXAM y está diseñado para aplicaciones de servicio mixto agresivas. El MX220V está equipado con botones de protección contra piedras dentro de los surcos de la banda de rodamiento para proteger contra perforaciones causadas por piedras, lo que garantiza un rendimiento duradero. Su sólido diseño de hombro resiste el roce lateral en condiciones de servicio agresivas, mientras que el compuesto resistente a cortes y desconchados ofrece una protección superior de la banda de rodadura y un mayor kilometraje durante los desplazamientos. Ideal para todas las posiciones en aplicaciones de servicio mixto, el MX220V proporciona durabilidad y fiabilidad en cada viaje. Disponible sólo en Norteamérica","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El MX220V es el neumático radial para camión para todas las posiciones de MAXAM y está diseñado para aplicaciones de servicio mixto agresivas. El MX220V está equipado con botones de protección contra piedras dentro de los surcos de la banda de rodamiento para proteger contra perforaciones causadas por piedras, lo que garantiza un rendimiento duradero. Su sólido diseño de hombro resiste el roce lateral en condiciones de servicio agresivas, mientras que el compuesto resistente a cortes y desconchados ofrece una protección superior de la banda de rodadura y un mayor kilometraje durante los desplazamientos. Ideal para todas las posiciones en aplicaciones de servicio mixto, el MX220V proporciona durabilidad y fiabilidad en cada viaje. Disponible sólo en Norteamérica","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-813a-8428-f220dac33c7f","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d2-aa32-c990d60f8174"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-817c-9dc1-e28b99744275","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d2-aa32-c990d60f8174"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Los protectores contra piedras dentro de los surcos de la banda de rodadura evitan las perforaciones causadas por piedras y maximizan la vida útil de la carcasa.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Los protectores contra piedras dentro de los surcos de la banda de rodadura evitan las perforaciones causadas por piedras y maximizan la vida útil de la carcasa.","href":null}],"color":"default"},