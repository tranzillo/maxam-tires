[{"object":"block","id":"38034d6d-7cea-8161-b32a-fade1950b979","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-8274-eb8c85b41d8d"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"El MX300L es el neumático de tracción de largo recorrido premium de MAXAM, diseñado con tecnología de compuesto EcoPoint 3 . La tecnología de compuesto EcoPoint 3 optimiza el kilometraje, la economía de combustible y la tracción sobre mojado sin concesiones. El MX300L cuenta con una sustancial profundidad de banda de rodadura de 30/32\" y un ancho de banda de rodadura de 240mm para un kilometraje excepcional y un desgaste uniforme, lo que proporciona una base sólida para el recauchutado. Su diseño de hombro cerrado garantiza una distribución uniforme del peso y el par, lo que resulta en una estabilidad y manejo excepcionales. El MX300L es el más adecuado para aplicaciones regionales y de transporte de largo recorrido por carretera. Disponible sólo en Norteamérica","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El MX300L es el neumático de tracción de largo recorrido premium de MAXAM, diseñado con tecnología de compuesto EcoPoint 3 . La tecnología de compuesto EcoPoint 3 optimiza el kilometraje, la economía de combustible y la tracción sobre mojado sin concesiones. El MX300L cuenta con una sustancial profundidad de banda de rodadura de 30/32\" y un ancho de banda de rodadura de 240mm para un kilometraje excepcional y un desgaste uniforme, lo que proporciona una base sólida para el recauchutado. Su diseño de hombro cerrado garantiza una distribución uniforme del peso y el par, lo que resulta en una estabilidad y manejo excepcionales. El MX300L es el más adecuado para aplicaciones regionales y de transporte de largo recorrido por carretera. Disponible sólo en Norteamérica","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81f9-92ae-e2dd10bd78a5","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-8274-eb8c85b41d8d"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81d2-8a5e-e7fbb4418e1b","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-8274-eb8c85b41d8d"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Los hombros sólidos proporcionan estabilidad, excelente manejo y mayor kilometraje.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Los hombros sólidos proporcionan estabilidad, excelente manejo y mayor kilometraje.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8130-a96f-e43bc51d6084","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-8274-eb8c85b41d