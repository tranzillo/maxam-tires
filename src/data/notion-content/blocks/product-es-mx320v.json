[{"object":"block","id":"38034d6d-7cea-810d-88ea-d14b9ea8496f","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-9b26-d4d3b18fa716"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"El MX320V es el neumático de tracción para servicios mixtos de MAXAM, diseñado para aplicaciones de servicios mixtos severas. Con un ancho de banda de rodadura de 230mm que promueve la estabilidad y el desgaste uniforme, el MX320V ofrece la máxima durabilidad para los rigores de las aplicaciones de mayor abrasión. Su patrón de tacos logra un equilibrio entre tracción y desgaste en diversas superficies, brindando versatilidad en diferentes entornos. Con su compuesto reforzado resistente a la abrasión, este neumático cuenta con una baja resistencia a la rodadura y un rendimiento inigualable con resistencia a cortes, desconchados y la abrasión. El MX320V está diseñado para aplicaciones de transporte y entregas locales y regionales de servicio mixto. Disponible sólo en Norteamérica","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El MX320V es el neumático de tracción para servicios mixtos de MAXAM, diseñado para aplicaciones de servicios mixtos severas. Con un ancho de banda de rodadura de 230mm que promueve la estabilidad y el desgaste uniforme, el MX320V ofrece la máxima durabilidad para los rigores de las aplicaciones de mayor abrasión. Su patrón de tacos logra un equilibrio entre tracción y desgaste en diversas superficies, brindando versatilidad en diferentes entornos. Con su compuesto reforzado resistente a la abrasión, este neumático cuenta con una baja resistencia a la rodadura y un rendimiento inigualable con resistencia a cortes, desconchados y la abrasión. El MX320V está diseñado para aplicaciones de transporte y entregas locales y regionales de servicio mixto. Disponible sólo en Norteamérica","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81ff-8cc9-ff857ace9f9b","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-9b26-d4d3b18fa716"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8172-89d3-f65dcec6e1ae","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-9b26-d4d3b18fa716"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"El diseño de hombro abierto proporciona una tracción mejorada para las superficies en cualquier condición climática.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El diseño de hombro abierto proporciona una tracción mejorada para las superficies en cualquier condición climática.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-