[{"object":"block","id":"38034d6d-7cea-812c-b6a4-de3c89717ba6","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-bf37-fdf74335c3cd"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"El MX325V es el neumático de tracción para servicios mixtos de MAXAM, diseñado para aplicaciones de servicios mixtos, incluso en las condiciones más extremas. Con una profundidad sustancial de la banda de rodadura de 32/32\", este neumático logra un equilibrio entre tracción y desgaste, lo que garantiza fiabilidad en aplicaciones de operaciones intensivas. La profundidad de la banda de rodadura de 230 mm promueve la estabilidad y el desgaste uniforme para una mayor durabilidad. Gracias a los compuestos especiales de alta resistencia de la banda de rodadura, el MX325 presenta máxima resistencia a cortes, desconchados y la abrasión. El MX325V está diseñado para aplicaciones de transporte y entregas locales y regionales de servicio mixto. Disponible sólo en Norteamérica","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El MX325V es el neumático de tracción para servicios mixtos de MAXAM, diseñado para aplicaciones de servicios mixtos, incluso en las condiciones más extremas. Con una profundidad sustancial de la banda de rodadura de 32/32\", este neumático logra un equilibrio entre tracción y desgaste, lo que garantiza fiabilidad en aplicaciones de operaciones intensivas. La profundidad de la banda de rodadura de 230 mm promueve la estabilidad y el desgaste uniforme para una mayor durabilidad. Gracias a los compuestos especiales de alta resistencia de la banda de rodadura, el MX325 presenta máxima resistencia a cortes, desconchados y la abrasión. El MX325V está diseñado para aplicaciones de transporte y entregas locales y regionales de servicio mixto. Disponible sólo en Norteamérica","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8159-ae3f-df1fc8c8911a","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-bf37-fdf74335c3cd"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8140-a0ba-d66a433a83a9","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-bf37-fdf74335c3cd"},"created_time":"2026-06-15T15:10:00.000Z","last_edited_time":"2026-06-15T15:10:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"El diseño de hombro abierto proporciona máxima tracción incluso en terrenos más blandos.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"El diseño de hombro abierto proporciona máxima tracción incluso en terrenos más blandos.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-816d-8720-fa0fda39d371","parent":{"type":"page_id","page_id":"38034d6d-7cea-81