[{"object":"block","id":"38034d6d-7cea-8127-b366-ec9ca2521c8e","parent":{"type":"page_id","page_id":"38034d6d-7cea-8166-9fed-c94b2fe09a02"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Doté de notre technologie exclusive de composé EcoPoint3, le MX200L est le pneu de roue directrice haut de gamme de MAXAM pour le transport de ligne. La technologie EcoPoint3 optimise le kilométrage, les économies de carburant et la traction sur route mouillée sans faire de compromis sur les performances. C’est la nouvelle référence pour les longues distances. Intégrant une rainure de découplage et cinq larges nervures, ce pneu haut de gamme offre un contrôle et un confort inégalés. Le MX200L est également équipé de micro-lamelles qui minimisent l’usure irrégulière et améliorent la traction latérale dans des conditions humides pour un maximum de fiabilité et de sécurité à chaque trajet. Le MX200L est particulièrement adapté aux utilisations longue distance sur autoroute. Disponible uniquement en Amérique du Nord","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Doté de notre technologie exclusive de composé EcoPoint3, le MX200L est le pneu de roue directrice haut de gamme de MAXAM pour le transport de ligne. La technologie EcoPoint3 optimise le kilométrage, les économies de carburant et la traction sur route mouillée sans faire de compromis sur les performances. C’est la nouvelle référence pour les longues distances. Intégrant une rainure de découplage et cinq larges nervures, ce pneu haut de gamme offre un contrôle et un confort inégalés. Le MX200L est également équipé de micro-lamelles qui minimisent l’usure irrégulière et améliorent la traction latérale dans des conditions humides pour un maximum de fiabilité et de sécurité à chaque trajet. Le MX200L est particulièrement adapté aux utilisations longue distance sur autoroute. Disponible uniquement en Amérique du Nord","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8191-8be5-d8e501531e68","parent":{"type":"page_id","page_id":"38034d6d-7cea-8166-9fed-c94b2fe09a02"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81bb-ba8d-ed3bbb375a09","parent":{"type":"page_id","page_id":"38034d6d-7cea-8166-9fed-c94b2fe09a02"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Les micro-lamelles améliorent la traction dans des conditions humides et uniformisent l’usure.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Les micro-lamelles améliorent la traction dans des conditions humides et uniformisent l’usure.","href":null}],"color":"default"},"archived":false},{"object":"b