[{"object":"block","id":"38034d6d-7cea-81de-a3d0-f2bd62cd4128","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d4-a79c-e6fa3d8228ad"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Conçu pour les applications intensives et mixtes, le MX220V est le pneu radial pour camions toutes positions de MAXAM. Le MX220V est équipé de boutons de protection dans les vides de la bande de roulement qui le protègent contre les perforations des graviers pour des performances durables. Sa conception robuste à épaulement résiste aux frottements latéraux dans les conditions difficiles, tandis que le composé résistant aux coupures et aux éclats protège efficacement la bande de roulement et prolonge le kilométrage. Idéal dans toutes les positions dans les applications de services mixtes, le MX220V assure résistance et fiabilité à chaque trajet. Disponible uniquement en Amérique du Nord","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Conçu pour les applications intensives et mixtes, le MX220V est le pneu radial pour camions toutes positions de MAXAM. Le MX220V est équipé de boutons de protection dans les vides de la bande de roulement qui le protègent contre les perforations des graviers pour des performances durables. Sa conception robuste à épaulement résiste aux frottements latéraux dans les conditions difficiles, tandis que le composé résistant aux coupures et aux éclats protège efficacement la bande de roulement et prolonge le kilométrage. Idéal dans toutes les positions dans les applications de services mixtes, le MX220V assure résistance et fiabilité à chaque trajet. Disponible uniquement en Amérique du Nord","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8189-b7e5-f6b87d55a28d","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d4-a79c-e6fa3d8228ad"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8119-b8af-f3c4be1fec45","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d4-a79c-e6fa3d8228ad"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Les protections installées dans les vides de la bande de roulement la protègent contre les perforations des graviers afin de maximiser la durée de vie de la carcasse.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Les protections installées dans les vides de la bande de roulement la protègent contre les perforations des graviers afin de maximiser la durée de vie de la carcasse.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81d5-ab92-db3ece8bdb61","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d4-a79c-e6