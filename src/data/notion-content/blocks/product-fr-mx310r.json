[{"object":"block","id":"38034d6d-7cea-8182-a392-c7514a487756","parent":{"type":"page_id","page_id":"38034d6d-7cea-814d-b2e7-c83876700cf5"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Équipé de la technologie de composé EcoPoint 3 , le MX310R est le pneu de traction de MAXAM pour le transport régional. La technologie de composé EcoPoint 3 optimise le kilométrage, les économies de carburant et la traction sur sol mouillé, sans faire aucun compromis. Offrant l’équilibre idéal entre traction et kilométrage, les crampons du MX310R s’adaptent à un large éventail d’applications. Sa largeur de bande de roulement de 230 mm est gage de stabilité et favorise une usure uniforme qui prolonge sa durée de vie. Avec sa conception à épaulement ouvert, ce pneu offre une traction supérieure pour une fiabilité optimale dans tous les environnements, y compris avec des conditions météorologiques extrêmes. Le MX310R est conçu pour les applications de livraison régionales et locales sur autoroute. Disponible uniquement en Amérique du Nord","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Équipé de la technologie de composé EcoPoint 3 , le MX310R est le pneu de traction de MAXAM pour le transport régional. La technologie de composé EcoPoint 3 optimise le kilométrage, les économies de carburant et la traction sur sol mouillé, sans faire aucun compromis. Offrant l’équilibre idéal entre traction et kilométrage, les crampons du MX310R s’adaptent à un large éventail d’applications. Sa largeur de bande de roulement de 230 mm est gage de stabilité et favorise une usure uniforme qui prolonge sa durée de vie. Avec sa conception à épaulement ouvert, ce pneu offre une traction supérieure pour une fiabilité optimale dans tous les environnements, y compris avec des conditions météorologiques extrêmes. Le MX310R est conçu pour les applications de livraison régionales et locales sur autoroute. Disponible uniquement en Amérique du Nord","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8153-a8fd-ccfed692a0d4","parent":{"type":"page_id","page_id":"38034d6d-7cea-814d-b2e7-c83876700cf5"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8178-8cf7-ce7d38bf19bd","parent":{"type":"page_id","page_id":"38034d6d-7cea-814d-b2e7-c83876700cf5"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"La conception à épaulement ouvert offre une traction supérieure par tous les temps.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"La conception à épaulement ouvert offre une traction supérieure par tous les temps.","href":null}],"color":"default"},"arc