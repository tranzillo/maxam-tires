[{"object":"block","id":"38034d6d-7cea-81e7-ba8b-d0df0d69b92a","parent":{"type":"page_id","page_id":"38034d6d-7cea-817b-8ee7-e7387662d3c8"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Le MX320V de MAXAM est conçu pour les applications intensives en service mixte. Avec sa largeur de bande de roulement de 230mm, gage de stabilité et d’usure uniforme, le MX320V offre une durabilité maximale face aux rigueurs des applications sur sol abrasif. Ses crampons assurent le juste équilibre entre traction et usure sur diverses surfaces pour une polyvalence adaptée à différents environnements. Avec son composé renforcé résistant à l’abrasion, ce pneu offre une faible résistance au roulement et des performances inégalées face aux coupures, aux éclats et à l’abrasion. Le MX320V est conçu pour les applications de livraison régionales et locales en service mixte. Disponible uniquement en Amérique du Nord","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Le MX320V de MAXAM est conçu pour les applications intensives en service mixte. Avec sa largeur de bande de roulement de 230mm, gage de stabilité et d’usure uniforme, le MX320V offre une durabilité maximale face aux rigueurs des applications sur sol abrasif. Ses crampons assurent le juste équilibre entre traction et usure sur diverses surfaces pour une polyvalence adaptée à différents environnements. Avec son composé renforcé résistant à l’abrasion, ce pneu offre une faible résistance au roulement et des performances inégalées face aux coupures, aux éclats et à l’abrasion. Le MX320V est conçu pour les applications de livraison régionales et locales en service mixte. Disponible uniquement en Amérique du Nord","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8162-94fa-dfdbc201cf74","parent":{"type":"page_id","page_id":"38034d6d-7cea-817b-8ee7-e7387662d3c8"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-810b-bafb-e49f51ae8de0","parent":{"type":"page_id","page_id":"38034d6d-7cea-817b-8ee7-e7387662d3c8"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"La conception à épaulement ouvert offre une traction supérieure par tous les temps.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"La conception à épaulement ouvert offre une traction supérieure par tous les temps.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81b3-80b4-eadd5254aefb","parent":{"type":"page_id","page_id":"38034d6d-7cea-817b-8ee7-e7387662d3c8"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object