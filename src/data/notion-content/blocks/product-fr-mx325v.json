[{"object":"block","id":"38034d6d-7cea-81b5-81bd-c175a8868c77","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c9-b71f-c8111d3c234d"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"Conçu pour les applications en service mixte, le MX325V de MAXAM permet de faire face aux conditions les plus difficiles. Avec une profondeur de bande de roulement conséquente de 32/32\", il offre un équilibre idéal entre traction et usure, gage de fiabilité dans les applications intensives. La profondeur de bande de roulement de 230 mm favorise la stabilité et l’uniformité de l’usure, pour une durée de vie prolongée. Grâce aux composés haute résistance spéciaux de la bande de roulement, le MX325 offre une résistance maximale aux coupures, aux éclats et à l’abrasion. Le MX325V est conçu pour les applications de livraison régionales et locales en service mixte. Disponible uniquement en Amérique du Nord","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Conçu pour les applications en service mixte, le MX325V de MAXAM permet de faire face aux conditions les plus difficiles. Avec une profondeur de bande de roulement conséquente de 32/32\", il offre un équilibre idéal entre traction et usure, gage de fiabilité dans les applications intensives. La profondeur de bande de roulement de 230 mm favorise la stabilité et l’uniformité de l’usure, pour une durée de vie prolongée. Grâce aux composés haute résistance spéciaux de la bande de roulement, le MX325 offre une résistance maximale aux coupures, aux éclats et à l’abrasion. Le MX325V est conçu pour les applications de livraison régionales et locales en service mixte. Disponible uniquement en Amérique du Nord","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-815c-882a-f25b66bbd63a","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c9-b71f-c8111d3c234d"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8157-a257-d4daa3502aa3","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c9-b71f-c8111d3c234d"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"La conception à épaulement ouvert offre une traction supérieure, y compris sur terrains meubles.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"La conception à épaulement ouvert offre une traction supérieure, y compris sur terrains meubles.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81d3-8634-db9c38e70871","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c9-b71f-c8111d3c234d"},"created_time":"2026-06-15T15:12:00.000Z","last_edited_time":"2026-06-15T15:12:00.000Z","create