[{"object":"block","id":"38034d6d-7cea-813f-a9ca-d723a729e80b","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-a2e7-e7ca06a68aff"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX100L è lo pneumatico di MAXAM pensato per i rimorchi destinati al trasporto a lunga percorrenza su autostrada, caratterizzato dalla mescola realizzata con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Il caratteristico disegno delle nervature, completato dalla microlamelle e dalla scanalatura di disaccoppiamento, consente di ridurre al minimo il consumo irregolare e di aumentare la durevolezza e il chilometraggio. L'MX100L è la scelta ottimale per rimorchi destinati ad applicazioni autostradali a lunga percorrenza su assali singoli o tandem. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX100L è lo pneumatico di MAXAM pensato per i rimorchi destinati al trasporto a lunga percorrenza su autostrada, caratterizzato dalla mescola realizzata con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Il caratteristico disegno delle nervature, completato dalla microlamelle e dalla scanalatura di disaccoppiamento, consente di ridurre al minimo il consumo irregolare e di aumentare la durevolezza e il chilometraggio. L'MX100L è la scelta ottimale per rimorchi destinati ad applicazioni autostradali a lunga percorrenza su assali singoli o tandem. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-815d-a83c-d438ed5362da","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-a2e7-e7ca06a68aff"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-815a-9a68-cb76dc225062","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-a2e7-e7ca06a68aff"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"L'esclusivo design delle nervature ottimizza la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'esclusivo design delle nervature ottimizza la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8145-899f-e7aa184f66df","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-a2e7-e7ca06a68aff"},"created_time":"2026-06