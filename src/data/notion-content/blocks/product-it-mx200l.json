[{"object":"block","id":"38034d6d-7cea-8157-b433-ef53dba0f3a2","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b4-81bc-ecdfb08ece70"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX200L è lo pneumatico per assi sterzanti di MAXAM da autotrasporto a lungo raggio di qualità premium caratterizzato dalla mescola realizzata con la nostra tecnologia brevettata EcoPoint 3 . EcoPoint 3 consente di ottimizzare la resa chilometrica, il risparmio di carburante e la trazione sul bagnato senza compromettere le prestazioni, stabilendo un nuovo standard per le applicazioni a lunga percorrenza. Progettato con una scanalatura di disaccoppiamento e cinque larghe nervature, questo pneumatico di qualità premium offre un controllo e un comfort senza eguali. L'MX200L è anche dotato di microlamelle per ridurre al minimo il consumo irregolare e migliorare la trazione laterale sul bagnato, garantendo affidabilità e sicurezza in ogni viaggio. L'MX200L è particolarmente indicato per le applicazioni autostradali a lunga percorrenza. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX200L è lo pneumatico per assi sterzanti di MAXAM da autotrasporto a lungo raggio di qualità premium caratterizzato dalla mescola realizzata con la nostra tecnologia brevettata EcoPoint 3 . EcoPoint 3 consente di ottimizzare la resa chilometrica, il risparmio di carburante e la trazione sul bagnato senza compromettere le prestazioni, stabilendo un nuovo standard per le applicazioni a lunga percorrenza. Progettato con una scanalatura di disaccoppiamento e cinque larghe nervature, questo pneumatico di qualità premium offre un controllo e un comfort senza eguali. L'MX200L è anche dotato di microlamelle per ridurre al minimo il consumo irregolare e migliorare la trazione laterale sul bagnato, garantendo affidabilità e sicurezza in ogni viaggio. L'MX200L è particolarmente indicato per le applicazioni autostradali a lunga percorrenza. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8117-89d3-fe7edd03cc93","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b4-81bc-ecdfb08ece70"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8151-9c10-eed7f817ee2f","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b4-81bc-ecdfb08ece70"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Le microlamelle ottimizzano l'aderenza sul bagnato e riducono al minimo il consumo irregolare.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Le microlamelle ottimizzano l'aderenza sul bagnato e 