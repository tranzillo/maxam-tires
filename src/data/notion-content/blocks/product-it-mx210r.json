[{"object":"block","id":"38034d6d-7cea-81f1-8aaf-e5a6441c1cda","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d0-89d2-d0c789ad7cb4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX210R, caratterizzato da una mescola realizzata mediante tecnologia EcoPoint 3 , è la scelta perfetta per gli pneumatici per assi sterzanti destinati ai trasporti regionali. La tecnologia EcoPoint 3 della mescola porta l'efficienza a un livello superiore, ottimizzando il chilometraggio, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Grazie alla notevole profondità del battistrada, pari a 20/32\"\", l'MX210R assicura una eccezionale resa chilometrica e una durevolezza senza precedenti. Il design delle nervature da 230 mm di larghezza favorisce un consumo uniforme e un'impronta compatta assicurando un alto grado di affidabilità su strada. Inoltre, l'MX210R è progettato con nervature che assicurano un'eccellente stabilità e maneggevolezza sul bagnato. L'MX210R è particolarmente adatto per applicazioni di trasporto merci locale e regionale su autostrada. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX210R, caratterizzato da una mescola realizzata mediante tecnologia EcoPoint 3 , è la scelta perfetta per gli pneumatici per assi sterzanti destinati ai trasporti regionali. La tecnologia EcoPoint 3 della mescola porta l'efficienza a un livello superiore, ottimizzando il chilometraggio, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Grazie alla notevole profondità del battistrada, pari a 20/32\"\", l'MX210R assicura una eccezionale resa chilometrica e una durevolezza senza precedenti. Il design delle nervature da 230 mm di larghezza favorisce un consumo uniforme e un'impronta compatta assicurando un alto grado di affidabilità su strada. Inoltre, l'MX210R è progettato con nervature che assicurano un'eccellente stabilità e maneggevolezza sul bagnato. L'MX210R è particolarmente adatto per applicazioni di trasporto merci locale e regionale su autostrada. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8184-bc62-cbebdde2356a","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d0-89d2-d0c789ad7cb4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81f2-828b-ec93d14caaf4","parent":{"type":"page_id","page_id":"38034d6d-7cea-81d0-89d2-d0c789ad7cb4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Le microlamelle ottimizzano l'aderenza sul bagnato e riducono al minimo il consumo irregolare.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":fal