[{"object":"block","id":"38034d6d-7cea-81a3-b568-e2e754b7389c","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-a0c7-f6ca515d795a"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX220V è lo pneumatico radiale di MAXAM per autocarri per tutte le posizioni, progettato per impegnative applicazioni in servizi misti. L'MX220V è dotato di elementi di protezione dal pietrisco all'interno delle scanalature del battistrada che proteggono lo pneumatico dai danni causati dalle pietre, assicurando prestazioni di lunga durata. Il robusto design della spalla resiste allo sfregamento laterale nelle condizioni di servizio più impegnative, mentre la mescola resistente ai tagli e alla frammentazione offre una protezione del battistrada e una resa chilometrica superiori durante l'utilizzo. Ideale per tutte le posizioni in applicazioni per servizi misti, l'MX220V assicura durevolezza e affidabilità in ogni viaggio. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX220V è lo pneumatico radiale di MAXAM per autocarri per tutte le posizioni, progettato per impegnative applicazioni in servizi misti. L'MX220V è dotato di elementi di protezione dal pietrisco all'interno delle scanalature del battistrada che proteggono lo pneumatico dai danni causati dalle pietre, assicurando prestazioni di lunga durata. Il robusto design della spalla resiste allo sfregamento laterale nelle condizioni di servizio più impegnative, mentre la mescola resistente ai tagli e alla frammentazione offre una protezione del battistrada e una resa chilometrica superiori durante l'utilizzo. Ideale per tutte le posizioni in applicazioni per servizi misti, l'MX220V assicura durevolezza e affidabilità in ogni viaggio. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81b7-a282-cc1104a38e5f","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-a0c7-f6ca515d795a"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8174-85ac-d9c6c67e79d6","parent":{"type":"page_id","page_id":"38034d6d-7cea-8110-a0c7-f6ca515d795a"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Gli elementi di protezione all'interno delle scanalature del battistrada impediscono al pietrisco di perforare la carcassa, allungandone la durata.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Gli elementi di protezione all'interno delle scanalature del battistrada impediscono al pietrisco di perforare la carcassa, allungandone la durata.","href":null}],"color":"default"},"archived":false},{"object":"block","id"