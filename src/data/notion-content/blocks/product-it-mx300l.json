[{"object":"block","id":"38034d6d-7cea-818f-9151-edb98b794f64","parent":{"type":"page_id","page_id":"38034d6d-7cea-8119-81d3-f3267b574548"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX300L è lo pneumatico di MAXAM per asse trattivo di qualità premium destinato al trasporto a lunga percorrenza e caratterizzato dalla mescola realizzata con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. L'MX300L vanta la notevole profondità di 30/32\"\" e una larghezza di 240 mm del battistrada e assicura così una resa chilometrica eccezionale e un consumo uniforme, offrendo una solida base per la ricostruzione. Il design a spalla chiusa assicura una distribuzione equilibrata del peso e della coppia, per un'eccezionale stabilità e maneggevolezza. L'MX300L è la scelta ottimale per applicazioni a lunga percorrenza e regionali su autostrada. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX300L è lo pneumatico di MAXAM per asse trattivo di qualità premium destinato al trasporto a lunga percorrenza e caratterizzato dalla mescola realizzata con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. L'MX300L vanta la notevole profondità di 30/32\"\" e una larghezza di 240 mm del battistrada e assicura così una resa chilometrica eccezionale e un consumo uniforme, offrendo una solida base per la ricostruzione. Il design a spalla chiusa assicura una distribuzione equilibrata del peso e della coppia, per un'eccezionale stabilità e maneggevolezza. L'MX300L è la scelta ottimale per applicazioni a lunga percorrenza e regionali su autostrada. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-811a-ba0a-d12fd8618013","parent":{"type":"page_id","page_id":"38034d6d-7cea-8119-81d3-f3267b574548"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81ea-b6ae-d9caa62aafc8","parent":{"type":"page_id","page_id":"38034d6d-7cea-8119-81d3-f3267b574548"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Le robuste spalle assicurano stabilità, eccellente manovrabilità e una resa chilometrica ottimale.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Le robuste spalle assicurano stabilità, eccellente manovrabilità e una resa chilometrica ottimale.","href":null}],"color":"default"},"archived":false},{"object