[{"object":"block","id":"38034d6d-7cea-81c5-b872-efdf85f6772c","parent":{"type":"page_id","page_id":"38034d6d-7cea-8145-9e20-d5c858dee78b"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX310R è lo pneumatico per asse trattivo di MAXAM per applicazioni regionali realizzato con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Il disegno dei tasselli dell'MX310R, che consente aderenza e resa chilometrica equilibrate, è adatto a molteplici applicazioni. Il battistrada da 230 mm fornisce stabilità e favorisce un consumo uniforme, prolungando la vita dello pneumatico. Grazie al design a spalla aperta, questo penumatico offre un'aderenza ottimale che lo rende affidabile in ogni ambiente e in condizioni meteorologiche estreme. L'MX310R è progettato per applicazioni di trasporto merci locale e regionale su autostrada. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX310R è lo pneumatico per asse trattivo di MAXAM per applicazioni regionali realizzato con tecnologia EcoPoint 3 . La tecnologia EcoPoint 3 della mescola consente di ottimizzare la resa chilometrica, il risparmio di carburante e l'aderenza sul bagnato senza fare compromessi. Il disegno dei tasselli dell'MX310R, che consente aderenza e resa chilometrica equilibrate, è adatto a molteplici applicazioni. Il battistrada da 230 mm fornisce stabilità e favorisce un consumo uniforme, prolungando la vita dello pneumatico. Grazie al design a spalla aperta, questo penumatico offre un'aderenza ottimale che lo rende affidabile in ogni ambiente e in condizioni meteorologiche estreme. L'MX310R è progettato per applicazioni di trasporto merci locale e regionale su autostrada. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-812d-9195-f0303e4d298f","parent":{"type":"page_id","page_id":"38034d6d-7cea-8145-9e20-d5c858dee78b"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8124-90ba-d2f6a26cf5ce","parent":{"type":"page_id","page_id":"38034d6d-7cea-8145-9e20-d5c858dee78b"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Il design a spalla aperta assicura un'aderenza ottimale in tutte le condizioni meteo.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Il design a spalla aperta assicura un'aderenza ottimale in tutte le condizioni meteo.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81ad-ae1f-ffe512b34b45","p