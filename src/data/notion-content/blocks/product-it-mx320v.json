[{"object":"block","id":"38034d6d-7cea-81f6-a4ad-cbbf3eae4db3","parent":{"type":"page_id","page_id":"38034d6d-7cea-81ab-82ff-cae676a38325"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX320V è lo pneumatico per asse trattivo di MAXAM destinato ai servizi misti progettato per le applicazioni più impegnative. Grazie al battistrada da 230mm, che favorisce stabilità e consumo uniforme, l'MX320V offre massima durevolezza per le impegnative applicazioni caratterizzate da un alto grado di attrito. Il disegno dei tasselli offre il giusto equilibro tra trazione e usura su diverse superfici, assicurando versatilità in diversi ambienti. Grazie alla mescola rinforzata resistente all'abrasione, questo pneumatico vanta una bassa resistenza al rotolamento e una resistenza ai tagli, alla frammentazione e all'abrasione senza eguali. L'MX320V è progettato per applicazioni di trasporto merci per servizio misto locale e regionale. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX320V è lo pneumatico per asse trattivo di MAXAM destinato ai servizi misti progettato per le applicazioni più impegnative. Grazie al battistrada da 230mm, che favorisce stabilità e consumo uniforme, l'MX320V offre massima durevolezza per le impegnative applicazioni caratterizzate da un alto grado di attrito. Il disegno dei tasselli offre il giusto equilibro tra trazione e usura su diverse superfici, assicurando versatilità in diversi ambienti. Grazie alla mescola rinforzata resistente all'abrasione, questo pneumatico vanta una bassa resistenza al rotolamento e una resistenza ai tagli, alla frammentazione e all'abrasione senza eguali. L'MX320V è progettato per applicazioni di trasporto merci per servizio misto locale e regionale. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81e7-8ff0-e43521f86054","parent":{"type":"page_id","page_id":"38034d6d-7cea-81ab-82ff-cae676a38325"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81fc-b5e9-d34dda452ca9","parent":{"type":"page_id","page_id":"38034d6d-7cea-81ab-82ff-cae676a38325"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Il design a spalla aperta assicura un'aderenza ottimale in tutte le condizioni meteo su tutte le superfici.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Il design a spalla aperta assicura un'aderenza ottimale in tutte le condizioni meteo su tutte le superfici.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8137-bf25-cb36cf65ce23","parent":{"type":"pa