[{"object":"block","id":"38034d6d-7cea-81e2-ae42-cb900c29c47e","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cb-838b-d0dedf5cf6a4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"L'MX325V è lo pneumatico per asse trattivo di MAXAM destinato al servizio misto, progettato per le applicazioni più impegnative. Grazie alla notevole profondità del battistrada di 32/32\"\", offre il giusto equilibrio tra trazione e usura, assicurando affidabilità nelle più impegnative applicazioni di utilizzo. Il battistrada da 230 mm favorisce la stabilità e il consumo uniforme, prolungando la durevolezza dello pneumatico. Grazie alle speciali mescole del battistrada destinate a impieghi intensivi, l'MX325 è caratterizzato da una resistenza ottimale ai tagli, alla frammentazione e all'abrasione. L'MX325V è progettato per applicazioni di trasporto merci per servizi misti locali e regionali. Disponibile solo in Nord America","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"L'MX325V è lo pneumatico per asse trattivo di MAXAM destinato al servizio misto, progettato per le applicazioni più impegnative. Grazie alla notevole profondità del battistrada di 32/32\"\", offre il giusto equilibrio tra trazione e usura, assicurando affidabilità nelle più impegnative applicazioni di utilizzo. Il battistrada da 230 mm favorisce la stabilità e il consumo uniforme, prolungando la durevolezza dello pneumatico. Grazie alle speciali mescole del battistrada destinate a impieghi intensivi, l'MX325 è caratterizzato da una resistenza ottimale ai tagli, alla frammentazione e all'abrasione. L'MX325V è progettato per applicazioni di trasporto merci per servizi misti locali e regionali. Disponibile solo in Nord America","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81e0-9644-db51420db0d9","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cb-838b-d0dedf5cf6a4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8188-b67e-f896386529b8","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cb-838b-d0dedf5cf6a4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Il design a spalla aperta assicura la massima aderenza anche su terreni cedevoli.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Il design a spalla aperta assicura la massima aderenza anche su terreni cedevoli.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-816f-930e-c5755fd5ca48","parent":{"type":"page_id","page_id":"38034d6d-7cea-81cb-838b-d0dedf5cf6a4"},"created_time":"2026-06-15T15:14:00.000Z","last_edited_time":"2026-06-15T15:14: