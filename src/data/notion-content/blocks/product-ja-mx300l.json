[{"object":"block","id":"38034d6d-7cea-8167-9810-ebc636799237","parent":{"type":"page_id","page_id":"38034d6d-7cea-810b-9871-f1139ebc40f6"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX300Lは、EcoPoint 3 ゴム配合技術を採用した、MAXAMの高品質な長距離輸送用ドライブタイヤです。EcoPoint 3 ゴム配合技術により、走行距離、燃費、ウェットトラクションを徹底して最適化しています。 30/32インチという十分な深さと240 mmの幅のトレッドにより、並外れた走行距離性能と摩耗の均一化を実現し、リトレッドタイヤとしての利用にも適しています。クローズドショルダー設計により、重量とトルクの配分を均等化し、並外れた安定性とハンドリング性能を実現しました。 MX300Lは高速道路における長距離輸送や地域輸送の用途に最適です。","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX300Lは、EcoPoint 3 ゴム配合技術を採用した、MAXAMの高品質な長距離輸送用ドライブタイヤです。EcoPoint 3 ゴム配合技術により、走行距離、燃費、ウェットトラクションを徹底して最適化しています。 30/32インチという十分な深さと240 mmの幅のトレッドにより、並外れた走行距離性能と摩耗の均一化を実現し、リトレッドタイヤとしての利用にも適しています。クローズドショルダー設計により、重量とトルクの配分を均等化し、並外れた安定性とハンドリング性能を実現しました。 MX300Lは高速道路における長距離輸送や地域輸送の用途に最適です。","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8151-9dde-e150a75c1bb2","parent":{"type":"page_id","page_id":"38034d6d-7cea-810b-9871-f1139ebc40f6"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false}