[{"object":"block","id":"38034d6d-7cea-815c-af75-e89330f64e9d","parent":{"type":"page_id","page_id":"38034d6d-7cea-81e6-9ede-e83d593d4e69"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX310Rは、 EcoPoint 3 を採用したMAXAMの地域輸送用ドライブタイヤです。 EcoPoint 3 ゴム配合技術により、走行距離、燃費、ウェットトラクションを徹底して最適化しています。 MX310Rは、トラクションと走行距離性能のバランスが取れたラグパターンを持ち、さまざまな用途に対応します。230 mmのトレッド幅で安定性に優れ、摩耗の均一化を促進してタイヤ寿命を延ばします。オープンショルダー設計によりトラクションを強化し、あらゆる環境や過酷な気象条件における信頼性を実現しました。 MX310Rはオンハイウェイの地域輸送および地方輸送用途向けに設計されています。 北米でのみ利用可能","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX310Rは、 EcoPoint 3 を採用したMAXAMの地域輸送用ドライブタイヤです。 EcoPoint 3 ゴム配合技術により、走行距離、燃費、ウェットトラクションを徹底して最適化しています。 MX310Rは、トラクションと走行距離性能のバランスが取れたラグパターンを持ち、さまざまな用途に対応します。230 mmのトレッド幅で安定性に優れ、摩耗の均一化を促進してタイヤ寿命を延ばします。オープンショルダー設計によりトラクションを強化し、あらゆる環境や過酷な気象条件における信頼性を実現しました。 MX310Rはオンハイウェイの地域輸送および地方輸送用途向けに設計されています。 北米でのみ利用可能","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-819d-acd7-dfcc4663d080","parent":{"type":"page_id","page_id":"38034d6d-7cea-81e6-9ede-e83d593d4e69"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleab