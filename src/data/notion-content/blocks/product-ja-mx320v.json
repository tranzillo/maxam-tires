[{"object":"block","id":"38034d6d-7cea-8116-ac38-d4a7beb909c3","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c1-81b0-ecfe9a48b188"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX320Vは過酷な混合サービス用途向けに設計された、MAXAMの混合サービス用ドライブタイヤです。 230 mmのトレッド幅が安定性と摩耗の均一化を促進し、過酷な高摩擦用途で最高レベルの耐久性を発揮します。さまざまな路面でトラクションと摩耗のバランスに優れたラグパターンを持ち、多様な環境に対応します。強化された耐摩耗コンパウンドを採用して、転がり抵抗をさらに低減し、突出した耐切創性、耐チップ性、耐摩耗性を実現しました。 北米でのみ利用可能","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX320Vは過酷な混合サービス用途向けに設計された、MAXAMの混合サービス用ドライブタイヤです。 230 mmのトレッド幅が安定性と摩耗の均一化を促進し、過酷な高摩擦用途で最高レベルの耐久性を発揮します。さまざまな路面でトラクションと摩耗のバランスに優れたラグパターンを持ち、多様な環境に対応します。強化された耐摩耗コンパウンドを採用して、転がり抵抗をさらに低減し、突出した耐切創性、耐チップ性、耐摩耗性を実現しました。 北米でのみ利用可能","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-816f-81a8-d4f3b34c6aea","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c1-81b0-ecfe9a48b188"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8103-b677-f293cd275edb","parent":{"type":"page_id","page_id":"38034d6d-7cea-8