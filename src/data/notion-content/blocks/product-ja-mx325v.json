[{"object":"block","id":"38034d6d-7cea-8156-8333-c3c3f4923016","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c1-ae80-e6403b48a3d3"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX325VはMAXAMの混合サービス用ドライブタイヤです。混合サービス用途向けに設計されており、最も過酷な条件下でも使用できます。 32/32インチという十分な深さのトレッドにより、トラクションと摩耗のバランスに優れ、過酷な走行用途における信頼性を実現します。230 mmの深さのトレッドが安定性と摩耗の均一化を促進し、耐久性を強化しています。極めて丈夫な特殊トレッドコンパウンドにより、最大レベルの耐切創性、耐チップ性、耐摩耗性を発揮します。 MX325Vは混合サービスの地域輸送および地方輸送用途向けに設計されています。 北米でのみ利用可能","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX325VはMAXAMの混合サービス用ドライブタイヤです。混合サービス用途向けに設計されており、最も過酷な条件下でも使用できます。 32/32インチという十分な深さのトレッドにより、トラクションと摩耗のバランスに優れ、過酷な走行用途における信頼性を実現します。230 mmの深さのトレッドが安定性と摩耗の均一化を促進し、耐久性を強化しています。極めて丈夫な特殊トレッドコンパウンドにより、最大レベルの耐切創性、耐チップ性、耐摩耗性を発揮します。 MX325Vは混合サービスの地域輸送および地方輸送用途向けに設計されています。 北米でのみ利用可能","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8159-a8e1-d9708c0a824c","parent":{"type":"page_id","page_id":"38034d6d-7cea-81c1-ae80-e6403b48a3d3"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"bl