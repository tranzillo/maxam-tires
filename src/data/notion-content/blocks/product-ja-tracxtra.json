[{"object":"block","id":"38034d6d-7cea-8162-9667-ce2117d6bb93","parent":{"type":"page_id","page_id":"38034d6d-7cea-8145-9c7e-d2fe03c419b6"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MS971Rは、今日の多機能農業機械および建設機械の多様なニーズに応えるよう設計されています。様々な硬質路面や多様な土壌条件に対応できるよう設計されたMS971Rは、堅牢なケーシング構造とスチールベルト技術を採用し、均一な接地圧分散、転がり抵抗の低減、そして卓越したトラクションを実現します。耐久性と快適性を独自に融合させたMS971Rは、圃場、高速道路、そして過酷なオンロード・オフロードの作業環境において、最高のパフォーマンスを発揮します。","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MS971Rは、今日の多機能農業機械および建設機械の多様なニーズに応えるよう設計されています。様々な硬質路面や多様な土壌条件に対応できるよう設計されたMS971Rは、堅牢なケーシング構造とスチールベルト技術を採用し、均一な接地圧分散、転がり抵抗の低減、そして卓越したトラクションを実現します。耐久性と快適性を独自に融合させたMS971Rは、圃場、高速道路、そして過酷なオンロード・オフロードの作業環境において、最高のパフォーマンスを発揮します。","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-816a-8c9d-d4b597008eed","parent":{"type":"page_id","page_id":"38034d6d-7cea-8145-9c7e-d2fe03c419b6"},"created_time":"2026-06-15T15:16:00.000Z","last_edited_time":"2026-06-15T15:16:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81f0-a846-e8de65e997a7","parent":{"type":"page_id","page_id":"38034d6d-7cea-8