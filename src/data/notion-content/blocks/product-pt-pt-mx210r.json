[{"object":"block","id":"38034d6d-7cea-81a2-b276-d0f8a6670fbd","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-84c4-c731fc967744"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"O MX210R, com a nossa tecnologia proprietária de composto EcoPoint3, é a sua melhor escolha para pneus regionais. A tecnologia do composto EcoPoint3 eleva a eficiência a novos patamares, otimizando a quilometragem, a economia de combustível e a tração em piso molhado sem compromissos. Com uma profundidade de piso substancial de 20/32\", o MX210R proporciona uma quilometragem excecional, prometendo uma durabilidade sem paralelo. O seu design com nervuras de 230 mm de largura promove um desgaste uniforme e uma pegada sólida, garantindo fiabilidade na estrada. O MX210R foi também concebido com nervuras para uma excelente estabilidade e manuseamento em condições de chuva. O MX210R é mais adequado para aplicações de entrega regional e local em auto-estrada. Disponível apenas na América do Norte","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"O MX210R, com a nossa tecnologia proprietária de composto EcoPoint3, é a sua melhor escolha para pneus regionais. A tecnologia do composto EcoPoint3 eleva a eficiência a novos patamares, otimizando a quilometragem, a economia de combustível e a tração em piso molhado sem compromissos. Com uma profundidade de piso substancial de 20/32\", o MX210R proporciona uma quilometragem excecional, prometendo uma durabilidade sem paralelo. O seu design com nervuras de 230 mm de largura promove um desgaste uniforme e uma pegada sólida, garantindo fiabilidade na estrada. O MX210R foi também concebido com nervuras para uma excelente estabilidade e manuseamento em condições de chuva. O MX210R é mais adequado para aplicações de entrega regional e local em auto-estrada. Disponível apenas na América do Norte","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8171-9159-c5ddfbd88f2e","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-84c4-c731fc967744"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8126-9b54-c3cc0ddf6f24","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-84c4-c731fc967744"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"As micro-lamelas melhoram a tração em piso molhado e minimizam o desgaste irregular.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"As micro-lamelas melhoram a tração em piso molhado e minimizam o desgaste irregular.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-813a-b300-ce5f69e183c7","parent":{"type"