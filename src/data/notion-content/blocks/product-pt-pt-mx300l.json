[{"object":"block","id":"38034d6d-7cea-81b1-b99c-f690159e3604","parent":{"type":"page_id","page_id":"38034d6d-7cea-8182-91a2-e088807f6abe"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"O MX300L é o pneu de linha de transporte premium da MAXAM, concebido com a tecnologia de composto EcoPoint 3 . A tecnologia do composto EcoPoint 3 otimiza a quilometragem, a economia de combustível e a tração em piso molhado sem compromissos. O MX300L apresenta uma profundidade do piso substancial de 30/32\" e uma largura do piso de 240 mm para uma quilometragem excecional e um desgaste uniforme, proporcionando uma base sólida para a recauchutagem. O seu design de ombro fechado assegura uma distribuição uniforme do peso e do binário para uma estabilidade e um manuseamento excecionais. O MX300L é mais adequado para aplicações de linha de transporte rodoviário e regionais. Disponível apenas na América do Norte","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"O MX300L é o pneu de linha de transporte premium da MAXAM, concebido com a tecnologia de composto EcoPoint 3 . A tecnologia do composto EcoPoint 3 otimiza a quilometragem, a economia de combustível e a tração em piso molhado sem compromissos. O MX300L apresenta uma profundidade do piso substancial de 30/32\" e uma largura do piso de 240 mm para uma quilometragem excecional e um desgaste uniforme, proporcionando uma base sólida para a recauchutagem. O seu design de ombro fechado assegura uma distribuição uniforme do peso e do binário para uma estabilidade e um manuseamento excecionais. O MX300L é mais adequado para aplicações de linha de transporte rodoviário e regionais. Disponível apenas na América do Norte","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8165-b411-df06ded75a4f","parent":{"type":"page_id","page_id":"38034d6d-7cea-8182-91a2-e088807f6abe"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-817f-8271-ebafe516b61c","parent":{"type":"page_id","page_id":"38034d6d-7cea-8182-91a2-e088807f6abe"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Os ombros sólidos proporcionam estabilidade, excelente manuseamento e maior quilometragem.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Os ombros sólidos proporcionam estabilidade, excelente manuseamento e maior quilometragem.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-813d-8f8a-c3ed7bac4d5a","parent":{"type":"page_id","page_id":"38034d6d-7cea-8182-91a2-e088807f6abe"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","crea