[{"object":"block","id":"38034d6d-7cea-81b7-a376-d3f447c58427","parent":{"type":"page_id","page_id":"38034d6d-7cea-8181-bea3-c9fe2219487a"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"O MX320V é o pneu para serviço misto da MAXAM, concebido para aplicações severas de serviço misto. Com uma largura do piso de 230 mm que promove a estabilidade e um desgaste uniforme, o MX320V oferece a máxima durabilidade para os rigores das aplicações de elevada abrasão. O seu padrão de ressaltos estabelece um equilíbrio entre a tração e o desgaste em várias superfícies, proporcionando versatilidade em diferentes ambientes. Com o seu composto reforçado resistente à abrasão, este pneu apresenta uma baixa resistência ao rolamento e um desempenho inigualável em termos de resistência a cortes, lascas e abrasão. O MX320V foi concebido para aplicações de serviço misto de entrega regional e local. Disponível apenas na América do Norte","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"O MX320V é o pneu para serviço misto da MAXAM, concebido para aplicações severas de serviço misto. Com uma largura do piso de 230 mm que promove a estabilidade e um desgaste uniforme, o MX320V oferece a máxima durabilidade para os rigores das aplicações de elevada abrasão. O seu padrão de ressaltos estabelece um equilíbrio entre a tração e o desgaste em várias superfícies, proporcionando versatilidade em diferentes ambientes. Com o seu composto reforçado resistente à abrasão, este pneu apresenta uma baixa resistência ao rolamento e um desempenho inigualável em termos de resistência a cortes, lascas e abrasão. O MX320V foi concebido para aplicações de serviço misto de entrega regional e local. Disponível apenas na América do Norte","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81cc-8526-d7620c96ef01","parent":{"type":"page_id","page_id":"38034d6d-7cea-8181-bea3-c9fe2219487a"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81d4-98ce-c8f15602113d","parent":{"type":"page_id","page_id":"38034d6d-7cea-8181-bea3-c9fe2219487a"},"created_time":"2026-06-15T15:18:00.000Z","last_edited_time":"2026-06-15T15:18:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"O design de ombros abertos proporciona uma tração melhorada para todas as condições climatéricas.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"O design de ombros abertos proporciona uma tração melhorada para todas as condições climatéricas.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81c9-acde-e00a80132dab","parent":{"type":"page_id","page_id":"38034d6d-7cea-8181-bea3-c9fe2219487a"},"created_time":"2026-06-15T15:18:00