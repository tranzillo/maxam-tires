[{"object":"block","id":"38034d6d-7cea-8150-9c98-e869644620f0","parent":{"type":"page_id","page_id":"38034d6d-7cea-81a4-aae9-d85627c8b641"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX200L – это премиальные шины MAXAM для передней оси для магистральных перевозок, которые используют фирменную технологию приготовления состава резины EcoPoint 3 . EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без ущерба для производительности, задавая новые стандарты для применения в дальнемагистральных перевозках. Сконструированная с отделяющей канавкой и пятью широкими ребрами, эта премиальная шина предлагает беспрецедентный контроль и комфорт. Протекторы MX200L также оснащены микропрорезями для минимизирования неправильного износа и повышения боковой тяги на мокром покрытии, обеспечивая надежность и безопасность в каждой поездке. MX200L лучше всего подходят для дальнемагистральных перевозок. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX200L – это премиальные шины MAXAM для передней оси для магистральных перевозок, которые используют фирменную технологию приготовления состава резины EcoPoint 3 . EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без ущерба для производительности, задавая новые стандарты для применения в дальнемагистральных перевозках. Сконструированная с отделяющей канавкой и пятью широкими ребрами, эта премиальная шина предлагает беспрецедентный контроль и комфорт. Протекторы MX200L также оснащены микропрорезями для минимизирования неправильного износа и повышения боковой тяги на мокром покрытии, обеспечивая надежность и безопасность в каждой поездке. MX200L лучше всего подходят для дальнемагистральных перевозок. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81d1-99cd-df7fcbdb0ea9","parent":{"type":"page_id","page_id":"38034d6d-7cea-81a4-aae9-d85627c8b641"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8188-b34c-eff46abc66b0","parent":{"type":"page_id","page_id":"38034d6d-7cea-81a4-aae9-d85627c8b641"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Микропрорези обеспечивают тягу на мокрой дороге и минимизируют неправильный износ.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Микропрорези обеспечивают тягу на мокрой дороге и минимизируют неправильный износ.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8163-a3a4-c46457e0b136","parent":{"type":"page_id","page_id":"38034d6d-7cea-81a4-aae9-d85627c8b641"},"