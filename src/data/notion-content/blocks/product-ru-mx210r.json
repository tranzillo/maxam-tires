[{"object":"block","id":"38034d6d-7cea-81a4-b27e-dfb2cf5e17f3","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-9fb8-e7b1783e8010"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX210R, использующие нашу фирменную технологию приготовления состава резины EcoPoint 3 – это ваш идеальный выбор шин передней оси для региональных перевозок. Технология приготовления состава резины EcoPoint 3 переводит эффективность на новые уровни, оптимизируя пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Существенная глубина протектора 20/32\"\" позволяет MX210R достигать исключительного пробега, обещая беспрецедентную долговечность. Протектор с ребристым рисунком шириной 230-мм обеспечивает равномерный износ и твердый отпечаток, гарантируя надежность при движении. MX210R также разработаны с ребрами для обеспечения идеальной стабильности и управляемости в мокрых условиях. MX210R лучше всего подходят для применения в региональных и локальных доставках по автострадам. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX210R, использующие нашу фирменную технологию приготовления состава резины EcoPoint 3 – это ваш идеальный выбор шин передней оси для региональных перевозок. Технология приготовления состава резины EcoPoint 3 переводит эффективность на новые уровни, оптимизируя пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Существенная глубина протектора 20/32\"\" позволяет MX210R достигать исключительного пробега, обещая беспрецедентную долговечность. Протектор с ребристым рисунком шириной 230-мм обеспечивает равномерный износ и твердый отпечаток, гарантируя надежность при движении. MX210R также разработаны с ребрами для обеспечения идеальной стабильности и управляемости в мокрых условиях. MX210R лучше всего подходят для применения в региональных и локальных доставках по автострадам. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81e7-b4df-e0bff8266f69","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-9fb8-e7b1783e8010"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8101-a405-d01985387860","parent":{"type":"page_id","page_id":"38034d6d-7cea-810c-9fb8-e7b1783e8010"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Микропрорези обеспечивают тягу на мокрой дороге и минимизируют неправильный износ .","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Микропрорези обеспечивают тягу на мокрой дороге и минимизируют неправильный износ .","href":null}],"color":"defa