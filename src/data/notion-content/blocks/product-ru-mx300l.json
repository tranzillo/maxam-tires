[{"object":"block","id":"38034d6d-7cea-8123-acff-ddfb96d5acf2","parent":{"type":"page_id","page_id":"38034d6d-7cea-819f-aac2-fc481bf4a069"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX300L – это премиальные линейные шины ведущего колеса MAXAM, разработанные с использованием фирменной технологии приготовления состава резины EcoPoint 3 . Технология приготовления состава резины EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Протекторы MX300L располагают существенной глубиной 30/32\"\" и шириной 240 мм для достижения исключительного пробега и равномерного износа, обеспечивая прочную основу для восстановления протектора. Замкнутая конструкция плеча обеспечивает равномерное распределение веса и крутящегося момента для достижения исключительной устойчивости и управления. Модель MX300L лучше всего подходит для автодорожных дальних перевозок и регионального применения. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX300L – это премиальные линейные шины ведущего колеса MAXAM, разработанные с использованием фирменной технологии приготовления состава резины EcoPoint 3 . Технология приготовления состава резины EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Протекторы MX300L располагают существенной глубиной 30/32\"\" и шириной 240 мм для достижения исключительного пробега и равномерного износа, обеспечивая прочную основу для восстановления протектора. Замкнутая конструкция плеча обеспечивает равномерное распределение веса и крутящегося момента для достижения исключительной устойчивости и управления. Модель MX300L лучше всего подходит для автодорожных дальних перевозок и регионального применения. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8135-b033-f96fa0f41799","parent":{"type":"page_id","page_id":"38034d6d-7cea-819f-aac2-fc481bf4a069"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8160-8792-db00e80c8686","parent":{"type":"page_id","page_id":"38034d6d-7cea-819f-aac2-fc481bf4a069"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Цельные плечи обеспечивают устойчивость, отличную управляемость и увеличенный пробег.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Цельные плечи обеспечивают устойчивость, отличную управляемость и увеличенный пробег.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81aa-be2e-f2da6426fdfb","parent":{"type":"page_id","page_id":"38