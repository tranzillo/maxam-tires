[{"object":"block","id":"38034d6d-7cea-81c4-b594-e4a1b8598ef6","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b2-8dbc-cf2232c6259f"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX310R — это региональные шины ведущего колеса MAXAM, разработанные с использованием EcoPoint 3 . Технология приготовления состава резины EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Уравновешивая тягу и пробег, рисунок грунтозацепов протектора MX310R предусматривает различные применения. Ширина протектора 230мм обеспечивает устойчивость и равномерный износ для продления срока эксплуатации шин. Открытая конструкция плеча позволяет этой шине обеспечивать повышенную тягу, что делает ее надежной в любой среде и экстремальных погодных условиях. MX310R разработаны для применения в региональных и локальных доставках по автострадам. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX310R — это региональные шины ведущего колеса MAXAM, разработанные с использованием EcoPoint 3 . Технология приготовления состава резины EcoPoint 3 оптимизирует пробег, экономию топлива и сцепление с мокрой дорогой без необходимости компромисса. Уравновешивая тягу и пробег, рисунок грунтозацепов протектора MX310R предусматривает различные применения. Ширина протектора 230мм обеспечивает устойчивость и равномерный износ для продления срока эксплуатации шин. Открытая конструкция плеча позволяет этой шине обеспечивать повышенную тягу, что делает ее надежной в любой среде и экстремальных погодных условиях. MX310R разработаны для применения в региональных и локальных доставках по автострадам. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8199-8fce-e38ba5e60918","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b2-8dbc-cf2232c6259f"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8177-af56-f2f2d161174e","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b2-8dbc-cf2232c6259f"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Открытая конструкция плеча позволяет обеспечивать повышенную тягу в любых погодных условиях.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Открытая конструкция плеча позволяет обеспечивать повышенную тягу в любых погодных условиях.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81be-86d0-c9167f11032e","parent":{"type":"page_id","page_id":"38034d6d-7cea-81b2-8dbc-cf2232c6259f"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time