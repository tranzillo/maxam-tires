[{"object":"block","id":"38034d6d-7cea-8116-a6cf-cf6340bd7ee5","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-8951-df0981001c2c"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX320V – это шина ведущего колеса для смешанного обслуживания, разработанная для тяжелых условий смешанного применения. Ширина протектора 230мм способствует повышению устойчивости и равномерному износу, позволяя шинам MX320V обеспечивать максимальную долговечность для суровых условий высокоинтенсивного применения. Рисунок грунтозацепов протектора создает баланс между тягой и износом на разных поверхностях, обеспечивая универсальность в различных средах. Усиленный устойчивый к износу состав резины позволяет этим шинам обеспечивать низкое сопротивление качению, непревзойденную производительность и устойчивость к порезам, сколам и износу. MX320V разработаны для применения в региональных и локальных доставках со смешанным обслуживанием. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX320V – это шина ведущего колеса для смешанного обслуживания, разработанная для тяжелых условий смешанного применения. Ширина протектора 230мм способствует повышению устойчивости и равномерному износу, позволяя шинам MX320V обеспечивать максимальную долговечность для суровых условий высокоинтенсивного применения. Рисунок грунтозацепов протектора создает баланс между тягой и износом на разных поверхностях, обеспечивая универсальность в различных средах. Усиленный устойчивый к износу состав резины позволяет этим шинам обеспечивать низкое сопротивление качению, непревзойденную производительность и устойчивость к порезам, сколам и износу. MX320V разработаны для применения в региональных и локальных доставках со смешанным обслуживанием. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-817e-8330-e60fc151226c","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-8951-df0981001c2c"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81a9-abf8-f756bfe035d7","parent":{"type":"page_id","page_id":"38034d6d-7cea-818b-8951-df0981001c2c"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Открытая конструкция плеча позволяет обеспечивать повышенную тягу на поверхности в любых погодных условиях.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Открытая конструкция плеча позволяет обеспечивать повышенную тягу на поверхности в любых погодных условиях.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81cf-bf3e-f925571a116f","parent":{"type"