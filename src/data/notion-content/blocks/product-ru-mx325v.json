[{"object":"block","id":"38034d6d-7cea-8135-b7d3-dca012f90af7","parent":{"type":"page_id","page_id":"38034d6d-7cea-81df-b1dc-ffb4afcb27da"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX325V – это шина ведущего колеса для смешанного обслуживания, разработанная для условий смешанного применения даже в самых суровых условиях. Значительная глубина протектора 32/32\"\" способствует уравновешиванию тяги и износа, обеспечивая надежность в тяжелых условиях эксплуатации. Ширина протектора 230 мм обеспечивает устойчивость и равномерный износ для увеличения долговечности. Благодаря специальному усиленному составу резины протектора шины MX325 обеспечивают максимальную устойчивость к порезам, сколам и износу. MX325V разработаны для применения в региональных и локальных доставках со смешанным обслуживанием. Доступно только в Северной Америке","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX325V – это шина ведущего колеса для смешанного обслуживания, разработанная для условий смешанного применения даже в самых суровых условиях. Значительная глубина протектора 32/32\"\" способствует уравновешиванию тяги и износа, обеспечивая надежность в тяжелых условиях эксплуатации. Ширина протектора 230 мм обеспечивает устойчивость и равномерный износ для увеличения долговечности. Благодаря специальному усиленному составу резины протектора шины MX325 обеспечивают максимальную устойчивость к порезам, сколам и износу. MX325V разработаны для применения в региональных и локальных доставках со смешанным обслуживанием. Доступно только в Северной Америке","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8151-bb13-e8ade6bece0b","parent":{"type":"page_id","page_id":"38034d6d-7cea-81df-b1dc-ffb4afcb27da"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"Features","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Features","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-81a8-ada3-e1e69be78509","parent":{"type":"page_id","page_id":"38034d6d-7cea-81df-b1dc-ffb4afcb27da"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"bulleted_list_item","bulleted_list_item":{"rich_text":[{"type":"text","text":{"content":"Открытая конструкция плеча обеспечивает максимальную тягу даже на мягком грунте.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"Открытая конструкция плеча обеспечивает максимальную тягу даже на мягком грунте.","href":null}],"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-8168-ad9c-c82ef6908444","parent":{"type":"page_id","page_id":"38034d6d-7cea-81df-b1dc-ffb4afcb27da"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc