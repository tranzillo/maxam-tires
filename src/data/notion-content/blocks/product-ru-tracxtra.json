[{"object":"block","id":"38034d6d-7cea-81c0-9e00-e8d5bd417ab1","parent":{"type":"page_id","page_id":"38034d6d-7cea-816a-8cbd-e9af26a8b3ff"},"created_time":"2026-06-15T15:20:00.000Z","last_edited_time":"2026-06-15T15:20:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MS971R разработан с учётом разнообразных требований к современной многофункциональной сельскохозяйственной и подрядной технике. MS971R, предназначенный для работы на самых разных типах твёрдых поверхностей и грунтов, отличается прочным корпусом и стальным ремнём, обеспечивающим равномерное распределение давления на грунт, сниженное сопротивление качению и исключительное сцепление. Уникальное сочетание прочности и комфорта MS971R обеспечивает максимальную производительность в поле, на шоссе и в сложных условиях эксплуатации как на дорогах, так и на бездорожье.","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MS971R разработан с учётом разнообразных требований к современной многофункциональной сельскохозяйственной и подрядной технике. MS971R, предназначенный для работы на самых разных типах твёрдых поверхностей и грунтов, отличается прочным корпусом и стальным ремнём, обеспечивающим равномерное распределение давления на грунт, сниженное сопротивление качению и исключительное сцепление. Уникальное сочетание прочности и комфорта MS971R обеспечивает максимальную производительность в поле, на шоссе и в сложных условиях эксплуатации как на дорогах, так и на бездорожье.","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"38034d6d-7cea-811c-9ff2-c49853baf2e8","parent":{"type":"page_id","page_id":"38034d6d-7cea-816a-8cbd-e9af26a8b3ff"},"created_time":"2026-06