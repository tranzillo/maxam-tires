[{"object":"block","id":"35534d6d-7cea-81ea-a53d-c9d752f9200b","parent":{"type":"page_id","page_id":"35534d6d-7cea-81ef-b310-c4e54ecdbd43"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX100L 是 MAXAM 的长途公路运输挂车轮胎，采用 EcoPoint 3 复合材料技术。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 这款轮胎采用独特的竖纹设计，还带有微型胎纹沟和去耦槽，可最大限度地减少不规则磨损，增加耐用性并提升行驶里程。 MX100L 最适合公路单轴或串联轴车辆长途运输应用场景。 仅在北美发售","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX100L 是 MAXAM 的长途公路运输挂车轮胎，采用 EcoPoint 3 复合材料技术。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 这款轮胎采用独特的竖纹设计，还带有微型胎纹沟和去耦槽，可最大限度地减少不规则磨损，增加耐用性并提升行驶里程。 MX100L 最适合公路单轴或串联轴车辆长途运输应用场景。 仅在北美发售","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-819e-bd64-e33a341f3f9d","parent":{"type":"page_id","page_id":"35534d6d-7cea-81ef-b310-c4e54ecdbd43"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"特點","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"特點","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-811d-adc0-d7d55d70c311","parent":{"type":"page_id","page_id":"35534d6d-7cea-81ef-b310-c4e54ecdbd43"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_tim