[{"object":"block","id":"35534d6d-7cea-818b-acfe-e54aa373eecd","parent":{"type":"page_id","page_id":"35534d6d-7cea-8199-9c30-f4f99ef1cce3"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX200L 是 MAXAM 的优质长途运输转向轮胎，采用我们专有的 EcoPoint 3 复合材料。EcoPoint 3 可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力，进而为长途运输应用场景树立新的标准。 这款优质轮胎设计带有去耦槽和五条宽大竖纹，可提供无与伦比的操控性和舒适性。MX200L 还带有微型胎纹沟，可最大限度地减少不规则磨损，并增强潮湿条件下的侧向牵引力，可在每次行驶中提供可靠性和安全性。 MX200L 最适合公路长途运输应用场景。 仅在北美发售","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX200L 是 MAXAM 的优质长途运输转向轮胎，采用我们专有的 EcoPoint 3 复合材料。EcoPoint 3 可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力，进而为长途运输应用场景树立新的标准。 这款优质轮胎设计带有去耦槽和五条宽大竖纹，可提供无与伦比的操控性和舒适性。MX200L 还带有微型胎纹沟，可最大限度地减少不规则磨损，并增强潮湿条件下的侧向牵引力，可在每次行驶中提供可靠性和安全性。 MX200L 最适合公路长途运输应用场景。 仅在北美发售","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8155-88e0-cd10901e5bab","parent":{"type":"page_id","page_id":"35534d6d-7cea-8199-9c30-f4f99ef1cce3"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"特點","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"特點","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81c2-a741-fef84b5ef863","parent":{"type":"page_id","pag