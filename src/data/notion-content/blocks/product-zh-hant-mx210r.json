[{"object":"block","id":"35534d6d-7cea-8137-9d00-c093a28e8e97","parent":{"type":"page_id","page_id":"35534d6d-7cea-817c-b2b4-ddfa2311f25b"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX210R 采用我们专有的 EcoPoint 3 复合材料技术，是区域运输应用场景下最佳的转向轮胎选择。EcoPoint 3 复合材料技术可将运输效率提升到新的高度，在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX210R 具备 20/32 英寸超深胎纹深度，可提供出色的行驶里程，并具有无与伦比的耐用性。这款轮胎采用 230 毫米竖纹设计，可提供良好的磨损均匀性和稳固的抓地力，进而确保在路上行驶时的可靠性。MX210R 还采用了竖纹设计，可在潮湿条件下提供出色的稳定性和操控性。 MX210R 最适合公路区域运输和本地运输应用场景。 仅在北美发售","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX210R 采用我们专有的 EcoPoint 3 复合材料技术，是区域运输应用场景下最佳的转向轮胎选择。EcoPoint 3 复合材料技术可将运输效率提升到新的高度，在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX210R 具备 20/32 英寸超深胎纹深度，可提供出色的行驶里程，并具有无与伦比的耐用性。这款轮胎采用 230 毫米竖纹设计，可提供良好的磨损均匀性和稳固的抓地力，进而确保在路上行驶时的可靠性。MX210R 还采用了竖纹设计，可在潮湿条件下提供出色的稳定性和操控性。 MX210R 最适合公路区域运输和本地运输应用场景。 仅在北美发售","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8163-ad6d-c3fba598f8b7","parent":{"type":"page_id","page_id":"35534d6d-7cea-817c-b2b4-ddfa2311f25b"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"特點","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"特點","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"o