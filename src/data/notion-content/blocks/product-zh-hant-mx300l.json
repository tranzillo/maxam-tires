[{"object":"block","id":"35534d6d-7cea-81f5-aefc-c2f70f54cffd","parent":{"type":"page_id","page_id":"35534d6d-7cea-8167-af77-f2b573aa2f6d"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX300L 是 MAXAM 的优质长途运输驱动轮胎，采用 EcoPoint 3 复合材料技术。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX300L 拥有 30/32 英寸超深胎纹深度和 240 毫米的胎纹宽度，可提供出色的行驶里程和磨损均匀性，进而为胎纹翻新提供坚实的基础。其封闭式胎肩设计可以确保均匀的重量和扭矩分配，以实现卓越的稳定性和处理性能。 MX300L 最适合公路长途运输和区域运输应用场景。 仅在北美发售","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX300L 是 MAXAM 的优质长途运输驱动轮胎，采用 EcoPoint 3 复合材料技术。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX300L 拥有 30/32 英寸超深胎纹深度和 240 毫米的胎纹宽度，可提供出色的行驶里程和磨损均匀性，进而为胎纹翻新提供坚实的基础。其封闭式胎肩设计可以确保均匀的重量和扭矩分配，以实现卓越的稳定性和处理性能。 MX300L 最适合公路长途运输和区域运输应用场景。 仅在北美发售","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-81f1-926a-f56989394a7b","parent":{"type":"page_id","page_id":"35534d6d-7cea-8167-af77-f2b573aa2f6d"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"特點","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"特點","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8141-b1ad-fbc96e8c8692","parent":{"type":"page_id","page_