[{"object":"block","id":"35534d6d-7cea-81dd-a9e3-cd2abe47ced3","parent":{"type":"page_id","page_id":"35534d6d-7cea-8166-9534-f336cc36509f"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"paragraph","paragraph":{"rich_text":[{"type":"text","text":{"content":"MX310R 是 MAXAM 采用 EcoPoint 3 复合材料技术的一款区域运输驱动轮胎。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX310R 采用横纹设计，可在牵引力和行驶里程之间实现平衡，适应多种应用场景。其 230 毫米的胎纹宽度可提供稳定性并提高磨损均匀性，进而延长轮胎寿命。这款轮胎采用开放式胎肩设计，可提供更大的牵引力，进而可以在任何环境和极端天气条件下实现理想的可靠性。 MX310R 专门用于公路区域运输和本地运输应用场景。 仅在北美发售","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"MX310R 是 MAXAM 采用 EcoPoint 3 复合材料技术的一款区域运输驱动轮胎。EcoPoint 3 复合材料技术可在不影响性能的情况下优化行驶里程、燃油经济性和湿地抓地力。 MX310R 采用横纹设计，可在牵引力和行驶里程之间实现平衡，适应多种应用场景。其 230 毫米的胎纹宽度可提供稳定性并提高磨损均匀性，进而延长轮胎寿命。这款轮胎采用开放式胎肩设计，可提供更大的牵引力，进而可以在任何环境和极端天气条件下实现理想的可靠性。 MX310R 专门用于公路区域运输和本地运输应用场景。 仅在北美发售","href":null}],"icon":null,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-8110-9aae-d68981207190","parent":{"type":"page_id","page_id":"35534d6d-7cea-8166-9534-f336cc36509f"},"created_time":"2026-05-03T20:58:00.000Z","last_edited_time":"2026-05-03T20:58:00.000Z","created_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"last_edited_by":{"object":"user","id":"35534d6d-7cea-8179-8809-002768bc44c3"},"has_children":false,"in_trash":false,"type":"heading_2","heading_2":{"rich_text":[{"type":"text","text":{"content":"特點","link":null},"annotations":{"bold":false,"italic":false,"strikethrough":false,"underline":false,"code":false,"color":"default"},"plain_text":"特點","href":null}],"is_toggleable":false,"color":"default"},"archived":false},{"object":"block","id":"35534d6d-7cea-811f-937a-c88156719