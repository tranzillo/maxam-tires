---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OfficeCard from '../../../components/ui/OfficeCard.astro';
import Field from '../../../components/ui/Field.astro';
import Input from '../../../components/ui/Input.astro';
import Select from '../../../components/ui/Select.astro';
import Textarea from '../../../components/ui/Textarea.astro';
import Button from '../../../components/ui/Button.astro';
import Plate from '../../../components/ui/Plate.astro';
import type { Locale, ContentLanguage } from '../../../types';
import { locales, t, contentLang } from '../../../lib/i18n';
import { getAllIndustries } from '../../../lib/data';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const industries = getAllIndustries(locale);
const lang = contentLang(locale);

// Office data extracted from WordPress (block-3-column-special).
// TODO (recovery phase 5): move offices to a Notion record; region names
// here are placeholders for the 7 newly-added languages (fall back to the
// English label) until that record exists.
const officeRegionNames: Record<string, Partial<Record<ContentLanguage, string>>> = {
  northAmerica: { en: 'North America', 'ar-ae': 'أمريكا الشمالية', 'zh-hant': '北美' },
  eu: { en: 'Maxam Tire EU', 'ar-ae': 'شركة Maxam للإطارات في الاتحاد الأوروبي', 'zh-hant': 'Maxam Tire（欧盟）' },
  amea: { en: 'Maxam Tire AMEA', 'ar-ae': 'شركة Maxam للإطارات في أفريقيا والشرق الأوسط وآسيا', 'zh-hant': 'Maxam Tire（亚洲、中東和非洲）' },
};
const regionName = (key: string) => officeRegionNames[key][lang] ?? officeRegionNames[key].en!;

const offices = [
  {
    region: regionName('northAmerica'),
    color: '#092479',
    company: 'MAXAM Tire North America Inc.',
    locations: [
      { label: '', address: '300 Rosewood Drive, Suite 102\nDanvers, MA 01923\nUnited States of America' },
      { label: 'Memphis', address: '5510 East Holmes Rd, Suite A\nMemphis, TN 38118' },
      { label: 'Los Angeles', address: '19119 South Reyes Avenue\nRancho Dominguez, CA 90221' },
      { label: 'Houston', address: '121 Esplanade Blvd\nHouston, TX 77060' },
    ],
    phones: ['+1 844-629-2662', '+1 978-560-0624'],
  },
  {
    region: regionName('eu'),
    color: '#0077c8',
    company: 'MAXAM International Limited',
    locations: [
      { label: '', address: 'Grosser Hasenpfad 30\nD-60598\nFrankfurt am Main\nGermany' },
    ],
    phones: ['+44 121 790 0505', '+44 121 767 1898'],
  },
  {
    region: regionName('amea'),
    color: '#1a1a1a',
    company: 'MAXAM Tire Solutions Co, Ltd',
    locations: [
      { label: '', address: 'EVE Building, No. 43\nZhengzhou Road,\nQingdao, China\n266000' },
      { label: '', address: 'Room 1911, Lee Garden One\n33 Hysan Avenue,\nCauseway Bay, Hong Kong' },
    ],
    phones: ['+86-532-66981649'],
  },
];
---

<BaseLayout locale={locale} title={t(locale, 'contact.title')}>
  <section class="contact-page">
    <!-- Page heading -->
    <div class="contact-page__heading">
      <h1 class="heading heading--lg">
        {t(locale, 'contact.heading')}
      </h1>
      <p class="contact-page__subheading heading heading--sm">
        {t(locale, 'contact.subheading')}
      </p>
    </div>

    <!-- Main: Offices + Form -->
    <div class="contact-page__layout">
      <!-- Left: Office locations -->
      <div class="contact-page__offices">
        <div class="contact-page__offices-label">
          <Plate as="h2" size="sm">{t(locale, 'contact.offices.heading')}</Plate>
        </div>
        <p class="contact-page__offices-intro">
          {t(locale, 'contact.offices.subheading')}
        </p>

        <div class="contact-page__offices-grid">
          {offices.map((office) => (
            <OfficeCard office={office} />
          ))}
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="contact-page__form-col">
        <div class="contact-form">
          <div class="contact-form__top">
            <h2 class="contact-form__title heading heading--md">
              {t(locale, 'product.get_in_touch')}
            </h2>
            <p class="contact-form__intro">
              {t(locale, 'contact.form_intro')}
            </p>
          </div>

          <form class="contact-form__body" data-static-form>
            <Field inputId="contact-name" label={t(locale, 'contact.form.name')} required>
              <Input id="contact-name" name="name" required autocomplete="name" />
            </Field>

            <Field inputId="contact-email" label={t(locale, 'contact.form.email')} required>
              <Input id="contact-email" type="email" name="email" required autocomplete="email" />
            </Field>

            <Field inputId="contact-phone" label={t(locale, 'contact.form.phone')}>
              <Input id="contact-phone" type="tel" name="phone" autocomplete="tel" />
            </Field>

            <Field inputId="contact-company" label={t(locale, 'contact.form.company')}>
              <Input id="contact-company" name="company" autocomplete="organization" />
            </Field>

            <Field inputId="contact-industry" label={t(locale, 'contact.form.industry')}>
              <Select id="contact-industry" name="industry">
                <option value="">{t(locale, 'contact.form.industry_placeholder')}</option>
                {industries.map((ind) => (
                  <option value={ind.slug}>{ind.name}</option>
                ))}
              </Select>
            </Field>

            <Field inputId="contact-message" label={t(locale, 'contact.form.message')} required>
              <Textarea id="contact-message" name="message" rows={4} required />
            </Field>

            <Button type="submit" variant="primary" size="lg" full>
              {t(locale, 'contact.form.submit')}
            </Button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
