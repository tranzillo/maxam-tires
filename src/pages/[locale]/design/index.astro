---
/**
 * Design system gallery — every component and inline pattern in one place.
 *
 * Gated by env var: only builds when MAXAM_SHOW_DESIGN_GALLERY=1 is set.
 * To view locally:  MAXAM_SHOW_DESIGN_GALLERY=1 npm run dev
 * Then open: http://localhost:4321/en/design/
 *
 * Adding a specimen: wrap markup in <Specimen name="..." status="...">.
 * Status badges: 'component' | 'inline' | 'missing' | 'inconsistent'.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Locale } from '../../../types';
import { locales } from '../../../lib/i18n';
import { getAllProducts, getAllArticles, getAllIndustries, getAllApplications } from '../../../lib/data';

import Specimen from '../../../components/design/Specimen.astro';
import ProductCard from '../../../components/ui/ProductCard.astro';
import ArticleCard from '../../../components/ui/ArticleCard.astro';
import FeaturedCard from '../../../components/ui/FeaturedCard.astro';
import IndustryCard from '../../../components/ui/IndustryCard.astro';
import IndustryBadge from '../../../components/ui/IndustryBadge.astro';
import Hero from '../../../components/ui/Hero.astro';
import Section from '../../../components/ui/Section.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import Grid from '../../../components/ui/Grid.astro';
import SpecTable from '../../../components/ui/SpecTable.astro';
import RubberProductCard from '../../../components/ui/RubberProductCard.astro';
import RubberHeader from '../../../components/global/RubberHeader.astro';
import MaxamLogo from '../../../components/ui/MaxamLogo.astro';
import RubberButton from '../../../components/ui/RubberButton.astro';
import RubberChip from '../../../components/ui/RubberChip.astro';
import RubberInput from '../../../components/ui/RubberInput.astro';
import RubberSelect from '../../../components/ui/RubberSelect.astro';
import RubberTextarea from '../../../components/ui/RubberTextarea.astro';
import RubberField from '../../../components/ui/RubberField.astro';
import RubberBreadcrumb from '../../../components/ui/RubberBreadcrumb.astro';
import RubberPlate from '../../../components/ui/RubberPlate.astro';
import RubberArticleCard from '../../../components/ui/RubberArticleCard.astro';
import RubberIndustryCard from '../../../components/ui/RubberIndustryCard.astro';
import RubberDocumentCard from '../../../components/ui/RubberDocumentCard.astro';
import RubberTestimonialCard from '../../../components/ui/RubberTestimonialCard.astro';
import RubberEventCard from '../../../components/ui/RubberEventCard.astro';
import { getAllRawDocuments, getAllTestimonials, getAllEvents } from '../../../lib/data';

export function getStaticPaths() {
  if (process.env.MAXAM_SHOW_DESIGN_GALLERY !== '1') return [];
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const sampleProducts = getAllProducts(locale).slice(0, 4);
const sampleArticles = getAllArticles(locale).slice(0, 4);
const sampleIndustries = getAllIndustries(locale).slice(0, 6);
const sampleApplications = getAllApplications(locale).slice(0, 6);
const sampleDocuments = getAllRawDocuments(locale).slice(0, 4);
const sampleTestimonials = getAllTestimonials(locale).slice(0, 3);
const sampleEvents = getAllEvents(locale).slice(0, 3);

const productsWithSpec = getAllProducts(locale).filter((p) => p.specTable && p.specTable.rows.length > 0);
const fallbackSpecTable = {
  headers: ['Size', 'LI/SR', 'Tread Depth', 'Max Load', 'Max Pressure'],
  rows: [
    ['10-16.5', '12 TL', '13.00 mm', '6400 lbs', '46 psi'],
    ['12-16.5', '14 TL', '14.50 mm', '7150 lbs', '51 psi'],
    ['14-17.5', '16 TL', '16.20 mm', '7850 lbs', '58 psi'],
  ],
};
const specTable = productsWithSpec[0]?.specTable ?? fallbackSpecTable;
const specColor = sampleIndustries[0]?.color ?? '#0077c8';

const brandColors = [
  { name: 'maxam-blue', value: '#0077c8' },
  { name: 'maxam-blue-dark', value: '#005a9e' },
  { name: 'maxam-black', value: '#1a1a1a' },
  { name: 'maxam-white', value: '#ffffff' },
];

const grayScale = [
  { name: 'gray-100', bg: 'bg-maxam-gray-100' },
  { name: 'gray-300', bg: 'bg-maxam-gray-300' },
  { name: 'gray-500', bg: 'bg-maxam-gray-500' },
  { name: 'gray-700', bg: 'bg-maxam-gray-700' },
  { name: 'gray-900', bg: 'bg-maxam-gray-900' },
];

const typeScale = [
  { cls: 'text-5xl font-bold', label: '5xl - Hero display' },
  { cls: 'text-4xl font-bold', label: '4xl - Page title' },
  { cls: 'text-3xl font-bold', label: '3xl - Section heading' },
  { cls: 'text-2xl font-bold', label: '2xl - Subsection' },
  { cls: 'text-xl font-bold', label: 'xl' },
  { cls: 'text-lg font-semibold', label: 'lg - Card title' },
  { cls: 'text-base', label: 'base - Body text' },
  { cls: 'text-sm text-maxam-gray-700', label: 'sm - Secondary' },
  { cls: 'text-xs text-maxam-gray-500', label: 'xs - Caption' },
];
---

<BaseLayout locale={locale} title="Design System Gallery">
  <article class="max-w-[var(--container-max)] mx-auto px-4 py-10 space-y-12">

    <header class="border-b border-maxam-gray-300 pb-6">
      <p class="text-xs font-semibold uppercase tracking-wider text-maxam-gray-500">
        Internal: design reference
      </p>
      <h1 class="text-3xl font-bold text-maxam-black mt-1">Design System Gallery</h1>
      <p class="text-maxam-gray-700 mt-3 max-w-3xl">
        Every component, inline pattern, and missing pattern in one page. Use this as the spec for
        the design pass. Status badges flag whether an item is a real component, only inline today,
        missing entirely, or visually inconsistent.
      </p>
      <p class="text-sm text-maxam-gray-500 mt-2">
        Current locale: <span class="bg-maxam-gray-100 px-1 rounded font-mono text-xs">{locale}</span>.
        See <span class="bg-maxam-gray-100 px-1 rounded font-mono text-xs">docs/DESIGN-SYSTEM.md</span> for the full inventory.
      </p>
    </header>

    <!-- ── TOKENS ── -->
    <section>
      <h2 class="text-2xl font-bold text-maxam-black mb-4">Design tokens</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <Specimen name="Brand colors" status="component">
          <div class="grid grid-cols-2 gap-3">
            {brandColors.map((c) => (
              <div class="flex items-center gap-3 text-sm">
                <div class="w-12 h-12 rounded border border-maxam-gray-300" style={`background:${c.value}`}></div>
                <div>
                  <div class="font-medium text-maxam-black">{c.name}</div>
                  <div class="text-xs text-maxam-gray-500 font-mono">{c.value}</div>
                </div>
              </div>
            ))}
          </div>
        </Specimen>

        <Specimen name="Neutral scale" status="component">
          <div class="grid grid-cols-5 gap-2 text-xs text-center">
            {grayScale.map((g) => (
              <div class="flex flex-col gap-1">
                <div class:list={['h-12 rounded border border-maxam-gray-300', g.bg]}></div>
                <div class="text-[10px] text-maxam-gray-700 font-mono">{g.name}</div>
              </div>
            ))}
          </div>
        </Specimen>

        <Specimen name="Industry colors" status="component" description="Per-industry in Notion. Applied inline at render.">
          <div class="grid grid-cols-2 gap-2">
            {sampleIndustries.map((ind) => (
              <div class="flex items-center gap-3 text-sm">
                <div class="w-10 h-10 rounded shrink-0" style={`background:${ind.color}`}></div>
                <div>
                  <div class="text-maxam-black">{ind.name}</div>
                  <div class="text-xs text-maxam-gray-500 font-mono">{ind.color}</div>
                </div>
              </div>
            ))}
          </div>
        </Specimen>

        <Specimen name="Type scale" status="inconsistent" description="Tailwind defaults. NotionBlocks defines its own scale.">
          <div class="space-y-1 text-maxam-black">
            {typeScale.map((t) => (
              <div class={t.cls}>{t.label}</div>
            ))}
          </div>
        </Specimen>
      </div>
    </section>

    <!-- ── ATOMS ── -->
    <section>
      <h2 class="text-2xl font-bold text-maxam-black mb-4">Atoms</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <Specimen name="IndustryBadge (small)" status="component">
          <div class="flex flex-wrap gap-2">
            {sampleIndustries.slice(0, 4).map((ind) => (
              <IndustryBadge name={ind.name} color={ind.color} size="sm" />
            ))}
          </div>
        </Specimen>

        <Specimen name="IndustryBadge (medium)" status="component">
          <div class="flex flex-wrap gap-2">
            {sampleIndustries.slice(0, 4).map((ind) => (
              <IndustryBadge name={ind.name} color={ind.color} size="md" />
            ))}
          </div>
        </Specimen>

        <Specimen name="Button: primary (inline only)" status="inline" description="Used on home hero, industry hero, product detail. 5 distinct stylings.">
          <div class="flex flex-wrap gap-3 items-center">
            <a href="#" class="inline-block bg-maxam-white text-maxam-black font-semibold px-6 py-3 rounded hover:bg-maxam-gray-100 transition-colors text-sm">
              White on dark
            </a>
            <a href="#" class="inline-block bg-maxam-blue text-maxam-white font-semibold px-6 py-3 rounded hover:bg-maxam-blue-dark transition-colors">
              Blue solid
            </a>
            <button class="bg-maxam-white text-maxam-blue font-semibold py-2.5 px-6 rounded-full hover:bg-maxam-gray-100 transition-colors text-sm">
              Pill submit
            </button>
          </div>
          <p class="text-xs text-maxam-gray-500 mt-3">
            3 different paddings. Mix of rounded vs rounded-full. No focus-visible state. No disabled state. No loading state.
          </p>
        </Specimen>

        <Specimen name="Button: filter pill" status="inline">
          <div class="flex flex-wrap gap-2">
            <button class="px-4 py-1.5 text-sm rounded-full border border-maxam-gray-300 hover:border-maxam-blue hover:text-maxam-blue transition-colors">
              All
            </button>
            <button class="px-4 py-1.5 text-sm rounded-full border border-maxam-blue text-maxam-white bg-maxam-blue">
              Active
            </button>
            <button class="px-3 py-1 text-xs rounded-full border border-maxam-gray-300 hover:border-maxam-blue transition-colors">
              Smaller variant
            </button>
            <button disabled class="px-4 py-1.5 text-sm rounded-full border border-maxam-gray-300 opacity-40 cursor-not-allowed">
              Disabled
            </button>
          </div>
        </Specimen>

        <Specimen name="Pagination buttons (inline)" status="inline">
          <div class="flex items-center gap-1">
            <button disabled class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded opacity-40 cursor-not-allowed">
              Previous
            </button>
            <button class="px-3 py-1.5 text-sm border bg-maxam-blue text-maxam-white border-maxam-blue rounded">1</button>
            <button class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100">2</button>
            <button class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100">3</button>
            <span class="px-2 py-1.5 text-sm text-maxam-gray-500">...</span>
            <button class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100">Next</button>
          </div>
        </Specimen>

        <Specimen name="Form input: search" status="inconsistent" description="Different from contact form inputs (ring-white) and language switcher (gray-900 bg). 3 styles total.">
          <input
            type="search"
            placeholder="Search products..."
            class="w-full border border-maxam-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-maxam-blue"
          />
        </Specimen>

        <Specimen name="Form input: contact form (on dark)" status="inconsistent" dark>
          <div class="bg-maxam-blue rounded-2xl p-4 space-y-3 text-maxam-white">
            <div>
              <label class="block text-sm mb-1 opacity-90">Full name</label>
              <input
                type="text"
                class="w-full px-3 py-2 rounded bg-maxam-white text-maxam-black text-sm focus:outline-none focus:ring-2 focus:ring-maxam-white"
              />
            </div>
            <button class="w-full bg-maxam-white text-maxam-blue font-semibold py-2.5 rounded-full hover:bg-maxam-gray-100 transition-colors text-sm">
              Send message
            </button>
          </div>
        </Specimen>

        <Specimen name="Form input: language switcher" status="inconsistent" dark>
          <select class="bg-maxam-gray-900 text-maxam-gray-300 text-sm border border-maxam-gray-700 rounded px-2 py-1 cursor-pointer hover:text-maxam-white focus:outline-none focus:ring-1 focus:ring-maxam-blue">
            <option>English</option>
            <option>Arabic</option>
            <option>Chinese</option>
          </select>
        </Specimen>

        <Specimen name="Active filter chip (inline)" status="inline">
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1 bg-maxam-gray-100 text-maxam-gray-700 text-xs px-2 py-1 rounded-full hover:bg-maxam-gray-300 cursor-pointer">
              Mining Tires <span aria-hidden="true">x</span>
            </span>
            <span class="inline-flex items-center gap-1 bg-maxam-gray-100 text-maxam-gray-700 text-xs px-2 py-1 rounded-full hover:bg-maxam-gray-300 cursor-pointer">
              Skid Steer <span aria-hidden="true">x</span>
            </span>
          </div>
        </Specimen>

        <Specimen name="Application tag (inline)" status="inline" description="On product detail pages. Different padding + no color from IndustryBadge.">
          <div class="flex flex-wrap gap-2">
            {sampleApplications.slice(0, 4).map((app) => (
              <span class="bg-maxam-gray-100 px-3 py-1 rounded text-sm">{app.name}</span>
            ))}
          </div>
        </Specimen>

        <Specimen name="Article type badge (inline)" status="inline">
          <div class="flex flex-wrap gap-3 items-start">
            <span class="bg-maxam-blue text-maxam-white text-xs font-medium px-2 py-0.5 rounded">News</span>
            <span class="bg-maxam-blue text-maxam-white text-xs font-medium px-2 py-0.5 rounded">Blog</span>
            <span class="bg-maxam-blue text-maxam-white text-xs font-medium px-2 py-0.5 rounded">Event</span>
            <span class="bg-maxam-blue text-maxam-white px-1.5 py-0.5 rounded text-[10px] uppercase font-medium">News (mega nav)</span>
          </div>
        </Specimen>

        <Specimen name="Icon (no shared component)" status="missing" description="All icons are inline SVGs. No Icon component or set chosen yet.">
          <div class="flex items-center gap-3 text-maxam-gray-700">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
        </Specimen>
      </div>
    </section>

    <!-- ── RUBBERMORPHISM PROTOTYPE ── -->
    <section>
      <h2 class="text-2xl font-bold text-maxam-black mb-2">Rubbermorphism prototype</h2>
      <p class="text-sm text-maxam-gray-700 max-w-3xl mb-6">
        New design language: physical, stacked layers. Light from upper-left. Hard overlap
        between layers. Industry color washes the panel and chip subtly. Subtle, not skeuomorphic.
      </p>
      <div class="space-y-6">

        <Specimen name="RubberProductCard: light vs dark" status="component" description="Same data, light variant on top, dark variant below. Industry color shows differently in each environment.">
          <div class="space-y-8">
            <div>
              <p class="text-xs uppercase tracking-wider text-maxam-gray-500 font-semibold mb-3">Light variant</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
                {sampleProducts.slice(0, 3).map((tire) => <RubberProductCard tire={tire} locale={locale} variant="light" />)}
              </div>
            </div>
            <div class="bg-[#1f1d1a] rounded-lg p-6 -mx-2">
              <p class="text-xs uppercase tracking-wider text-[#9b958a] font-semibold mb-3">Dark variant (on dark page)</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
                {sampleProducts.slice(0, 3).map((tire) => <RubberProductCard tire={tire} locale={locale} variant="dark" />)}
              </div>
            </div>
          </div>
        </Specimen>

        <Specimen name="Side by side: original vs rubbermorphism" status="inconsistent" description="Original ProductCard (top) vs new RubberProductCard (bottom). Both use the same data.">
          <div class="space-y-8">
            <div>
              <p class="text-xs uppercase tracking-wider text-maxam-gray-500 font-semibold mb-3">Original</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
                {sampleProducts.slice(0, 3).map((tire) => <ProductCard tire={tire} locale={locale} />)}
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-maxam-gray-500 font-semibold mb-3">New (rubbermorphism)</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
                {sampleProducts.slice(0, 3).map((tire) => <RubberProductCard tire={tire} locale={locale} />)}
              </div>
            </div>
          </div>
        </Specimen>
      </div>
    </section>

    <!-- ── RUBBERMORPHIC NAVIGATION ── -->
    <section>
      <h2 class="text-2xl font-bold text-maxam-black mb-2">Rubbermorphic navigation</h2>
      <p class="text-sm text-maxam-gray-700 max-w-3xl mb-6">
        New header in the same language as the product card. Light raised surface
        sitting on the warm page background, with the MAXAM wordmark in brand blue.
        Mega-nav and mobile menu functionality match the existing header. Use the
        comparison below to evaluate the swap.
      </p>
      <div class="space-y-6">

        <Specimen name="MaxamLogo SVG" status="component" description="Inline SVG, scales with text size, uses currentColor.">
          <div class="flex items-end gap-8 flex-wrap">
            <div class="flex flex-col items-center gap-2">
              <MaxamLogo class="h-4 text-maxam-blue" />
              <code class="text-[10px] text-maxam-gray-500">h-4 blue</code>
            </div>
            <div class="flex flex-col items-center gap-2">
              <MaxamLogo class="h-6 text-maxam-blue" />
              <code class="text-[10px] text-maxam-gray-500">h-6 blue</code>
            </div>
            <div class="flex flex-col items-center gap-2">
              <MaxamLogo class="h-10 text-maxam-blue" />
              <code class="text-[10px] text-maxam-gray-500">h-10 blue</code>
            </div>
            <div class="flex flex-col items-center gap-2">
              <MaxamLogo class="h-10 text-maxam-black" />
              <code class="text-[10px] text-maxam-gray-500">h-10 black</code>
            </div>
            <div class="flex flex-col items-center gap-2 bg-maxam-black p-3 rounded">
              <MaxamLogo class="h-10 text-maxam-white" />
              <code class="text-[10px] text-maxam-gray-300">h-10 white on black</code>
            </div>
          </div>
        </Specimen>

        <Specimen name="RubberHeader (full preview)" status="component" description="Click Products / Resources to see the mega nav drop down. Hover the triggers to feel the lift; click to see the pressed-in state.">
          <!-- Faux-viewport: relative positioning so the absolute mega-nav
               panel inside the header anchors to this container. We deliberately
               leave overflow visible (no clip) so the panel can drop below the
               header bar. Min-height reserves room so the panel doesn't collide
               with the next gallery section. -->
          <div
            class="rounded-lg border border-[var(--color-edge)] relative"
            style="background:var(--color-surface-page); min-height: 520px;"
          >
            <RubberHeader locale={locale} sticky={false} />
            <div class="px-6 py-12 text-sm text-maxam-gray-500">
              <p>Page content underneath, on <code>--color-surface-page</code> (#f3f1ec).</p>
              <p class="mt-2">Click <strong>Products</strong> or <strong>Resources</strong> in the header to drop the mega nav.</p>
              <p class="mt-2">Notice the pressed-in state on the active trigger and the chamfered edge on the new pill triggers.</p>
            </div>
          </div>
        </Specimen>

        <Specimen name="Old vs new header" status="inconsistent" description="Original is dark (visible at the top of this page). New is light raised. Open mega nav on the new one below.">
          <div class="space-y-6">
            <div>
              <p class="text-xs uppercase tracking-wider text-maxam-gray-500 font-semibold mb-3">Original (Header.astro)</p>
              <p class="text-xs text-maxam-gray-500">
                The original Header is rendering at the very top of this page. Scroll up to see it.
              </p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-maxam-gray-500 font-semibold mb-3">New (RubberHeader.astro)</p>
              <div
                class="rounded-lg border border-[var(--color-edge)] relative"
                style="background:var(--color-surface-page); min-height: 480px;"
              >
                <RubberHeader locale={locale} sticky={false} />
                <div class="px-6 py-12 text-sm text-maxam-gray-500">Page content area.</div>
              </div>
            </div>
          </div>
        </Specimen>
      </div>
    </section>

    <!-- ── RUBBERMORPHIC ATOMS ── -->
    <section>
      <h2 class="text-2xl font-bold text-maxam-black mb-2">Rubbermorphic atoms</h2>
      <p class="text-sm text-maxam-gray-700 max-w-3xl mb-6">
        Phase 1 atoms in the new language. These replace the inline patterns
        scattered across the codebase (5 button variants, 8 chip/badge variants,
        3 input stylings, inline breadcrumb on 3 pages). Once you sign off on
        these, we promote them globally and start migrating cards.
      </p>
      <div class="space-y-6">

        <Specimen name="RubberButton — variants" status="component" description="primary / secondary / ghost — three emphasis levels.">
          <div class="flex flex-wrap items-center gap-3">
            <RubberButton variant="primary">Primary action</RubberButton>
            <RubberButton variant="secondary">Secondary action</RubberButton>
            <RubberButton variant="ghost">Ghost action</RubberButton>
          </div>
        </Specimen>

        <Specimen name="RubberButton — sizes" status="component">
          <div class="flex flex-wrap items-center gap-3">
            <RubberButton variant="primary" size="sm">Small</RubberButton>
            <RubberButton variant="primary" size="md">Medium (default)</RubberButton>
            <RubberButton variant="primary" size="lg">Large</RubberButton>
          </div>
          <div class="flex flex-wrap items-center gap-3 mt-3">
            <RubberButton variant="secondary" size="sm">Small</RubberButton>
            <RubberButton variant="secondary" size="md">Medium</RubberButton>
            <RubberButton variant="secondary" size="lg">Large</RubberButton>
          </div>
        </Specimen>

        <Specimen name="RubberButton — states" status="component" description="Disabled and as-link rendering.">
          <div class="flex flex-wrap items-center gap-3">
            <RubberButton variant="primary" disabled>Disabled primary</RubberButton>
            <RubberButton variant="secondary" disabled>Disabled secondary</RubberButton>
            <RubberButton variant="ghost" disabled>Disabled ghost</RubberButton>
            <RubberButton variant="primary" href="#">As link</RubberButton>
          </div>
        </Specimen>

        <Specimen name="RubberButton — full width" status="component">
          <div class="max-w-xs space-y-2">
            <RubberButton variant="primary" full>Full-width primary</RubberButton>
            <RubberButton variant="secondary" full>Full-width secondary</RubberButton>
