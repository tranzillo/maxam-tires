---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Grid from '../../components/ui/Grid.astro';
import IndustryCard from '../../components/ui/IndustryCard.astro';
import ProductCard from '../../components/ui/ProductCard.astro';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import Button from '../../components/ui/Button.astro';
import Chip from '../../components/ui/Chip.astro';
import Input from '../../components/ui/Input.astro';
import type { Locale } from '../../types';
import { locales, t, localePath } from '../../lib/i18n';
import {
  getAllIndustries,
  getRecentProductsByIndustry,
  getRecentArticles,
  getPageContent,
  getPagePromos,
  pageText,
} from '../../lib/data';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

// Page-bound content (hero / sustainability / newsletter copy + the promo
// pair) comes from the Notion-pipeline snapshot via the Pages content type.
const homePage = getPageContent(locale, 'home');
const promoCards = getPagePromos(locale, 'home');

// Collection content (industries, products, articles) flows through the
// same pipeline as the rest of the site. All industries show in the strip.
const industries = getAllIndustries(locale);

// Recent products: newest first (wpId proxy), max one per industry, up to
// 10 — the grid shows an even subset per breakpoint (5x2 → … → 1x3).
const featuredProducts = getRecentProductsByIndustry(locale, 10);

const recentArticles = getRecentArticles(locale, 3);
---

<BaseLayout locale={locale}>
  <!-- 1. HERO — full-bleed background image, content in container -->
  <Section
    background="image"
    backgroundImage={pageText(homePage, 'hero.background_image', '/images/hero-home.jpg')}
    backgroundPosition={pageText(homePage, 'hero.background_position', 'center bottom')}
    overlay="blue-lr"
    vertical="xlg"
  >
    <div class="hero-content">
      <h1 class="hero-heading">
        <span class="hero-lead">{pageText(homePage, 'hero.lead')}</span>
        <span class="hero-punch">{pageText(homePage, 'hero.heading')}</span>
      </h1>
      <p class="hero-description">{pageText(homePage, 'hero.description')}</p>
      <div class="hero-actions">
        <Button variant="primary" size="lg" href={localePath(locale, pageText(homePage, 'hero.cta_href', '/products'))}>
          {pageText(homePage, 'hero.cta_label')}
        </Button>
      </div>
    </div>
  </Section>

  <!-- 2. PROMO PAIR — 2-col grid inside the standard container -->
  <Section vertical="lg" class="home-promos">
    <Grid cols={2} gap="md">
      {promoCards.map((card) => (
        <a
          class="promo-card"
          href={localePath(locale, card.ctaHref)}
          style={`background-image:url('${card.image}');background-position:${card.imagePosition};`}
        >
          <span class="promo-card__overlay" aria-hidden="true"></span>
          {card.tag && (
            <span class="promo-card__tag">
              <Chip variant="solid" size="sm">{card.tag}</Chip>
            </span>
          )}
          <div class="promo-card__body">
            <h2 class="promo-card__heading">{card.heading}</h2>
            <p class="promo-card__description">{card.description}</p>
            <Chip variant="category" size="lg">{card.ctaLabel}</Chip>
          </div>
        </a>
      ))}
    </Grid>
  </Section>

  <!-- 3. INDUSTRIES — wide block: horizontally scrolling strip of all
       industry tiles. Same full-bleed gutter treatment as the header and
       products viewer; scrolls when the tiles overflow it. -->
  <section class="industries-strip" aria-label={t(locale, 'nav.products')}>
    <ul class="industries-strip__track">
      {industries.map((industry) => (
        <li class="industries-strip__item">
          <IndustryCard industry={industry} locale={locale} />
        </li>
      ))}
    </ul>
  </section>

  <!-- 4. RECENT PRODUCTS — wide block: newest product per industry in an
       even grid (5x2 → 4x2 → 3x2 → 2x2 → 1x3; CSS hides trailing items
       so rows are always full). -->
  <section class="recent-products">
    <SectionHeader
      heading={t(locale, 'home.featured_heading')}
      viewAllHref={localePath(locale, '/products')}
      viewAllLabel={t(locale, 'home.featured_view_all')}
    />
    <ul class="recent-products__grid">
      {featuredProducts.map((tire) => (
        <li class="recent-products__item">
          <ProductCard tire={tire} locale={locale} />
        </li>
      ))}
    </ul>
  </section>

  <!-- 5. SUSTAINABILITY — full-bleed bg image, content in container, 2-col layout -->
  <Section
    background="image"
    backgroundImage={pageText(homePage, 'sustainability.background_image', '/images/bg-sustainability.jpg')}
    overlay="dark"
    vertical="xlg"
  >
    <div class="strip-2col">
      <div class="strip-2col__lead">
        <h2 class="strip-heading">{pageText(homePage, 'sustainability.heading')}</h2>
        <div>
          <Button
            variant="primary"
            size="lg"
            href={localePath(locale, pageText(homePage, 'sustainability.cta_href', '/sustainability'))}
          >
            {pageText(homePage, 'sustainability.cta_label')}
          </Button>
        </div>
      </div>
      <div class="strip-2col__body">
        <p class="strip-lead" set:html={pageText(homePage, 'sustainability.lead')} />
        <p class="strip-body" set:html={pageText(homePage, 'sustainability.body')} />
      </div>
    </div>
  </Section>

  <!-- 6. RESOURCE CENTER — sunken bg, 3-up Grid -->
  {recentArticles.length > 0 && (
    <Section background="sunken" vertical="lg">
      <SectionHeader
        heading={t(locale, 'home.resources_heading')}
        subheading={t(locale, 'home.resources_lead')}
        viewAllHref={localePath(locale, '/resources')}
        viewAllLabel={t(locale, 'home.resources_view_all')}
      />
      <Grid cols={3} gap="md">
        {recentArticles.map((article) => (
          <ArticleCard article={article} locale={locale} />
        ))}
      </Grid>
    </Section>
  )}

  <!-- 7. NEWSLETTER CTA — full-bleed bg image, centered content in container -->
  <Section
    background="image"
    backgroundImage={pageText(homePage, 'newsletter.background_image', '/images/bg-newsletter.jpg')}
    overlay="blue-full"
    vertical="xlg"
  >
    <div class="cta-centered">
      <h2 class="cta-heading">{pageText(homePage, 'newsletter.heading')}</h2>
      <p class="cta-description">{pageText(homePage, 'newsletter.description')}</p>
      <form class="cta-form" data-static-form>
        <label class="sr-only" for="newsletter-email">
          {pageText(homePage, 'newsletter.email_label')}
        </label>
        <div class="cta-form__input">
          <Input
            id="newsletter-email"
            type="email"
            name="email"
            placeholder={pageText(homePage, 'newsletter.email_label')}
            required
            autocomplete="email"
            size="lg"
          />
        </div>
        <Button type="submit" variant="primary" size="lg">
          {pageText(homePage, 'newsletter.submit_label')}
        </Button>
      </form>
    </div>
  </Section>
</BaseLayout>
