---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import NotionBlocks from '../../../../components/NotionBlocks.astro';
import TireGallery from '../../../../components/ui/TireGallery.astro';
import SpecViewer from '../../../../components/ui/SpecViewer.astro';
import SpecSizeSelector from '../../../../components/ui/SpecSizeSelector.astro';
import RubberBreadcrumb from '../../../../components/ui/RubberBreadcrumb.astro';
import RubberChip from '../../../../components/ui/RubberChip.astro';
import RubberButton from '../../../../components/ui/RubberButton.astro';
import RubberDocumentCard from '../../../../components/ui/RubberDocumentCard.astro';
import type { Locale } from '../../../../types';
import { locales, t, localePath } from '../../../../lib/i18n';
import { getAllProducts, getProductBySlug, getProductBlocks, getProductSpecs } from '../../../../lib/data';

export function getStaticPaths() {
  const paths: Array<{ params: { locale: string; industry: string; slug: string } }> = [];
  for (const locale of locales) {
    const products = getAllProducts(locale as Locale);
    for (const tire of products) {
      if (tire.industries.length === 0) continue;
      paths.push({
        params: { locale, industry: tire.industries[0].urlSlug, slug: tire.urlSlug },
      });
    }
  }
  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; industry: string; slug: string };
const tire = getProductBySlug(locale, slug);

if (!tire) {
  return Astro.redirect(localePath(locale, '/products'));
}

const primaryIndustry = tire.industries[0];
const blocks = getProductBlocks(locale, slug);
const specs = getProductSpecs(locale, slug);

// ── Split the Notion block stream into three parts ─────────────────
//   1. images    → pulled out for the gallery column
//   2. lead      → description + Features, shown in the info column
//   3. specs     → the spec section (heading + table), full-width below
//
// The split is STRUCTURE-based, not heading-text based, so it works
// in every locale (the headings are translated — "Specifications",
// "المواصفات", "技術規格" — and English-string matching broke RTL/CJK).
//
// Rules, derived from how WP exported these tire bodies:
//   - The spec section is the `table` block plus the heading directly
//     before it; everything from that heading onward is "specs".
//   - The gallery heading is the heading directly before the first
//     image block; it's dropped (images move to the gallery column).
function isHeading(b: any): boolean {
  return typeof b?.type === 'string' && b.type.startsWith('heading');
}
function blockImageUrl(b: any): string | null {
  if (b?.type !== 'image') return null;
  const img = b.image ?? {};
  return img.url ?? img.external?.url ?? img.file?.url ?? null;
}

// Locate the structural boundaries by index.
const firstTableIdx = blocks.findIndex((b) => b?.type === 'table');
const firstImageIdx = blocks.findIndex((b) => blockImageUrl(b) !== null);

// Spec section starts at the heading right before the first table
// (fall back to the table itself if no heading precedes it).
let specsStartIdx = -1;
if (firstTableIdx !== -1) {
  specsStartIdx = firstTableIdx;
  if (specsStartIdx > 0 && isHeading(blocks[specsStartIdx - 1])) specsStartIdx -= 1;
}

// Gallery heading = heading immediately before the first image.
const galleryHeadingIdx =
  firstImageIdx > 0 && isHeading(blocks[firstImageIdx - 1]) ? firstImageIdx - 1 : -1;

const galleryFromBlocks: string[] = [];
let leadBlocks: any[] = [];
let specsBlocks: any[] = [];

// When structured specs exist, the SpecViewer replaces the raw spec
// table, so we drop the whole Specifications section from the blocks.
const hasStructuredSpecs = !!specs;

blocks.forEach((b, i) => {
  const imgUrl = blockImageUrl(b);
  if (imgUrl) {
    galleryFromBlocks.push(imgUrl);
    return;
  }
  if (i === galleryHeadingIdx) return; // drop the redundant gallery heading

  const inSpecs = specsStartIdx !== -1 && i >= specsStartIdx;
  if (inSpecs) {
    if (!hasStructuredSpecs) specsBlocks.push(b);
  } else {
    leadBlocks.push(b);
  }
});

// Featured image first, then block images, de-duplicated by URL.
const galleryImages = [
  ...(tire.featuredImage ? [tire.featuredImage] : []),
  ...galleryFromBlocks,
].filter((url, i, arr) => arr.indexOf(url) === i);
---

<BaseLayout locale={locale} title={tire.title}>
  <article class="tire-page" style={`--industry-color:${primaryIndustry.color}`}>
    <div class="tire-page__breadcrumb">
      <RubberBreadcrumb items={[
        { label: t(locale, 'nav.products'), href: localePath(locale, '/products') },
        { label: primaryIndustry.name, href: localePath(locale, `/products/${primaryIndustry.urlSlug}`) },
        { label: tire.title },
      ]} />
    </div>

    <!-- 2-column hero: info (left) + gallery (right) -->
    <div class="tire-page__hero">
      <div class="tire-page__info">
        <div class="tire-page__chips">
          {tire.industries.map((ind) => (
            <RubberChip variant="industry" size="md" color={ind.color}>{ind.name}</RubberChip>
          ))}
        </div>

        <h1 class="tire-page__title heading heading--lg">{tire.title}</h1>
        {tire.subheading && <p class="tire-page__subheading heading heading--sm">{tire.subheading}</p>}

        {tire.applications.length > 0 && (
          <div class="tire-page__applications">
            {tire.applications.map((app) => (
              <RubberChip variant="neutral" size="sm">{app.name}</RubberChip>
            ))}
          </div>
        )}

        <!-- Description + Features (Notion blocks before Specifications) -->
        <div class="tire-page__lead prose-content">
          <NotionBlocks blocks={leadBlocks} />
        </div>

        <!-- Size selector — drives the spec table below; "See Specs" jumps to it. -->
        {specs && (
          <SpecSizeSelector
            specs={specs}
            sizeLabel={t(locale, 'product.size_select')}
            countLabel={t(locale, 'product.sizes_available')}
            seeSpecsLabel={t(locale, 'product.see_specs')}
            target="tire-specs"
          />
        )}
      </div>

      <!-- Gallery: featured image + thumb column -->
      <TireGallery images={galleryImages} alt={tire.title} />
    </div>

    <!-- Specifications (full width). Structured spec table when we have
         normalized spec data; otherwise fall back to the raw block table. -->
    {specs ? (
      <section class="tire-page__section">
        <h2 class="tire-page__section-heading heading heading--md">{t(locale, 'product.specifications')}</h2>
        <SpecViewer specs={specs} id="tire-specs" />
      </section>
    ) : (
      specsBlocks.length > 0 && (
        <section class="tire-page__section prose-content">
          <NotionBlocks blocks={specsBlocks} />
        </section>
      )
    )}

    <!-- CTA -->
    <div class="tire-page__section">
      <RubberButton variant="primary" size="lg" href={localePath(locale, '/contact')}>
        {t(locale, 'product.get_in_touch')}
      </RubberButton>
    </div>

    <!-- Documents -->
    {tire.documents.length > 0 && (
      <section class="tire-page__section">
        <h2 class="tire-page__section-heading heading heading--md">
          {t(locale, 'product.documents') || 'Documents'}
        </h2>
        <div class="tire-page__docs-grid">
          {tire.documents.map((doc) => (
            <RubberDocumentCard document={doc} locale={locale} />
          ))}
        </div>
      </section>
    )}

    <!-- Back link -->
    <div class="tire-page__back">
      <RubberButton variant="ghost" size="md" href={localePath(locale, '/products')}>
        <span class="tire-page__back-arrow" aria-hidden="true">←</span>
        {t(locale, 'product.back')}
      </RubberButton>
    </div>
  </article>
</BaseLayout>
