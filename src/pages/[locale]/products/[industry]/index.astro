---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductsViewer from '../../../../components/ui/ProductsViewer.astro';
import Section from '../../../../components/ui/Section.astro';
import SectionHeader from '../../../../components/ui/SectionHeader.astro';
import Grid from '../../../../components/ui/Grid.astro';
import RubberArticleCard from '../../../../components/ui/RubberArticleCard.astro';
import RubberBreadcrumb from '../../../../components/ui/RubberBreadcrumb.astro';
import type { Locale } from '../../../../types';
import { locales, t, localePath } from '../../../../lib/i18n';
import { industryVars } from '../../../../lib/style';
import {
  getAllIndustries,
  getIndustryBySlug,
  getProductsByIndustry,
  getArticlesByIndustry,
} from '../../../../lib/data';

export function getStaticPaths() {
  // Canonical (English) industry slugs — locale-stable URLs across all locales.
  const industries = getAllIndustries('en');
  const paths: Array<{ params: { locale: string; industry: string } }> = [];
  for (const locale of locales) {
    for (const industry of industries) {
      paths.push({ params: { locale, industry: industry.urlSlug } });
    }
  }
  return paths;
}

const { locale, industry: industrySlug } = Astro.params as { locale: Locale; industry: string };
const industry = getIndustryBySlug(locale, industrySlug);

if (!industry) {
  return Astro.redirect(localePath(locale, '/products'));
}

const tires = getProductsByIndustry(locale, industrySlug);
const articles = getArticlesByIndustry(locale, industrySlug).slice(0, 6);
const allIndustries = getAllIndustries(locale);

// The Industry filter group is hidden on this page (the route already
// scopes the industry), so we only need to surface the application /
// size / rating options that this industry's tires actually have.
const apps = new Map<string, { id: string; slug: string; name: string }>();
const sizes = new Set<string>();
const ratings = new Set<number>();
for (const tire of tires) {
  for (const app of tire.applications) apps.set(app.id, app);
  for (const s of tire.sizes) sizes.add(s);
  if (tire.rating != null) ratings.add(tire.rating);
}
const industryApplications = [...apps.values()];
const industrySizes = [...sizes].sort();
const industryRatings = [...ratings].sort((a, b) => a - b);

// Bg image for the hero — use the industry's hero image if it has one,
// otherwise fall back to the shared products hero.
const heroBg = industry.heroImage ?? '/images/hero-home.jpg';
---

<BaseLayout locale={locale} title={industry.name}>
  <!-- Hero header: matches /products page hero. Industry color overlay. -->
  <section
    class="products-hero"
    style={`background-image:url('${heroBg}');--products-hero-overlay-color:${industry.color};`}
    data-overlay="industry"
  >
    <div class="products-hero__overlay" aria-hidden="true"></div>
    <div class="products-hero__inner">
      <h1 class="products-hero__heading">{industry.name}</h1>
      <span id="results-count" class="products-hero__count"></span>
    </div>
  </section>

  <!-- Breadcrumb — uses the page gutter so it aligns with the viewer below. -->
  <div class="products-breadcrumb">
    <RubberBreadcrumb items={[
      { label: t(locale, 'nav.home'), href: localePath(locale, '/') },
      { label: t(locale, 'nav.products'), href: localePath(locale, '/products') },
      { label: industry.name },
    ]} />
  </div>

  <!-- Tire viewer — same component as /products. Industry filter group
       is hidden here since the route already scopes the industry. -->
  <div class="products-page" style={industryVars(industry.color)}>
    <ProductsViewer
      locale={locale}
      tires={tires}
      industries={allIndustries}
      applications={industryApplications}
      sizes={industrySizes}
      ratings={industryRatings}
      hideIndustryFilter={true}
      countTargetId="results-count"
    />
  </div>

  <!-- Related resources — kept; tire-only pages don't always have enough
       imagery for some industries, the articles add context + depth. -->
  {articles.length > 0 && (
    <Section background="sunken">
      <SectionHeader
        heading={t(locale, 'industry.resources_heading')}
        viewAllHref={`/${locale}/resources/?industry=${industry.id}`}
        viewAllLabel={t(locale, 'common.view_all')}
      />
      <Grid cols={3} gap="md">
        {articles.map((article) => (
          <RubberArticleCard article={article} locale={locale} />
        ))}
      </Grid>
    </Section>
  )}
</BaseLayout>
