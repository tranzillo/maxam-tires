---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCard from '../../../components/ui/ProductCard.astro';
import type { Locale } from '../../../types';
import { locales, t } from '../../../lib/i18n';
import { getAllProducts, getAllIndustries, getAllApplications, getAllSizes, getAllRatings } from '../../../lib/data';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const tires = getAllProducts(locale);
const industries = getAllIndustries(locale);
const applications = getAllApplications(locale);
const allSizes = getAllSizes();
const allRatings = getAllRatings();
---

<BaseLayout locale={locale} title={t(locale, 'products.title')}>
  <section class="max-w-[var(--container-max)] mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-maxam-black mb-8">
      {t(locale, 'products.title')}
    </h1>

    <!-- Mobile filter toggle -->
    <button
      id="mobile-filter-toggle"
      class="md:hidden flex items-center gap-2 mb-4 px-4 py-2 bg-maxam-blue text-maxam-white rounded-full text-sm font-semibold"
      aria-expanded="false"
      aria-controls="filter-sidebar"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
      </svg>
      {t(locale, 'products.filter.show')}
    </button>

    <!-- Filter overlay (mobile) -->
    <div id="filter-overlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

    <div class="flex flex-col md:flex-row gap-8">
      <!-- Filters sidebar -->
      <aside
        id="filter-sidebar"
        class="w-full md:w-64 shrink-0 fixed inset-y-0 start-0 z-50 bg-maxam-white p-6 overflow-y-auto md:relative md:inset-auto md:z-auto md:p-0 transition-transform duration-300"
        data-open="false"
      >
        <!-- Close button (mobile only) -->
        <button
          id="filter-close"
          class="md:hidden mb-4 text-sm text-maxam-gray-500 hover:text-maxam-black"
        >
          {t(locale, 'products.filter.close')} &times;
        </button>

        <!-- Search -->
        <div class="mb-6">
          <input
            type="text"
            id="product-search"
            placeholder={t(locale, 'products.search_placeholder')}
            class="w-full border border-maxam-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-maxam-blue"
          />
        </div>

        <!-- Industry filter -->
        <div class="mb-6">
          <h3 class="font-semibold text-sm uppercase tracking-wider text-maxam-gray-700 mb-2">
            {t(locale, 'products.filter.industry')}
          </h3>
          <div class="space-y-1">
            {industries.map((ind) => (
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" class="filter-checkbox" data-filter="industry" data-value={ind.id} />
                <span class="inline-block w-3 h-3 rounded-full shrink-0" style={`background:${ind.color}`}></span>
                <span class="filter-label-text">{ind.name}</span>
                <span class="filter-count text-xs text-maxam-gray-500 ms-auto" data-count-for={`industry:${ind.id}`}></span>
              </label>
            ))}
          </div>
        </div>

        <!-- Application filter -->
        <div class="mb-6">
          <h3 class="font-semibold text-sm uppercase tracking-wider text-maxam-gray-700 mb-2">
            {t(locale, 'products.filter.application')}
          </h3>
          <div class="space-y-1">
            {applications.map((app) => (
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" class="filter-checkbox" data-filter="application" data-value={app.id} />
                <span class="filter-label-text">{app.name}</span>
                <span class="filter-count text-xs text-maxam-gray-500 ms-auto" data-count-for={`application:${app.id}`}></span>
              </label>
            ))}
          </div>
        </div>

        <!-- Size filter -->
        <div class="mb-6">
          <h3 class="font-semibold text-sm uppercase tracking-wider text-maxam-gray-700 mb-2">
            {t(locale, 'products.filter.size')}
          </h3>
          <div class="space-y-1 max-h-40 overflow-y-auto">
            {allSizes.map((size) => (
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" class="filter-checkbox" data-filter="size" data-value={size} />
                <span class="filter-label-text">{size}</span>
                <span class="filter-count text-xs text-maxam-gray-500 ms-auto" data-count-for={`size:${size}`}></span>
              </label>
            ))}
          </div>
        </div>

        <!-- Rating filter -->
        {allRatings.length > 0 && (
          <div class="mb-6">
            <h3 class="font-semibold text-sm uppercase tracking-wider text-maxam-gray-700 mb-2">
              {t(locale, 'products.filter.rating')}
            </h3>
            <div class="space-y-1">
              {allRatings.map((rating) => (
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                  <input type="checkbox" class="filter-checkbox" data-filter="rating" data-value={String(rating)} />
                  <span class="filter-label-text" aria-label={`${rating} of 5`}>{'★'.repeat(rating)}{'☆'.repeat(5 - rating)}</span>
                  <span class="filter-count text-xs text-maxam-gray-500 ms-auto" data-count-for={`rating:${rating}`}></span>
                </label>
              ))}
            </div>
          </div>
        )}

        <button
          id="clear-filters"
          class="text-sm text-maxam-blue hover:underline"
        >
          {t(locale, 'products.filter.clear')}
        </button>
      </aside>

      <!-- Product grid area -->
      <div class="flex-1">
        <!-- Results count + active filter chips -->
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <div id="active-chips" class="flex flex-wrap gap-2"></div>
          <span id="results-count" class="text-sm text-maxam-gray-500 shrink-0"></span>
        </div>

        <!-- Grid -->
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {tires.map((tire) => (
            <ProductCard tire={tire} locale={locale} showFilterData={true} />
          ))}
        </div>

        <!-- Pagination -->
        <nav id="pagination" class="hidden items-center justify-center gap-2 mt-8" aria-label="Pagination">
          <button id="page-prev" class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100 disabled:opacity-40 disabled:cursor-not-allowed">
            {t(locale, 'products.pagination.prev')}
          </button>
          <div id="page-numbers" class="flex gap-1"></div>
          <button id="page-next" class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100 disabled:opacity-40 disabled:cursor-not-allowed">
            {t(locale, 'products.pagination.next')}
          </button>
        </nav>

        <!-- No results -->
        <p id="no-results" class="hidden text-center text-maxam-gray-500 py-12">
          {t(locale, 'products.no_results')}
        </p>
      </div>
    </div>
  </section>

  <!-- Filter metadata for client-side friendly names -->
  <script
    is:inline
    type="application/json"
    id="filter-meta"
    set:html={JSON.stringify({
      industry: Object.fromEntries(industries.map(i => [i.id, i.name])),
      application: Object.fromEntries(applications.map(a => [a.id, a.name])),
      rating: Object.fromEntries(allRatings.map(r => [String(r), '★'.repeat(r) + '☆'.repeat(5 - r)])),
      labels: {
        industry: t(locale, 'products.filter.industry'),
        application: t(locale, 'products.filter.application'),
        size: t(locale, 'products.filter.size'),
        rating: t(locale, 'products.filter.rating'),
      },
      resultsTemplate: t(locale, 'products.results_count'),
    })}
  />
</BaseLayout>

<script>
  const ITEMS_PER_PAGE = 12;

  // DOM refs
  const checkboxes = document.querySelectorAll<HTMLInputElement>('.filter-checkbox');
  const searchInput = document.getElementById('product-search') as HTMLInputElement;
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.product-card'));
  const noResults = document.getElementById('no-results')!;
  const chipsContainer = document.getElementById('active-chips')!;
  const resultsCountEl = document.getElementById('results-count')!;
  const clearBtn = document.getElementById('clear-filters')!;
  const paginationNav = document.getElementById('pagination')!;
  const pagePrev = document.getElementById('page-prev') as HTMLButtonElement;
  const pageNext = document.getElementById('page-next') as HTMLButtonElement;
  const pageNumbers = document.getElementById('page-numbers')!;
  const filterSidebar = document.getElementById('filter-sidebar')!;
  const filterOverlay = document.getElementById('filter-overlay')!;
  const mobileToggle = document.getElementById('mobile-filter-toggle')!;
  const filterClose = document.getElementById('filter-close')!;

  // Filter metadata
  const meta = JSON.parse(document.getElementById('filter-meta')!.textContent!);

  // State
  let filteredCards: HTMLElement[] = [];
  let currentPage = 1;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;
  let isInitializing = false;

  /* ── URL ↔ State ──────────────────────────────────────── */

  function parseURL(): { filters: Record<string, string[]>; q: string; page: number } {
    const params = new URLSearchParams(window.location.search);
    const filters: Record<string, string[]> = {};
    for (const key of ['industry', 'application', 'size', 'rating']) {
      const val = params.get(key);
      if (val) filters[key] = val.split(',').filter(Boolean);
    }
    return {
      filters,
      q: params.get('q') || '',
      page: Math.max(1, parseInt(params.get('page') || '1', 10)),
    };
  }

  function syncURL(method: 'push' | 'replace' = 'push') {
    const params = new URLSearchParams();
    const active = getActiveFilters();

    for (const [key, values] of Object.entries(active)) {
      if (values.size > 0) params.set(key, [...values].join(','));
    }
    const q = searchInput.value.trim();
    if (q) params.set('q', q);
    if (currentPage > 1) params.set('page', String(currentPage));

    const search = params.toString();
    const url = window.location.pathname + (search ? '?' + search : '');

    if (method === 'push') {
      history.pushState(null, '', url);
    } else {
      history.replaceState(null, '', url);
    }
  }

  /* ── Filters ──────────────────────────────────────────── */

  function getActiveFilters(): Record<string, Set<string>> {
    const active: Record<string, Set<string>> = {};
    checkboxes.forEach((cb) => {
      if (cb.checked) {
        const key = cb.dataset.filter!;
        if (!active[key]) active[key] = new Set();
        active[key].add(cb.dataset.value!);
      }
    });
    return active;
  }

  function cardMatchesFilters(card: HTMLElement, active: Record<string, Set<string>>, query: string): boolean {
    // Text search
    if (query && !card.dataset.title?.includes(query)) return false;

    // Checkbox filters: AND across groups, OR within group
    for (const [key, values] of Object.entries(active)) {
      if (key === 'rating') {
        const cardRating = card.dataset.rating ?? '';
        if (![...values].some((v) => v === cardRating)) return false;
      } else {
        const attr = key === 'industry' ? 'industries' : key === 'application' ? 'applications' : key + 's';
        const cardValues = (card.dataset[attr] ?? '').split(',');
        if (![...values].some((v) => cardValues.includes(v))) return false;
      }
    }
    return true;
  }

  function applyFilters(preservePage = false) {
    const active = getActiveFilters();
    const query = searchInput.value.toLowerCase().trim();

    filteredCards = allCards.filter((card) => cardMatchesFilters(card, active, query));

    if (!preservePage) currentPage = 1;

    renderPage();
    renderChips(active);
    updateFilterCounts(active, query);

    if (!isInitializing) {
      syncURL('push');
    }
  }

  /* ── Filter Counts ────────────────────────────────────── */

  function updateFilterCounts(active: Record<string, Set<string>>, query: string) {
    const countSpans = document.querySelectorAll<HTMLElement>('.filter-count');
    countSpans.forEach((span) => {
      const [group, value] = span.dataset.countFor!.split(':');
      // Count matches with all OTHER filters applied (not this group)
      const otherActive = { ...active };
      delete otherActive[group];

      let count = 0;
      for (const card of allCards) {
        if (!cardMatchesFilters(card, otherActive, query)) continue;
        if (group === 'rating') {
          if (card.dataset.rating === value) count++;
        } else {
          const attr = group === 'industry' ? 'industries' : group === 'application' ? 'applications' : group + 's';
          const cardValues = (card.dataset[attr] ?? '').split(',');
          if (cardValues.includes(value)) count++;
        }
      }

      span.textContent = count > 0 ? `(${count})` : '';
    });
  }

  /* ── Pagination ───────────────────────────────────────── */

  function renderPage() {
    const totalPages = Math.max(1, Math.ceil(filteredCards.length / ITEMS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    const visibleSet = new Set(filteredCards.slice(start, end));

    // Show/hide cards
    allCards.forEach((card) => {
      card.style.display = visibleSet.has(card) ? '' : 'none';
    });

    // Results count
    resultsCountEl.textContent = meta.resultsTemplate.replace('{count}', String(filteredCards.length));

    // No results
    noResults.classList.toggle('hidden', filteredCards.length > 0);

    // Pagination controls
    if (totalPages <= 1) {
      paginationNav.classList.add('hidden');
      paginationNav.classList.remove('flex');
    } else {
      paginationNav.classList.remove('hidden');
      paginationNav.classList.add('flex');
      renderPaginationButtons(totalPages);
    }
  }

  function renderPaginationButtons(totalPages: number) {
    pagePrev.disabled = currentPage <= 1;
    pageNext.disabled = currentPage >= totalPages;

    pageNumbers.innerHTML = '';
    const pages = getPaginationRange(currentPage, totalPages);

    for (const p of pages) {
      if (p === '...') {
        const ellipsis = document.createElement('span');
        ellipsis.className = 'px-2 py-1.5 text-sm text-maxam-gray-500';
        ellipsis.textContent = '...';
        pageNumbers.appendChild(ellipsis);
      } else {
        const btn = document.createElement('button');
        btn.className = `px-3 py-1.5 text-sm border rounded ${
          p === currentPage
            ? 'bg-maxam-blue text-maxam-white border-maxam-blue'
            : 'border-maxam-gray-300 hover:bg-maxam-gray-100'
        }`;
        btn.textContent = String(p);
        if (p === currentPage) btn.setAttribute('aria-current', 'page');
        btn.addEventListener('click', () => {
          currentPage = p as number;
          renderPage();
          syncURL('push');
          document.getElementById('product-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        pageNumbers.appendChild(btn);
      }
    }
  }

  function getPaginationRange(current: number, total: number): (number | '...')[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

    const range: (number | '...')[] = [1];
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);

    if (start > 2) range.push('...');
    for (let i = start; i <= end; i++) range.push(i);
    if (end < total - 1) range.push('...');
    range.push(total);

    return range;
  }

  /* ── Chips ────────────────────────────────────────────── */

  function renderChips(active: Record<string, Set<string>>) {
    chipsContainer.innerHTML = '';

    // Search query chip
    const q = searchInput.value.trim();
    if (q) {
      addChip(`"${q}"`, () => {
        searchInput.value = '';
        applyFilters();
      });
    }

    for (const [group, values] of Object.entries(active)) {
      const groupLabel = meta.labels[group] || group;
      const nameMap = meta[group] || {};

      for (const val of values) {
        const displayName = nameMap[val] || val;
        addChip(`${groupLabel}: ${displayName}`, () => {
          const cb = document.querySelector<HTMLInputElement>(
            `.filter-checkbox[data-filter="${group}"][data-value="${val}"]`
          );
          if (cb) cb.checked = false;
          applyFilters();
        });
      }
    }
  }

  function addChip(label: string, onRemove: () => void) {
    const chip = document.createElement('button');
    chip.className =
      'inline-flex items-center gap-1 bg-maxam-gray-100 text-maxam-gray-700 text-xs px-2 py-1 rounded-full hover:bg-maxam-gray-300';
    chip.innerHTML = `${escapeHtml(label)} <span aria-hidden="true">&times;</span>`;
    chip.setAttribute('aria-label', `Remove filter: ${label}`);
    chip.addEventListener('click', onRemove);
    chipsContainer.appendChild(chip);
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  /* ── Mobile Drawer ────────────────────────────────────── */

  function openDrawer() {
    filterSidebar.dataset.open = 'true';
    filterOverlay.classList.remove('hidden');
    mobileToggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    filterSidebar.dataset.open = 'false';
    filterOverlay.classList.add('hidden');
    mobileToggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  mobileToggle.addEventListener('click', openDrawer);
  filterClose.addEventListener('click', closeDrawer);
  filterOverlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !filterOverlay.classList.contains('hidden')) {
      closeDrawer();
    }
  });

  /* ── Event Listeners ──────────────────────────────────── */

  checkboxes.forEach((cb) => cb.addEventListener('change', () => applyFilters()));

  searchInput.addEventListener('input', () => {
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      applyFilters();
      syncURL('replace'); // Override the push from applyFilters with replace for search
    }, 300);
  });

  clearBtn.addEventListener('click', () => {
    checkboxes.forEach((cb) => (cb.checked = false));
    searchInput.value = '';
    applyFilters();
  });

  pagePrev.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderPage();
      syncURL('push');
      document.getElementById('product-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  pageNext.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      renderPage();
      syncURL('push');
      document.getElementById('product-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  window.addEventListener('popstate', () => initFromURL());

  /* ── Init ─────────────────────────────────────────────── */

  function initFromURL() {
    isInitializing = true;
    const { filters, q, page } = parseURL();

    // Set checkbox states
    checkboxes.forEach((cb) => {
      const group = cb.dataset.filter!;
      const value = cb.dataset.value!;
      cb.checked = !!filters[group]?.includes(value);
    });

    // Set search
    searchInput.value = q;

    // Set page
    currentPage = page;

    applyFilters(true);
    isInitializing = false;
  }

  initFromURL();
</script>
