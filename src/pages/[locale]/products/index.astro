---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductsViewer from '../../../components/ui/ProductsViewer.astro';
import type { Locale } from '../../../types';
import { locales, t } from '../../../lib/i18n';
import {
  getAllProducts,
  getAllIndustries,
  getAllApplications,
  getAllSizes,
  getAllRatings,
} from '../../../lib/data';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const tires = getAllProducts(locale);
const industries = getAllIndustries(locale);
const applications = getAllApplications(locale);
const allSizes = getAllSizes();
const allRatings = getAllRatings();
---

<BaseLayout locale={locale} title={t(locale, 'products.title')}>
  <!-- Hero: full-bleed image + neutral dark overlay; H1 + count inline -->
  <section
    class="products-hero"
    style="background-image:url('/images/hero-home.jpg');"
  >
    <div class="products-hero__overlay" aria-hidden="true"></div>
    <div class="products-hero__inner">
      <h1 class="products-hero__heading">
        {t(locale, 'products.title')}
      </h1>
      <span id="results-count" class="products-hero__count"></span>
    </div>
  </section>

  <div class="products-page">
    <ProductsViewer
      locale={locale}
      tires={tires}
      industries={industries}
      applications={applications}
      sizes={allSizes}
      ratings={allRatings}
      countTargetId="results-count"
    />
  </div>
</BaseLayout>
