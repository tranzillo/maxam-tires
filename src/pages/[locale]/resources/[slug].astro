---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NotionBlocks from '../../../components/NotionBlocks.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Chip from '../../../components/ui/Chip.astro';
import Button from '../../../components/ui/Button.astro';
import type { Locale } from '../../../types';
import { locales, t, localePath } from '../../../lib/i18n';
import { getAllArticles, getArticleBySlug, getArticleBlocks } from '../../../lib/data';

export function getStaticPaths() {
  const paths: Array<{ params: { locale: string; slug: string } }> = [];
  for (const locale of locales) {
    for (const article of getAllArticles(locale as Locale)) {
      // External "in the news" coverage points off-site, no detail page needed.
      if (article.externalUrl) continue;
      paths.push({ params: { locale, slug: article.slug } });
    }
  }
  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const article = getArticleBySlug(locale, slug);

if (!article) {
  return Astro.redirect(localePath(locale, '/resources'));
}

const blocks = getArticleBlocks(locale, slug);

const dateFormatted = article.date
  ? new Date(article.date).toLocaleDateString(
      locale === 'ar-ae' ? 'ar' : locale === 'zh-hant' ? 'zh-Hant' : 'en',
      { year: 'numeric', month: 'long', day: 'numeric' }
    )
  : '';

const typeLabel = t(locale, `resources.type.${article.type}`) || article.type;
---

<BaseLayout locale={locale} title={article.title}>
  <article class="article-page">
    <div class="article-page__breadcrumb">
      <Breadcrumb items={[
        { label: t(locale, 'nav.resources'), href: localePath(locale, '/resources') },
        { label: article.title },
      ]} />
    </div>

    <header class="article-page__header">
      <div class="article-page__meta">
        <Chip variant="category" size="sm">{typeLabel}</Chip>
        {article.date && (
          <time class="article-page__date" datetime={article.date}>{dateFormatted}</time>
        )}
      </div>

      <h1 class="article-page__title heading heading--lg">{article.title}</h1>

      {article.excerpt && (
        <p class="article-page__excerpt heading heading--sm">{article.excerpt}</p>
      )}
    </header>

    {article.featuredImage && (
      <figure class="article-page__figure">
        <img src={article.featuredImage} alt={article.title} loading="lazy" />
      </figure>
    )}

    <section class="prose-content">
      <NotionBlocks blocks={blocks} />
    </section>

    <div class="article-page__back">
      <Button variant="ghost" size="md" href={localePath(locale, '/resources')}>
        <span class="article-page__back-arrow" aria-hidden="true">←</span>
        {t(locale, 'nav.resources')}
      </Button>
    </div>
  </article>
</BaseLayout>
