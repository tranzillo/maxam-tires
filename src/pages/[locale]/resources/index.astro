---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ui/ArticleCard.astro';
import type { Locale } from '../../../types';
import { locales, t } from '../../../lib/i18n';
import { getAllArticles, getAllIndustries } from '../../../lib/data';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const articles = getAllArticles(locale);
const industries = getAllIndustries(locale);

const articleTypes = [
  { key: 'all', label: t(locale, 'resources.filter.all') },
  { key: 'blog', label: t(locale, 'resources.type.blog') },
  { key: 'news', label: t(locale, 'resources.type.news') },
  { key: 'event', label: t(locale, 'resources.type.event') },
  { key: 'product-sheet', label: t(locale, 'resources.type.product-sheet') },
  { key: 'brochure', label: t(locale, 'resources.type.brochure') },
];
---

<BaseLayout locale={locale} title={t(locale, 'resources.title')}>
  <section class="max-w-[var(--container-max)] mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-maxam-black mb-8">
      {t(locale, 'resources.title')}
    </h1>

    <!-- Type filter pills -->
    <div class="flex flex-wrap gap-2 mb-4">
      {articleTypes.map((type) => (
        <button
          class="type-filter-btn px-4 py-1.5 text-sm rounded-full border border-maxam-gray-300 hover:border-maxam-blue hover:text-maxam-blue transition-colors"
          data-type={type.key}
        >
          {type.label}
        </button>
      ))}
    </div>

    <!-- Industry filter pills -->
    <div class="flex flex-wrap gap-2 mb-8">
      <button
        class="industry-filter-btn px-3 py-1 text-xs rounded-full border border-maxam-gray-300 hover:border-maxam-blue transition-colors"
        data-industry="all"
      >
        {t(locale, 'resources.filter.all')}
      </button>
      {industries.map((ind) => (
        <button
          class="industry-filter-btn px-3 py-1 text-xs rounded-full border border-maxam-gray-300 hover:border-maxam-blue transition-colors"
          data-industry={ind.id}
        >
          {ind.name}
        </button>
      ))}
    </div>

    <!-- Results count -->
    <div class="flex items-center justify-between mb-4">
      <span id="results-count" class="text-sm text-maxam-gray-500"></span>
    </div>

    <!-- Article grid -->
    <div id="article-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles
        .sort((a, b) => b.date.localeCompare(a.date))
        .map((article) => (
          <ArticleCard article={article} locale={locale} showFilterData={true} />
        ))
      }
    </div>

    <!-- Pagination -->
    <nav id="pagination" class="hidden items-center justify-center gap-2 mt-8" aria-label="Pagination">
      <button id="page-prev" class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100 disabled:opacity-40 disabled:cursor-not-allowed">
        {t(locale, 'products.pagination.prev')}
      </button>
      <div id="page-numbers" class="flex gap-1"></div>
      <button id="page-next" class="px-3 py-1.5 text-sm border border-maxam-gray-300 rounded hover:bg-maxam-gray-100 disabled:opacity-40 disabled:cursor-not-allowed">
        {t(locale, 'products.pagination.next')}
      </button>
    </nav>

    <!-- No results -->
    <p id="no-results" class="hidden text-center text-maxam-gray-500 py-12">
      {t(locale, 'resources.no_results')}
    </p>
  </section>

  <!-- Filter metadata -->
  <script
    is:inline
    type="application/json"
    id="filter-meta"
    set:html={JSON.stringify({
      resultsTemplate: t(locale, 'resources.results_count'),
    })}
  />
</BaseLayout>

<script>
  const ITEMS_PER_PAGE = 12;

  const typeBtns = document.querySelectorAll<HTMLButtonElement>('.type-filter-btn');
  const industryBtns = document.querySelectorAll<HTMLButtonElement>('.industry-filter-btn');
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.article-card'));
  const noResults = document.getElementById('no-results')!;
  const resultsCountEl = document.getElementById('results-count')!;
  const paginationNav = document.getElementById('pagination')!;
  const pagePrev = document.getElementById('page-prev') as HTMLButtonElement;
  const pageNext = document.getElementById('page-next') as HTMLButtonElement;
  const pageNumbers = document.getElementById('page-numbers')!;
  const meta = JSON.parse(document.getElementById('filter-meta')!.textContent!);

  let activeType = 'all';
  let activeIndustry = 'all';
  let filteredCards: HTMLElement[] = [];
  let currentPage = 1;

  function applyFilters() {
    filteredCards = allCards.filter((card) => {
      const typeMatch = activeType === 'all' || card.dataset.type === activeType;
      const indMatch = activeIndustry === 'all' || (card.dataset.industries ?? '').split(',').includes(activeIndustry);
      return typeMatch && indMatch;
    });
    currentPage = 1;
    renderPage();
    syncURL();
  }

  function renderPage() {
    const totalPages = Math.max(1, Math.ceil(filteredCards.length / ITEMS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    const visibleSet = new Set(filteredCards.slice(start, end));

    allCards.forEach((card) => {
      card.style.display = visibleSet.has(card) ? '' : 'none';
    });

    resultsCountEl.textContent = meta.resultsTemplate.replace('{count}', String(filteredCards.length));
    noResults.classList.toggle('hidden', filteredCards.length > 0);

    if (totalPages <= 1) {
      paginationNav.classList.add('hidden');
      paginationNav.classList.remove('flex');
    } else {
      paginationNav.classList.remove('hidden');
      paginationNav.classList.add('flex');
      renderPaginationButtons(totalPages);
    }
  }

  function renderPaginationButtons(totalPages: number) {
    pagePrev.disabled = currentPage <= 1;
    pageNext.disabled = currentPage >= totalPages;
    pageNumbers.innerHTML = '';

    const range = getPaginationRange(currentPage, totalPages);
    for (const p of range) {
      if (p === '...') {
        const el = document.createElement('span');
        el.className = 'px-2 py-1.5 text-sm text-maxam-gray-500';
        el.textContent = '...';
        pageNumbers.appendChild(el);
      } else {
        const btn = document.createElement('button');
        btn.className = `px-3 py-1.5 text-sm border rounded ${
          p === currentPage ? 'bg-maxam-blue text-maxam-white border-maxam-blue' : 'border-maxam-gray-300 hover:bg-maxam-gray-100'
        }`;
        btn.textContent = String(p);
        if (p === currentPage) btn.setAttribute('aria-current', 'page');
        btn.addEventListener('click', () => { currentPage = p as number; renderPage(); syncURL(); });
        pageNumbers.appendChild(btn);
      }
    }
  }

  function getPaginationRange(current: number, total: number): (number | '...')[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const range: (number | '...')[] = [1];
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);
    if (start > 2) range.push('...');
    for (let i = start; i <= end; i++) range.push(i);
    if (end < total - 1) range.push('...');
    range.push(total);
    return range;
  }

  function syncURL() {
    const params = new URLSearchParams();
    if (activeType !== 'all') params.set('type', activeType);
    if (activeIndustry !== 'all') params.set('industry', activeIndustry);
    if (currentPage > 1) params.set('page', String(currentPage));
    const search = params.toString();
    history.replaceState(null, '', window.location.pathname + (search ? '?' + search : ''));
  }

  function initFromURL() {
    const params = new URLSearchParams(window.location.search);
    activeType = params.get('type') || 'all';
    activeIndustry = params.get('industry') || 'all';
    currentPage = Math.max(1, parseInt(params.get('page') || '1', 10));
    updateButtonStates();
    filteredCards = allCards.filter((card) => {
      const typeMatch = activeType === 'all' || card.dataset.type === activeType;
      const indMatch = activeIndustry === 'all' || (card.dataset.industries ?? '').split(',').includes(activeIndustry);
      return typeMatch && indMatch;
    });
    renderPage();
  }

  function updateButtonStates() {
    typeBtns.forEach((btn) => {
      const isActive = btn.dataset.type === activeType;
      btn.classList.toggle('bg-maxam-blue', isActive);
      btn.classList.toggle('text-maxam-white', isActive);
      btn.classList.toggle('border-maxam-blue', isActive);
    });
    industryBtns.forEach((btn) => {
      const isActive = btn.dataset.industry === activeIndustry;
      btn.classList.toggle('bg-maxam-blue', isActive);
      btn.classList.toggle('text-maxam-white', isActive);
      btn.classList.toggle('border-maxam-blue', isActive);
    });
  }

  // Event listeners
  typeBtns.forEach((btn) => btn.addEventListener('click', () => {
    activeType = btn.dataset.type!;
    updateButtonStates();
    applyFilters();
  }));

  industryBtns.forEach((btn) => btn.addEventListener('click', () => {
    activeIndustry = btn.dataset.industry!;
    updateButtonStates();
    applyFilters();
  }));

  pagePrev.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); syncURL(); } });
  pageNext.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) { currentPage++; renderPage(); syncURL(); }
  });

  window.addEventListener('popstate', () => initFromURL());
  initFromURL();
</script>
